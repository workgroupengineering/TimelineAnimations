  </Style>

  <Style Selector="dockControls|ToolChromeControl /template/ Panel#PART_Panel">
    <Setter Property="Background" Value="{DynamicResource DockBorderStrongBrush}" />
  </Style>

  <Style Selector="Button.color-field-swatch">
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="{DynamicResource InspectorFieldMinHeight}" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="Background" Value="{DynamicResource ControlSurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="Button.color-field-swatch:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
  </Style>

  <Style Selector="Button.color-field-swatch:pressed">
    <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
  </Style>

  <Style Selector="Border.color-field-swatch-preview">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderBrush" Value="#D9E2EC" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinWidth" Value="18" />
    <Setter Property="MinHeight" Value="18" />
  </Style>

  <Style Selector="Border.color-picker-popup">
    <Setter Property="Padding" Value="10" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{DynamicResource PanelSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 10 28 0 #70000000" />
  </Style>

  <Style Selector="Border.color-picker-preview">
    <Setter Property="MinHeight" Value="52" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="Border.color-picker-preview-previous">
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Opacity" Value="0.78" />
  </Style>

  <Style Selector="Button.color-picker-utility-button">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <Style Selector="Button.color-preset-button">
    <Setter Property="MinWidth" Value="22" />
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Margin" Value="0,0,4,4" />
  </Style>

  <Style Selector="Button.color-preset-button:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
  </Style>
</Styles>
