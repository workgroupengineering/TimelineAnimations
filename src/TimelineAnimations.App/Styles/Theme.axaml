<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#050915" />
    <SolidColorBrush x:Key="PanelBrush" Color="#0B1220" />
    <SolidColorBrush x:Key="PanelSoftBrush" Color="#0D1628" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#1E2C46" />
    <SolidColorBrush x:Key="PanelStrongBorderBrush" Color="#304872" />
    <SolidColorBrush x:Key="AccentMintBrush" Color="#24E5C1" />
    <SolidColorBrush x:Key="AccentWarmBrush" Color="#FF8A4C" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#ECF2FF" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#92A7D1" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7F9F" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="30" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="0 18 50 0 #42000000" />
  </Style>

  <Style Selector="Border.panel-soft">
    <Setter Property="Background" Value="{DynamicResource PanelSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="24" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.palette-card">
    <Setter Property="Padding" Value="16" />
    <Setter Property="BoxShadow" Value="0 12 30 0 #30000000" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.eyebrow">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="LetterSpacing" Value="0.9" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.strong-label">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.micro-label">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="Background" Value="#121C2F" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStrongBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#17253D" />
    <Setter Property="BorderBrush" Value="#4E74AB" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#1A4C45" />
    <Setter Property="BorderBrush" Value="#5AF0D0" />
  </Style>

  <Style Selector="Button.warm">
    <Setter Property="Background" Value="#4B2718" />
    <Setter Property="BorderBrush" Value="#FFB685" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="#09111C" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#223354" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Foreground" Value="{DynamicResource AccentMintBrush}" />
  </Style>

  <Style Selector="ToggleButton">
    <Setter Property="Background" Value="#10192A" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#223354" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="14,10" />
  </Style>

  <Style Selector="ToggleButton:checked">
    <Setter Property="Background" Value="#143A35" />
    <Setter Property="BorderBrush" Value="#55E9CA" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem:selected Border.layer-row">
    <Setter Property="BorderBrush" Value="#9BFFF0" />
    <Setter Property="Background" Value="#132135" />
  </Style>

  <Style Selector="Border.layer-row">
    <Setter Property="Background" Value="#0D1626" />
    <Setter Property="BorderBrush" Value="#1E2C46" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="14" />
  </Style>
</Styles>
