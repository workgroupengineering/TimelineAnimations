  <ControlTheme x:Key="StudioButtonTheme"
                TargetType="Button"
                BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Background" Value="{DynamicResource ControlSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="{DynamicResource ButtonPadding}" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="FontSize" Value="10.75" />
    <Setter Property="FontWeight" Value="SemiBold" />

    <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>

    <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
    </Style>

    <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
      <Setter Property="BorderBrush" Value="#11151A" />
      <Setter Property="Foreground" Value="#7A8390" />
    </Style>

    <Style Selector="^.accent /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SelectionFillStrongBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
    </Style>

    <Style Selector="^.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#3591D7" />
      <Setter Property="BorderBrush" Value="#73DAFF" />
    </Style>

    <Style Selector="^.warm /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource WarmFillBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
    </Style>

    <Style Selector="^.warm:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#8E6836" />
      <Setter Property="BorderBrush" Value="#F7B85B" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioToggleButtonTheme"
                TargetType="ToggleButton"
                BasedOn="{StaticResource {x:Type ToggleButton}}">
    <Setter Property="Background" Value="{DynamicResource ControlSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="{DynamicResource ButtonPadding}" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="FontSize" Value="10.75" />
    <Setter Property="FontWeight" Value="SemiBold" />

    <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>

    <Style Selector="^:checked /template/ ContentPresenter#PART_ContentPresenter, ^:indeterminate /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SelectionFillBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
    </Style>

    <Style Selector="^:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter, ^:indeterminate:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SelectionFillStrongBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
    </Style>

    <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
    </Style>

    <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
      <Setter Property="BorderBrush" Value="#11151A" />
      <Setter Property="Foreground" Value="#7A8390" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioTextBoxTheme"
                TargetType="TextBox"
                BasedOn="{StaticResource {x:Type TextBox}}">
    <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="MinHeight" Value="{DynamicResource TextControlThemeMinHeight}" />
    <Setter Property="Padding" Value="{DynamicResource TextControlThemePadding}" />
    <Setter Property="FontSize" Value="10.75" />

    <Style Selector="^ /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^ /template/ TextBlock#PART_Watermark, ^ /template/ TextBlock#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="{DynamicResource FieldPlaceholderBrush}" />
      <Setter Property="FontSize" Value="10.25" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>

    <Style Selector="^:focus-visible /template/ Border#PART_BorderElement, ^:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource FieldFocusBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlFocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="^:disabled /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
      <Setter Property="BorderBrush" Value="#11151A" />
    </Style>

    <Style Selector="^:disabled /template/ TextBlock#PART_Watermark, ^:disabled /template/ TextBlock#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="{DynamicResource FieldDisabledForegroundBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioComboBoxTheme"
                TargetType="ComboBox"
                BasedOn="{StaticResource {x:Type ComboBox}}">
    <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="MinHeight" Value="{DynamicResource ComboBoxMinHeight}" />
    <Setter Property="Padding" Value="{DynamicResource ComboBoxPadding}" />
    <Setter Property="FontSize" Value="10.75" />

    <Style Selector="^ /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^ /template/ Border#PopupBorder">
      <Setter Property="Background" Value="#252D36" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="^ /template/ Border#HighlightBackground">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^ /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="{DynamicResource FieldPlaceholderBrush}" />
    </Style>

    <Style Selector="^ /template/ PathIcon#DropDownGlyph">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>

    <Style Selector="^:focus-visible /template/ Border#HighlightBackground, ^:focus /template/ Border#HighlightBackground">
      <Setter Property="IsVisible" Value="True" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlFocusBorderBrush}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
    </Style>

    <Style Selector="^:disabled /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
      <Setter Property="BorderBrush" Value="#11151A" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioCheckBoxTheme"
                TargetType="CheckBox"
                BasedOn="{StaticResource {x:Type CheckBox}}">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="Padding" Value="6,0,0,0" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="10.75" />

    <Style Selector="^ /template/ Border#PART_Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="^ /template/ Border#NormalRectangle">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#NormalRectangle">
      <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>

    <Style Selector="^:checked /template/ Border#NormalRectangle, ^:indeterminate /template/ Border#NormalRectangle">
      <Setter Property="Background" Value="{DynamicResource SelectionFillStrongBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
    </Style>

    <Style Selector="^:checked /template/ Path#CheckGlyph, ^:indeterminate /template/ Path#CheckGlyph">
      <Setter Property="Fill" Value="#F5F7FA" />
    </Style>

    <Style Selector="^:disabled /template/ Border#NormalRectangle">
      <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
      <Setter Property="BorderBrush" Value="#11151A" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioTabItemTheme"
                TargetType="TabItem"
                BasedOn="{StaticResource {x:Type TabItem}}">
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Background" Value="{DynamicResource ChromeSoftBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{DynamicResource TabItemHeaderMargin}" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Margin" Value="0,0,2,0" />

    <Style Selector="^ /template/ Border#PART_LayoutRoot">
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^ /template/ Border#PART_SelectedPipe">
      <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
      <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="^:selected">
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#4B5564" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioMenuItemTheme"
                TargetType="MenuItem"
                BasedOn="{StaticResource {x:Type MenuItem}}">
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />

    <Style Selector="^ /template/ Border#PART_LayoutRoot">
      <Setter Property="CornerRadius" Value="5" />
    </Style>

    <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource MenuFlyoutItemBackgroundPointerOver}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#PART_LayoutRoot:pointerover">
      <Setter Property="Background" Value="{DynamicResource MenuFlyoutItemBackgroundPressed}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioMenuBarItemTheme"
                TargetType="MenuItem"
                BasedOn="{StaticResource HorizontalMenuItem}">
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="Margin" Value="0,0,2,0" />
    <Setter Property="Foreground" Value="#EDF2F8" />
    <Setter Property="Background" Value="Transparent" />

    <Style Selector="^ /template/ Border#PART_LayoutRoot">
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="^:selected /template/ Border#PART_LayoutRoot, ^:open /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#566273" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#4B5665" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioToolbarMenuItemTheme"
                TargetType="MenuItem"
                BasedOn="{StaticResource HorizontalMenuItem}">
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Margin" Value="0,0,4,0" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />

    <Style Selector="^ /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#313C48" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="^:selected /template/ Border#PART_LayoutRoot, ^:open /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#516172" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#3C4857" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioScrollBarTheme"
                TargetType="ScrollBar"
                BasedOn="{StaticResource {x:Type ScrollBar}}">
    <Setter Property="Background" Value="{DynamicResource ScrollBarBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ScrollBarBorderBrush}" />

    <Style Selector="^ /template/ Rectangle#TrackRect">
      <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="^:pointerover /template/ Rectangle#TrackRect">
      <Setter Property="Opacity" Value="0.8" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioSliderHorizontalRepeatButtonTheme"
                TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid MinHeight="{DynamicResource SliderHorizontalHeight}">
          <Border x:Name="TrackSegment"
                  Height="{DynamicResource SliderTrackThemeHeight}"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{DynamicResource SliderTrackCornerRadius}"
                  VerticalAlignment="Center" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="StudioSliderVerticalRepeatButtonTheme"
                TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid MinWidth="{DynamicResource SliderVerticalWidth}">
          <Border x:Name="TrackSegment"
                  Width="{DynamicResource SliderTrackThemeHeight}"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{DynamicResource SliderTrackCornerRadius}"
                  HorizontalAlignment="Center" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="StudioSliderThumbTheme"
                TargetType="Thumb">
    <Setter Property="Background" Value="{DynamicResource SliderThumbBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SliderThumbBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{DynamicResource SliderThumbCornerRadius}">
          <Border Margin="1"
                  CornerRadius="{DynamicResource SliderThumbCornerRadius}"
                  BorderBrush="#18FFFFFF"
                  BorderThickness="1"
                  Opacity="0.75" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="StudioSliderTheme"
                TargetType="Slider"
                BasedOn="{StaticResource {x:Type Slider}}">
    <Setter Property="Background" Value="{DynamicResource SliderTrackFill}" />
    <Setter Property="BorderThickness" Value="{DynamicResource SliderBorderThemeThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource SliderTrackValueFill}" />
    <Setter Property="MinHeight" Value="{DynamicResource SliderHorizontalHeight}" />
    <Setter Property="Margin" Value="0,1" />

    <Style Selector="^:horizontal">
      <Setter Property="Template">
        <ControlTemplate>
          <DataValidationErrors>
            <Border x:Name="FocusTarget"
                    Padding="{TemplateBinding Padding}"
                    Background="{DynamicResource SliderContainerBackground}"
                    CornerRadius="{DynamicResource SliderTrackCornerRadius}">
              <Grid x:Name="SliderContainer">
                <Grid.Styles>
                  <Style Selector="TickBar">
                    <Setter Property="ReservedSpace" Value="{Binding #PART_Track.Thumb.Bounds}" />
                  </Style>
                </Grid.Styles>
                <Grid MinHeight="{DynamicResource SliderHorizontalHeight}"
                      ColumnDefinitions="Auto,Auto,*">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="{DynamicResource SliderPreContentMargin}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{DynamicResource SliderPostContentMargin}" />
                  </Grid.RowDefinitions>
                  <TickBar Name="TopTickBar"
                           Grid.ColumnSpan="3"
                           Ticks="{TemplateBinding Ticks}"
                           TickFrequency="{TemplateBinding Slider.TickFrequency}"
                           Orientation="{TemplateBinding Slider.Orientation}"
                           Minimum="{TemplateBinding Slider.Minimum}"
                           Maximum="{TemplateBinding Slider.Maximum}"
                           Height="{DynamicResource SliderOutsideTickBarThemeHeight}"
                           Margin="0,0,0,4"
                           VerticalAlignment="Bottom"
                           Placement="Top"
                           IsVisible="False"
                           IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                           Fill="{DynamicResource SliderTickBarFill}" />
                  <TickBar Name="BottomTickBar"
                           Grid.Row="2"
                           Grid.ColumnSpan="3"
                           Ticks="{TemplateBinding Ticks}"
                           TickFrequency="{TemplateBinding Slider.TickFrequency}"
                           Orientation="{TemplateBinding Slider.Orientation}"
                           Minimum="{TemplateBinding Slider.Minimum}"
                           Maximum="{TemplateBinding Slider.Maximum}"
                           Height="{DynamicResource SliderOutsideTickBarThemeHeight}"
                           Margin="0,4,0,0"
                           VerticalAlignment="Top"
                           Placement="Bottom"
                           IsVisible="False"
                           IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                           Fill="{DynamicResource SliderTickBarFill}" />
                  <Track Name="PART_Track"
                         Grid.Row="1"
                         Grid.ColumnSpan="3"
                         Minimum="{TemplateBinding Minimum}"
                         Maximum="{TemplateBinding Maximum}"
                         Value="{TemplateBinding Value, Mode=TwoWay}"
                         IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                         Orientation="Horizontal">
                    <Track.DecreaseButton>
                      <RepeatButton Name="PART_DecreaseButton"
                                    Theme="{StaticResource StudioSliderHorizontalRepeatButtonTheme}"
                                    Background="{TemplateBinding Foreground}"
                                    Focusable="False" />
                    </Track.DecreaseButton>
                    <Track.IncreaseButton>
                      <RepeatButton Name="PART_IncreaseButton"
                                    Theme="{StaticResource StudioSliderHorizontalRepeatButtonTheme}"
                                    Background="{TemplateBinding Background}"
                                    Focusable="False" />
                    </Track.IncreaseButton>
                    <Thumb Name="thumb"
                           Width="{DynamicResource SliderHorizontalThumbWidth}"
                           Height="{DynamicResource SliderHorizontalThumbHeight}"
                           Theme="{StaticResource StudioSliderThumbTheme}"
                           Background="{DynamicResource SliderThumbBackground}"
                           BorderBrush="{DynamicResource SliderThumbBorderBrush}"
                           BorderThickness="1" />
                  </Track>
                </Grid>
              </Grid>
            </Border>
          </DataValidationErrors>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="^:vertical">
      <Setter Property="Template">
        <ControlTemplate>
          <DataValidationErrors>
            <Border x:Name="FocusTarget"
                    Padding="{TemplateBinding Padding}"
                    Background="{DynamicResource SliderContainerBackground}"
                    CornerRadius="{DynamicResource SliderTrackCornerRadius}">
              <Grid x:Name="SliderContainer">
                <Grid.Styles>
                  <Style Selector="TickBar">
                    <Setter Property="ReservedSpace" Value="{Binding #PART_Track.Thumb.Bounds}" />
                  </Style>
                </Grid.Styles>
                <Grid MinWidth="{DynamicResource SliderVerticalWidth}"
                      RowDefinitions="*,Auto,Auto">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{DynamicResource SliderPreContentMargin}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource SliderPostContentMargin}" />
                  </Grid.ColumnDefinitions>
                  <TickBar Name="LeftTickBar"
                           Grid.RowSpan="3"
                           Ticks="{TemplateBinding Ticks}"
                           TickFrequency="{TemplateBinding Slider.TickFrequency}"
                           Orientation="{TemplateBinding Slider.Orientation}"
                           Minimum="{TemplateBinding Slider.Minimum}"
                           Maximum="{TemplateBinding Slider.Maximum}"
                           Width="{DynamicResource SliderOutsideTickBarThemeHeight}"
                           Margin="0,0,4,0"
                           HorizontalAlignment="Right"
                           Placement="Left"
                           IsVisible="False"
                           IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                           Fill="{DynamicResource SliderTickBarFill}" />
                  <TickBar Name="RightTickBar"
                           Grid.RowSpan="3"
                           Grid.Column="2"
                           Ticks="{TemplateBinding Ticks}"
                           TickFrequency="{TemplateBinding Slider.TickFrequency}"
                           Orientation="{TemplateBinding Slider.Orientation}"
                           Minimum="{TemplateBinding Slider.Minimum}"
                           Maximum="{TemplateBinding Slider.Maximum}"
                           Width="{DynamicResource SliderOutsideTickBarThemeHeight}"
                           Margin="4,0,0,0"
                           HorizontalAlignment="Left"
                           Placement="Right"
                           IsVisible="False"
                           IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                           Fill="{DynamicResource SliderTickBarFill}" />
                  <Track Name="PART_Track"
                         Grid.RowSpan="3"
                         Grid.Column="1"
                         Minimum="{TemplateBinding Minimum}"
                         Maximum="{TemplateBinding Maximum}"
                         Value="{TemplateBinding Value, Mode=TwoWay}"
                         IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                         Orientation="Vertical">
                    <Track.DecreaseButton>
                      <RepeatButton Name="PART_DecreaseButton"
                                    Theme="{StaticResource StudioSliderVerticalRepeatButtonTheme}"
                                    Background="{TemplateBinding Foreground}"
                                    Focusable="False" />
                    </Track.DecreaseButton>
                    <Track.IncreaseButton>
                      <RepeatButton Name="PART_IncreaseButton"
                                    Theme="{StaticResource StudioSliderVerticalRepeatButtonTheme}"
                                    Background="{TemplateBinding Background}"
                                    Focusable="False" />
                    </Track.IncreaseButton>
                    <Thumb Name="thumb"
                           Width="{DynamicResource SliderVerticalThumbWidth}"
                           Height="{DynamicResource SliderVerticalThumbHeight}"
                           Theme="{StaticResource StudioSliderThumbTheme}"
                           Background="{DynamicResource SliderThumbBackground}"
                           BorderBrush="{DynamicResource SliderThumbBorderBrush}"
                           BorderThickness="1" />
                  </Track>
                </Grid>
              </Grid>
            </Border>
          </DataValidationErrors>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="^[TickPlacement=TopLeft] /template/ TickBar#LeftTickBar, ^[TickPlacement=Outside] /template/ TickBar#LeftTickBar">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="^[TickPlacement=TopLeft] /template/ TickBar#TopTickBar, ^[TickPlacement=Outside] /template/ TickBar#TopTickBar">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="^[TickPlacement=BottomRight] /template/ TickBar#BottomTickBar, ^[TickPlacement=Outside] /template/ TickBar#BottomTickBar">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="^[TickPlacement=BottomRight] /template/ TickBar#RightTickBar, ^[TickPlacement=Outside] /template/ TickBar#RightTickBar">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="^ /template/ Thumb#thumb">
      <Setter Property="Background" Value="{DynamicResource SliderThumbBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SliderThumbBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="^:pointerover /template/ Border#FocusTarget">
      <Setter Property="Background" Value="{DynamicResource SliderContainerBackgroundPointerOver}" />
    </Style>

    <Style Selector="^:pointerover /template/ RepeatButton#PART_DecreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackValueFillPointerOver}" />
    </Style>

    <Style Selector="^:pointerover /template/ RepeatButton#PART_IncreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackFillPointerOver}" />
    </Style>

    <Style Selector="^:pointerover /template/ Thumb#thumb">
      <Setter Property="Background" Value="{DynamicResource SliderThumbBackgroundPointerOver}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SliderThumbBorderBrushPointerOver}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#FocusTarget">
      <Setter Property="Background" Value="{DynamicResource SliderContainerBackgroundPressed}" />
    </Style>

    <Style Selector="^:pressed /template/ RepeatButton#PART_DecreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackValueFillPressed}" />
    </Style>

    <Style Selector="^:pressed /template/ RepeatButton#PART_IncreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackFillPressed}" />
    </Style>

    <Style Selector="^:pressed /template/ Thumb#thumb">
      <Setter Property="Background" Value="{DynamicResource SliderThumbBackgroundPressed}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SliderThumbBorderBrushPressed}" />
    </Style>

    <Style Selector="^:focus-visible /template/ Border#FocusTarget">
      <Setter Property="BorderBrush" Value="{DynamicResource ControlFocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="^:disabled /template/ RepeatButton#PART_DecreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackValueFillDisabled}" />
    </Style>

    <Style Selector="^:disabled /template/ RepeatButton#PART_IncreaseButton">
      <Setter Property="Background" Value="{DynamicResource SliderTrackFillDisabled}" />
    </Style>

    <Style Selector="^:disabled /template/ Thumb#thumb">
      <Setter Property="Background" Value="{DynamicResource SliderThumbBackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SliderThumbBorderBrushDisabled}" />
    </Style>

    <Style Selector="^:disabled /template/ TickBar">
      <Setter Property="Fill" Value="{DynamicResource SliderTickBarFillDisabled}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="StudioListBoxTheme"
                TargetType="ListBox"
                BasedOn="{StaticResource {x:Type ListBox}}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{DynamicResource DenseListPadding}" />
  </ControlTheme>

  <ControlTheme x:Key="StudioListBoxItemTheme"
                TargetType="ListBoxItem"
                BasedOn="{StaticResource {x:Type ListBoxItem}}">
    <Setter Property="Margin" Value="0,0,0,3" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="{DynamicResource ListRowMinHeight}" />
  </ControlTheme>

  <ControlTheme x:Key="StudioProgressBarTheme"
                TargetType="ProgressBar"
                BasedOn="{StaticResource {x:Type ProgressBar}}">
    <Setter Property="Foreground" Value="{DynamicResource AccentMintBrush}" />
    <Setter Property="Background" Value="#18212B" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="{DynamicResource ProgressBarThemeMinHeight}" />
    <Setter Property="CornerRadius" Value="999" />
  </ControlTheme>

  <ControlTheme x:Key="StudioToolTipTheme"
                TargetType="ToolTip"
                BasedOn="{StaticResource {x:Type ToolTip}}">
    <Setter Property="Background" Value="#2A323B" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#151A20" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
