<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#252A31" />
    <LinearGradientBrush x:Key="ChromeBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
      <GradientStop Color="#4E5968" Offset="0" />
      <GradientStop Color="#424B58" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ChromeSoftBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
      <GradientStop Color="#5B6677" Offset="0" />
      <GradientStop Color="#4D5766" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
      <GradientStop Color="#495462" Offset="0" />
      <GradientStop Color="#3E4854" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelSoftBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
      <GradientStop Color="#3A434D" Offset="0" />
      <GradientStop Color="#303842" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#1F242B" />
    <SolidColorBrush x:Key="PanelStrongBorderBrush" Color="#7F8B9D" />
    <LinearGradientBrush x:Key="StageWorkspaceBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
      <GradientStop Color="#2D343D" Offset="0" />
      <GradientStop Color="#212830" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="StageInsetBrush" Color="#1F252D" />
    <SolidColorBrush x:Key="AccentMintBrush" Color="#57C9FF" />
    <SolidColorBrush x:Key="AccentWarmBrush" Color="#F3A33C" />
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="#F4C94E" />
    <SolidColorBrush x:Key="MetricChipBrush" Color="#37404C" />
    <SolidColorBrush x:Key="MetricChipBorderBrush" Color="#242A32" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FA" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CDD5E0" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A0A9B8" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter#Inter" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="BoxShadow" Value="0 3 10 0 #12000000" />
  </Style>

  <Style Selector="Border.panel-soft">
    <Setter Property="Background" Value="{DynamicResource PanelSoftBrush}" />
    <Setter Property="BorderBrush" Value="#262C34" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style Selector="Border.chrome">
    <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
    <Setter Property="BorderBrush" Value="#171B20" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="5,3" />
    <Setter Property="BoxShadow" Value="0 4 12 0 #16000000" />
  </Style>

  <Style Selector="Border.chrome-soft">
    <Setter Property="Background" Value="{DynamicResource ChromeSoftBrush}" />
    <Setter Property="BorderBrush" Value="#20252B" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="4,3" />
  </Style>

  <Style Selector="Border.chrome-group">
    <Setter Property="Background" Value="#333D47" />
    <Setter Property="BorderBrush" Value="#21262D" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="5,3" />
  </Style>

  <Style Selector="Border.metric-chip">
    <Setter Property="Background" Value="{DynamicResource MetricChipBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MetricChipBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,4" />
  </Style>

  <Style Selector="Border.workspace-summary-chip">
    <Setter Property="Background" Value="#303944" />
    <Setter Property="BorderBrush" Value="#20262D" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,4" />
  </Style>

  <Style Selector="Border.stage-workspace">
    <Setter Property="Background" Value="{DynamicResource StageWorkspaceBrush}" />
    <Setter Property="BorderBrush" Value="#1A1E24" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="7" />
  </Style>

  <Style Selector="Border.workspace-tab">
    <Setter Property="Background" Value="#4A5260" />
    <Setter Property="BorderBrush" Value="#232931" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,3" />
  </Style>

  <Style Selector="Border.workspace-tab.active">
    <Setter Property="Background" Value="#687285" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="Border.palette-card">
    <Setter Property="Padding" Value="8" />
    <Setter Property="BoxShadow" Value="0 4 12 0 #1A000000" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.eyebrow">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="0.45" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.strong-label">
    <Setter Property="FontSize" Value="11.25" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.micro-label">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.menu-label">
    <Setter Property="FontSize" Value="10.25" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="0.35" />
    <Setter Property="Foreground" Value="#E9EEF5" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Background" Value="#616C7B" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#20252C" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#748092" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#525B69" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#4E6C8E" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentMintBrush}" />
  </Style>

  <Style Selector="Button.warm">
    <Setter Property="Background" Value="#7A5A33" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
  </Style>

  <Style Selector="Button.toolbar">
    <Setter Property="Padding" Value="5,2" />
    <Setter Property="MinHeight" Value="21" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="Button.edge-handle">
    <Setter Property="Padding" Value="7,2" />
    <Setter Property="MinHeight" Value="18" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="#36414D" />
    <Setter Property="BorderBrush" Value="#1D242C" />
    <Setter Property="FontSize" Value="10.25" />
    <Setter Property="Opacity" Value="0.92" />
  </Style>

  <Style Selector="Button.edge-handle:pointerover">
    <Setter Property="Background" Value="#44505F" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.tool">
    <Setter Property="Padding" Value="7,4" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Background" Value="#586271" />
  </Style>

  <Style Selector="Button.tool-rail">
    <Setter Property="Padding" Value="6,6" />
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="Button.timeline-action">
    <Setter Property="Padding" Value="9,4" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="ToggleButton.timeline-action">
    <Setter Property="Padding" Value="9,4" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="ToggleButton.timeline-tab">
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="10.75" />
    <Setter Property="Background" Value="#3A4654" />
    <Setter Property="BorderBrush" Value="#1C2229" />
  </Style>

  <Style Selector="ToggleButton.timeline-tab:checked">
    <Setter Property="Background" Value="#5C6A7C" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="Menu.timeline-toolbar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="MenuItem.timeline-toolbar-item">
    <Setter Property="Background" Value="#3A4654" />
    <Setter Property="BorderBrush" Value="#1C2229" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Margin" Value="0,0,4,0" />
    <Setter Property="FontSize" Value="10.75" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="MenuItem.timeline-toolbar-item:selected">
    <Setter Property="Background" Value="#5C6A7C" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="Border.timeline-resize-grip">
    <Setter Property="Background" Value="#39414B" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Opacity" Value="0.72" />
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>

  <Style Selector="Border.timeline-resize-grip:pointerover">
    <Setter Property="Background" Value="#5B6778" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="#2C323A" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#1C2128" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="5,3" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="TextBox.timeline-entry">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="6,4" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="#2C323A" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#1C2128" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="#2C323A" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#1C2128" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="NumericUpDown.timeline-entry">
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Foreground" Value="{DynamicResource AccentMintBrush}" />
  </Style>

  <Style Selector="ToggleButton">
    <Setter Property="Background" Value="#596273" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#20252C" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="ToggleButton:checked">
    <Setter Property="Background" Value="#4E6C8E" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="ToggleButton.toolbar">
    <Setter Property="Padding" Value="5,2" />
    <Setter Property="MinHeight" Value="21" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontSize" Value="10.75" />
  </Style>

  <Style Selector="TabControl.dock-tabs">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="FontSize" Value="10.25" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Background" Value="#586171" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#1D2229" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="7,3" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="#6D788A" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Margin" Value="0,0,0,3" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem:selected Border.layer-row">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentSelectionBrush}" />
    <Setter Property="Background" Value="#5F6978" />
  </Style>

  <Style Selector="Border.layer-row">
    <Setter Property="Background" Value="#454E5A" />
    <Setter Property="BorderBrush" Value="#262C33" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="Background" Value="#2F3843" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#1F252C" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,4" />
  </Style>

  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="#353E49" />
    <Setter Property="BorderBrush" Value="#1F252C" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="7,4" />
  </Style>

  <Style Selector="MenuItem:selected">
    <Setter Property="Background" Value="#4D5A69" />
  </Style>

  <Style Selector="GridSplitter.panel-splitter">
    <Setter Property="Background" Value="#39414B" />
    <Setter Property="ShowsPreview" Value="True" />
    <Setter Property="DragIncrement" Value="1" />
    <Setter Property="KeyboardIncrement" Value="10" />
  </Style>

  <Style Selector="GridSplitter.panel-splitter:pointerover">
    <Setter Property="Background" Value="#566172" />
  </Style>

  <Style Selector="GridSplitter.panel-splitter:pressed">
    <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
  </Style>

  <Style Selector="GridSplitter.panel-splitter.vertical">
    <Setter Property="Cursor" Value="SizeWestEast" />
  </Style>

  <Style Selector="GridSplitter.panel-splitter.horizontal">
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>
</Styles>
