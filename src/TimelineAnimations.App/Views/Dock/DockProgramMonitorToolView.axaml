<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TimelineAnimations.App.ViewModels.Dock"
             x:Class="TimelineAnimations.App.Views.Dock.DockProgramMonitorToolView"
             x:DataType="vm:DockProgramMonitorToolViewModel">
  <Grid RowDefinitions="Auto,*"
        RowSpacing="4">
    <Border Classes="chrome-group"
            Padding="4,3">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="8">
        <StackPanel Spacing="1">
          <TextBlock Classes="monitor-label"
                     Text="Program monitor" />
          <TextBlock Classes="micro-label"
                     Text="{Binding Host.ProgramMonitorSummary}"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <Border Grid.Column="1"
                Classes="metric-chip compact">
          <TextBlock Classes="strong-label"
                     Text="{Binding Host.CurrentSceneInFrameLabel}" />
        </Border>
        <Border Grid.Column="2"
                Classes="metric-chip compact">
          <TextBlock Classes="strong-label"
                     Text="{Binding Host.CurrentSceneOutFrameLabel}" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="panel-soft monitor-card">
      <Grid RowDefinitions="*,Auto"
            RowSpacing="6">
        <Border Classes="panel-soft"
                Padding="6"
                MinHeight="180">
          <Image Source="{Binding Host.ProgramMonitorBitmap}"
                 Stretch="Uniform"
                 IsVisible="{Binding Host.HasProgramMonitorBitmap}" />
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
          <TextBlock Classes="micro-label"
                     VerticalAlignment="Center"
                     Text="{Binding Host.CurrentSceneWorkAreaLabel}" />
          <CheckBox Grid.Column="1"
                    Content="Work area"
                    IsChecked="{Binding Host.UseWorkAreaPlayback, Mode=TwoWay}" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
