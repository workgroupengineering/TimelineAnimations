<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dockControls="using:Dock.Avalonia.Controls"
             xmlns:vm="using:TimelineAnimations.App.ViewModels.Dock"
             x:Class="TimelineAnimations.App.Views.Dock.DockWorkspaceHostView"
             x:DataType="vm:DockWorkspaceHostViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*"
        RowSpacing="4">
    <Border Classes="chrome-group command-strip animate-workspace-strip"
            Padding="6,4">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Border Classes="workspace-tab active">
            <TextBlock Classes="strong-label"
                       Text="Essentials" />
          </Border>
          <Button Classes="toolbar compact workspace-preset"
                  Content="Animate"
                  Command="{Binding ApplyPresetCommand}"
                  CommandParameter="Animate" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Editorial"
                  Command="{Binding ApplyPresetCommand}"
                  CommandParameter="Editorial" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Review"
                  Command="{Binding ApplyPresetCommand}"
                  CommandParameter="Review" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Stage"
                  Command="{Binding ApplyPresetCommand}"
                  CommandParameter="StageFocus" />
        </StackPanel>

        <Grid Grid.Column="1"
              ColumnDefinitions="Auto,Auto,*"
              ColumnSpacing="8">
          <Border Classes="workspace-summary-chip"
                  Padding="8,4"
                  ToolTip.Tip="{Binding WorkspaceOrganizerSummary}">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Document" />
              <TextBlock Classes="strong-label"
                         Text="{Binding Host.DocumentName}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Classes="workspace-summary-chip"
                  Padding="8,4">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Workspace" />
              <TextBlock Classes="strong-label"
                         Text="{Binding CurrentPresetLabel}" />
            </StackPanel>
          </Border>

          <TextBlock Grid.Column="2"
                     Classes="micro-label"
                     VerticalAlignment="Center"
                     Text="{Binding WorkspaceDragHint}"
                     TextTrimming="CharacterEllipsis" />
        </Grid>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Menu Classes="timeline-toolbar">
            <MenuItem Classes="timeline-toolbar-item"
                      Header="Monitors">
              <MenuItem Header="{Binding StageSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="StageDocument" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="StageDocument" />
              </MenuItem>
              <MenuItem Header="{Binding SourceSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="SourceMonitorTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="SourceMonitorTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="SourceMonitorTool" />
              </MenuItem>
              <MenuItem Header="{Binding ProgramSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="ProgramMonitorTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="ProgramMonitorTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="ProgramMonitorTool" />
              </MenuItem>
            </MenuItem>
            <MenuItem Classes="timeline-toolbar-item"
                      Header="Timeline">
              <MenuItem Header="{Binding FramesSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="FramesTimelineTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="FramesTimelineTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="FramesTimelineTool" />
              </MenuItem>
              <MenuItem Header="{Binding CurvesSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="CurvesTimelineTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="CurvesTimelineTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="CurvesTimelineTool" />
              </MenuItem>
            </MenuItem>
            <MenuItem Classes="timeline-toolbar-item"
                      Header="Panels">
              <MenuItem Header="{Binding ProjectSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="ProjectTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="ProjectTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="ProjectTool" />
              </MenuItem>
              <MenuItem Header="{Binding InspectorSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="InspectorTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="InspectorTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="InspectorTool" />
              </MenuItem>
              <MenuItem Header="{Binding OutputSurfaceMenuLabel}">
                <MenuItem Header="Show / focus"
                          Command="{Binding FocusSurfaceCommand}"
                          CommandParameter="OutputTool" />
                <MenuItem Header="Overlay"
                          Command="{Binding OverlaySurfaceCommand}"
                          CommandParameter="OutputTool" />
                <MenuItem Header="Hide"
                          Command="{Binding HideSurfaceCommand}"
                          CommandParameter="OutputTool" />
              </MenuItem>
            </MenuItem>
          </Menu>

          <Button Classes="toolbar"
                  Content="Reveal All"
                  Command="{Binding RestoreAllSurfacesCommand}"
                  IsEnabled="{Binding CanRevealAllSurfaces}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="chrome-group command-strip"
            Padding="6,4">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto"
            ColumnSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Classes="toolbar compact"
                  x:Name="DockOpenButton"
                  Content="Open"
                  Click="OpenDocumentClick" />
          <Button Classes="toolbar compact accent"
                  x:Name="DockSaveButton"
                  Content="Save"
                  Click="SaveDocumentClick" />
          <Button Classes="toolbar compact"
                  Content="Frame"
                  Click="ExportFrameClick" />
          <Button Classes="toolbar compact"
                  Content="Sequence"
                  Click="ExportSequenceClick" />
          <Button Classes="toolbar compact"
                  x:Name="DockProjectExportButton"
                  Content="Project"
                  Click="ExportProjectClick" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Classes="toolbar compact"
                  Content="Edit Symbol"
                  Command="{Binding Host.EnterSelectedSymbolEditCommand}"
                  IsEnabled="{Binding Host.CanEnterSymbolEdit}" />
          <Button Classes="toolbar compact"
                  Content="Exit Symbol"
                  Command="{Binding Host.ExitSymbolEditCommand}"
                  IsEnabled="{Binding Host.CanExitSymbolEdit}" />
          <ToggleButton Classes="toolbar compact accent"
                        Content="Prototype"
                        Command="{Binding Host.TogglePrototypeModeCommand}"
                        IsChecked="{Binding Host.IsPrototypeMode, Mode=OneWay}"
                        IsEnabled="{Binding Host.CanTogglePrototypeModeMenu}" />
          <Button Classes="toolbar compact"
                  Content="Undo"
                  Command="{Binding Host.UndoCommand}"
                  IsEnabled="{Binding Host.CanUndo}" />
          <Button Classes="toolbar compact"
                  Content="Redo"
                  Command="{Binding Host.RedoCommand}"
                  IsEnabled="{Binding Host.CanRedo}" />
          <Button Classes="toolbar compact"
                  Content="Sample"
                  Command="{Binding Host.ResetSampleCommand}" />
        </StackPanel>

        <Border Grid.Column="2"
                Classes="workspace-summary-chip"
                Padding="8,4">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Status" />
              <TextBlock Classes="strong-label"
                         Text="{Binding Host.DocumentFileSummary}" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Classes="micro-label"
                       VerticalAlignment="Center"
                       Text="{Binding Host.StatusMessage}"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
        </Border>

        <Menu Grid.Column="3"
              Classes="timeline-toolbar">
          <MenuItem Classes="timeline-toolbar-item"
                    Header="Context">
            <MenuItem Header="Show current context"
                      Command="{Binding Host.ShowWorkspaceHelpCommand}" />
            <MenuItem Header="Show selection context"
                      Command="{Binding Host.ShowSelectionContextCommand}" />
            <MenuItem Header="Show keyboard shortcuts"
                      Command="{Binding Host.ShowKeyboardShortcutsCommand}" />
          </MenuItem>
        </Menu>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Classes="chrome-group animate-context-strip"
            Padding="6,4">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto"
            ColumnSpacing="8">
        <Border Classes="workspace-summary-chip"
                Padding="8,4">
          <StackPanel Spacing="1">
            <TextBlock Classes="eyebrow"
                       Text="Tool" />
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.ToolModeLabel}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="workspace-summary-chip"
                Padding="8,4">
          <StackPanel Spacing="1">
            <TextBlock Classes="eyebrow"
                       Text="Selection" />
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.SelectionHeadline}" />
            <TextBlock Classes="micro-label"
                       Text="{Binding Host.SelectedSceneSummary}" />
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Classes="toolbar compact workspace-surface"
                  Content="Stage"
                  Command="{Binding FocusSurfaceCommand}"
                  CommandParameter="StageDocument"
                  ToolTip.Tip="{Binding StageSurfaceMenuLabel}" />
          <Button Classes="toolbar compact workspace-surface"
                  Content="Source"
                  Command="{Binding FocusSurfaceCommand}"
                  CommandParameter="SourceMonitorTool"
                  ToolTip.Tip="{Binding SourceSurfaceMenuLabel}" />
          <Button Classes="toolbar compact workspace-surface"
                  Content="Program"
                  Command="{Binding FocusSurfaceCommand}"
                  CommandParameter="ProgramMonitorTool"
                  ToolTip.Tip="{Binding ProgramSurfaceMenuLabel}" />
          <Button Classes="toolbar compact workspace-surface"
                  Content="Frames"
                  Command="{Binding FocusSurfaceCommand}"
                  CommandParameter="FramesTimelineTool"
                  ToolTip.Tip="{Binding FramesSurfaceMenuLabel}" />
          <Button Classes="toolbar compact workspace-surface"
                  Content="Curves"
                  Command="{Binding FocusSurfaceCommand}"
                  CommandParameter="CurvesTimelineTool"
                  ToolTip.Tip="{Binding CurvesSurfaceMenuLabel}" />
        </StackPanel>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Border Classes="metric-chip compact">
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.CurrentFrameLabel}" />
          </Border>
          <Border Classes="metric-chip compact">
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.DurationLabel}" />
          </Border>
          <Border Classes="metric-chip compact">
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.FrameRateLabel}" />
          </Border>
          <Border Classes="metric-chip compact">
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.CanvasSizeLabel}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="3"
          ColumnDefinitions="64,*"
          ColumnSpacing="4">
      <Border Classes="panel tool-rail-shell">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="6">
          <StackPanel Spacing="4">
            <ToggleButton Classes="tool-rail-button"
                          Content="Sel"
                          IsChecked="{Binding Host.IsSelectToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Select"
                          ToolTip.Tip="Selection tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Rect"
                          IsChecked="{Binding Host.IsRectangleToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Rectangle"
                          ToolTip.Tip="Rectangle tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Oval"
                          IsChecked="{Binding Host.IsEllipseToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Ellipse"
                          ToolTip.Tip="Ellipse tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Text"
                          IsChecked="{Binding Host.IsTextToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Text"
                          ToolTip.Tip="Text tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Line"
                          IsChecked="{Binding Host.IsLineToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Line"
                          ToolTip.Tip="Line tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Pen"
                          IsChecked="{Binding Host.IsPenToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Pen"
                          ToolTip.Tip="Pen tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Brush"
                          IsChecked="{Binding Host.IsBrushToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Brush"
                          ToolTip.Tip="Brush tool" />
          </StackPanel>

          <Border Grid.Row="1"
                  Classes="workspace-summary-chip compact"
                  Margin="0,4,0,4">
            <StackPanel Spacing="2">
              <TextBlock Classes="eyebrow"
                         Text="Mode" />
              <TextBlock Classes="micro-label"
                         Text="{Binding Host.ToolModeLabel}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Row="2"
                      Spacing="4">
            <Button Classes="tool-rail-button"
                    Content="Play"
                    Command="{Binding Host.TogglePlaybackCommand}" />
            <Button Classes="tool-rail-button"
                    Content="Stop"
                    Command="{Binding Host.StopPlaybackCommand}"
                    IsEnabled="{Binding Host.CanStopPlayback}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Classes="dock-workspace-shell">
        <dockControls:DockControl x:Name="WorkspaceDockControl"
                                  Layout="{Binding Layout}" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
