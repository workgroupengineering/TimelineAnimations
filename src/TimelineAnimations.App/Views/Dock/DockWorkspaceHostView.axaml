<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dockControls="using:Dock.Avalonia.Controls"
             xmlns:vm="using:TimelineAnimations.App.ViewModels.Dock"
             x:Class="TimelineAnimations.App.Views.Dock.DockWorkspaceHostView"
             x:DataType="vm:DockWorkspaceHostViewModel">
  <Grid ColumnDefinitions="64,*"
        ColumnSpacing="4">
    <Border Classes="panel tool-rail-shell">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="6">
          <StackPanel Spacing="4">
            <ToggleButton x:Name="DockSelectToolButton"
                          Classes="tool-rail-button"
                          Content="Sel"
                          IsChecked="{Binding Host.IsSelectToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Select"
                          ToolTip.Tip="Selection tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Rect"
                          IsChecked="{Binding Host.IsRectangleToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Rectangle"
                          ToolTip.Tip="Rectangle tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Oval"
                          IsChecked="{Binding Host.IsEllipseToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Ellipse"
                          ToolTip.Tip="Ellipse tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Text"
                          IsChecked="{Binding Host.IsTextToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Text"
                          ToolTip.Tip="Text tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Line"
                          IsChecked="{Binding Host.IsLineToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Line"
                          ToolTip.Tip="Line tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Pen"
                          IsChecked="{Binding Host.IsPenToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Pen"
                          ToolTip.Tip="Pen tool" />
            <ToggleButton Classes="tool-rail-button"
                          Content="Brush"
                          IsChecked="{Binding Host.IsBrushToolActive, Mode=OneWay}"
                          Command="{Binding Host.SelectDrawingToolCommand}"
                          CommandParameter="Brush"
                          ToolTip.Tip="Brush tool" />
          </StackPanel>

          <Border Grid.Row="1"
                  Classes="workspace-summary-chip compact"
                  Margin="0,4,0,4">
            <StackPanel Spacing="2">
              <TextBlock Classes="eyebrow"
                         Text="Mode" />
              <TextBlock Classes="micro-label"
                         Text="{Binding Host.ToolModeLabel}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Row="2"
                      Spacing="4">
            <Button Classes="tool-rail-button"
                    Content="Play"
                    Command="{Binding Host.TogglePlaybackCommand}" />
            <Button Classes="tool-rail-button"
                    Content="Stop"
                    Command="{Binding Host.StopPlaybackCommand}"
                    IsEnabled="{Binding Host.CanStopPlayback}" />
          </StackPanel>
        </Grid>
      </Border>

    <Border Grid.Column="1"
            Classes="dock-workspace-shell">
      <dockControls:DockControl x:Name="WorkspaceDockControl"
                                Factory="{Binding Factory}"
                                HostWindowFactory="{Binding HostWindowFactory}"
                                InitializeFactory="False"
                                InitializeLayout="False"
                                Layout="{Binding Layout}" />
    </Border>
  </Grid>
</UserControl>
