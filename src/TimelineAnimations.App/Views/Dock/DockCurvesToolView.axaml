<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TimelineAnimations.App.Controls"
             xmlns:vm="using:TimelineAnimations.App.ViewModels.Dock"
             x:Class="TimelineAnimations.App.Views.Dock.DockCurvesToolView"
             x:DataType="vm:DockCurvesToolViewModel">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="4">
    <Border Classes="chrome-group"
            Padding="4,3">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,160,*,180"
            ColumnSpacing="6">
        <Button Classes="timeline-action accent"
                Content="Play"
                Command="{Binding Host.TogglePlaybackCommand}" />
        <Button Grid.Column="1"
                Classes="timeline-action"
                Content="Stop"
                Command="{Binding Host.StopPlaybackCommand}"
                IsEnabled="{Binding Host.CanStopPlayback}" />
        <Button Grid.Column="2"
                Classes="timeline-action"
                Content="+ Key"
                Command="{Binding Host.AddCurrentKeyframeCommand}"
                IsEnabled="{Binding Host.CanEditPropertyTracks}" />
        <Button Grid.Column="3"
                Classes="timeline-action warm"
                Content="- Key"
                Command="{Binding Host.DeleteCurrentKeyframeCommand}"
                IsEnabled="{Binding Host.CanDeleteSelectedKeyframe}" />
        <ToggleButton Grid.Column="4"
                      Classes="timeline-action"
                      Content="Auto"
                      IsChecked="{Binding Host.AutoKey, Mode=TwoWay}" />
        <ComboBox Grid.Column="5"
                  Classes="inspector-field"
                  ItemsSource="{Binding Host.AvailableEasings}"
                  SelectedItem="{Binding Host.SelectedKeyframeEasing, Mode=TwoWay}"
                  IsEnabled="{Binding Host.CanDeleteSelectedKeyframe}" />
        <StackPanel Grid.Column="6"
                    Orientation="Horizontal"
                    Spacing="6">
          <Border Classes="metric-chip compact">
            <TextBlock Classes="strong-label"
                       Text="{Binding Host.SelectedProperty}" />
          </Border>
          <Border Classes="metric-chip">
            <TextBlock Classes="micro-label"
                       Text="{Binding Host.SelectedKeyframeSummary}"
                       TextTrimming="CharacterEllipsis" />
          </Border>
        </StackPanel>
        <Slider Grid.Column="7"
                Classes="timeline-slider"
                Minimum="10"
                Maximum="160"
                Value="{Binding Host.TimelineZoom, Mode=TwoWay}" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="panel-soft">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,*,Auto,Auto"
              ColumnSpacing="8">
          <Border Classes="metric-chip">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Keyframe" />
              <TextBlock Classes="strong-label"
                         Text="{Binding Host.SelectedKeyframeSummary}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Classes="metric-chip">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Shape tween" />
              <TextBlock Classes="strong-label"
                         Text="{Binding Host.ShapeTweenSummary}" />
            </StackPanel>
          </Border>

          <Button Grid.Column="2"
                  Content="Capture Morph"
                  Command="{Binding Host.CaptureShapeKeyframeCommand}"
                  IsEnabled="{Binding Host.CanCaptureShapeKeyframe}"
                  IsVisible="{Binding Host.SelectedLayerIsPath}" />

          <Button Grid.Column="3"
                  Content="Delete Morph"
                  Classes="warm"
                  Command="{Binding Host.DeleteCurrentShapeKeyframeCommand}"
                  IsEnabled="{Binding Host.CanDeleteCurrentShapeKeyframe}"
                  IsVisible="{Binding Host.SelectedLayerIsPath}" />
        </Grid>

        <Border Classes="panel-soft"
                IsVisible="{Binding Host.HasSelectedCustomEasing}">
          <StackPanel Spacing="10">
            <TextBlock Classes="eyebrow"
                       Text="Custom Curve" />
            <controls:EasingCurveEditorControl Height="200"
                                              ControlPoint1X="{Binding Host.CustomEaseControl1X, Mode=TwoWay}"
                                              ControlPoint1Y="{Binding Host.CustomEaseControl1Y, Mode=TwoWay}"
                                              ControlPoint2X="{Binding Host.CustomEaseControl2X, Mode=TwoWay}"
                                              ControlPoint2Y="{Binding Host.CustomEaseControl2Y, Mode=TwoWay}"
                                              IsEnabled="{Binding Host.CanEditCustomEasingCurve}" />
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  RowDefinitions="Auto,Auto">
              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle A X" />
                <TextBox Text="{Binding Host.CustomEaseControl1X, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle A Y" />
                <TextBox Text="{Binding Host.CustomEaseControl1Y, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle B X" />
                <TextBox Text="{Binding Host.CustomEaseControl2X, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Grid.Column="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle B Y" />
                <TextBox Text="{Binding Host.CustomEaseControl2Y, Mode=TwoWay}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Classes="micro-label"
                   Text="Canvas edits and inspector changes update the current playhead. Away from zero or with auto-key enabled, the editor writes keyframes automatically."
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <controls:TimelineEditorControl x:Name="TimelineEditor"
                                      Width="{Binding Host.TimelineSurfaceWidth}"
                                      Height="{Binding Host.TimelineSurfaceHeight}"
                                      Rows="{Binding Host.TimelineRows}"
                                      CurrentTime="{Binding Host.CurrentTime}"
                                      Duration="{Binding Host.Duration}"
                                      SelectedProperty="{Binding Host.SelectedProperty}"
                                      SelectedKeyframeId="{Binding Host.SelectedKeyframeId}"
                                      PixelsPerSecond="{Binding Host.TimelineZoom}" />
    </ScrollViewer>
  </Grid>
</UserControl>
