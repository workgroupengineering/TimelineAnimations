<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TimelineAnimations.App.Controls"
             xmlns:helpers="using:TimelineAnimations.App.Helpers"
             xmlns:vm="using:TimelineAnimations.App.ViewModels.Dock"
             x:Class="TimelineAnimations.App.Views.Dock.DockCurvesToolView"
             x:DataType="vm:DockCurvesToolViewModel">
  <Grid RowDefinitions="Auto,*"
        RowSpacing="4">
    <Border Classes="chrome-group"
            Padding="4,3">
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,180"
              ColumnSpacing="8">
          <WrapPanel>
            <Button Classes="timeline-action accent"
                    Command="{Binding Host.TogglePlaybackCommand}"
                    ToolTip.Tip="Play or pause curve playback">
              <StackPanel Classes="icon-label-content">
                <PathIcon Classes="command-icon"
                          Data="{x:Static helpers:FluentIconData.Play20Regular}" />
                <TextBlock Text="Play" />
              </StackPanel>
            </Button>
            <Button Classes="timeline-action"
                    Command="{Binding Host.StopPlaybackCommand}"
                    IsEnabled="{Binding Host.CanStopPlayback}"
                    ToolTip.Tip="Stop curve playback">
              <StackPanel Classes="icon-label-content">
                <PathIcon Classes="command-icon"
                          Data="{x:Static helpers:FluentIconData.Stop20Regular}" />
                <TextBlock Text="Stop" />
              </StackPanel>
            </Button>
            <Button Classes="timeline-action"
                    Content="+ Key"
                    Command="{Binding Host.AddCurrentKeyframeCommand}"
                    IsEnabled="{Binding Host.CanEditPropertyTracks}" />
            <Button Classes="timeline-action warm"
                    Content="- Key"
                    Command="{Binding Host.DeleteCurrentKeyframeCommand}"
                    IsEnabled="{Binding Host.CanDeleteSelectedKeyframe}" />
            <ToggleButton Classes="timeline-action"
                          Content="Auto"
                          IsChecked="{Binding Host.AutoKey, Mode=TwoWay}" />
            <ComboBox Width="172"
                      Classes="inspector-field"
                      ItemsSource="{Binding Host.AvailableEasings}"
                      SelectedItem="{Binding Host.SelectedKeyframeEasing, Mode=TwoWay}"
                      IsEnabled="{Binding Host.CanDeleteSelectedKeyframe}" />
            <Border Classes="metric-chip compact">
              <TextBlock Classes="strong-label"
                         Text="{Binding Host.SelectedProperty}" />
            </Border>
            <Border Classes="metric-chip compact">
              <TextBlock Classes="micro-label"
                         Text="{Binding Host.SelectedKeyframeSummary}"
                         TextTrimming="CharacterEllipsis" />
            </Border>
          </WrapPanel>

          <StackPanel Grid.Column="1"
                      Spacing="2">
            <TextBlock Classes="eyebrow"
                       HorizontalAlignment="Right"
                       Text="Curve zoom" />
            <Slider Classes="timeline-slider"
                    Minimum="10"
                    Maximum="160"
                    Value="{Binding Host.TimelineZoom, Mode=TwoWay}" />
          </StackPanel>
        </Grid>

        <WrapPanel>
          <ComboBox Width="220"
                    ItemsSource="{Binding Host.MotionPresets}"
                    SelectedItem="{Binding Host.SelectedMotionPreset, Mode=TwoWay}"
                    IsEnabled="{Binding Host.CanEditPropertyTracks}" />
          <Button Classes="timeline-action"
                  Content="Capture"
                  Command="{Binding Host.CaptureMotionPresetCommand}"
                  IsEnabled="{Binding Host.CanCaptureMotionPreset}" />
          <Button Classes="timeline-action"
                  Content="Apply"
                  Command="{Binding Host.ApplySelectedMotionPresetCommand}"
                  IsEnabled="{Binding Host.CanApplySelectedMotionPreset}" />
          <Button Classes="timeline-action warm"
                  Content="Delete"
                  Command="{Binding Host.DeleteSelectedMotionPresetCommand}"
                  IsEnabled="{Binding Host.CanDeleteSelectedMotionPreset}" />
          <Button Content="Capture Morph"
                  Command="{Binding Host.CaptureShapeKeyframeCommand}"
                  IsEnabled="{Binding Host.CanCaptureShapeKeyframe}"
                  IsVisible="{Binding Host.SelectedLayerIsPath}" />
          <Button Content="Delete Morph"
                  Classes="warm"
                  Command="{Binding Host.DeleteCurrentShapeKeyframeCommand}"
                  IsEnabled="{Binding Host.CanDeleteCurrentShapeKeyframe}"
                  IsVisible="{Binding Host.SelectedLayerIsPath}" />
          <Border Classes="metric-chip compact">
            <TextBlock Classes="micro-label"
                       Text="{Binding Host.MotionPresetSummary}"
                       TextTrimming="CharacterEllipsis" />
          </Border>
          <Border Classes="metric-chip compact">
            <TextBlock Classes="micro-label"
                       Text="{Binding Host.ShapeTweenSummary}"
                       TextTrimming="CharacterEllipsis" />
          </Border>
        </WrapPanel>

        <Border Classes="panel-soft"
                IsVisible="{Binding Host.HasSelectedCustomEasing}">
          <StackPanel Spacing="8">
            <TextBlock Classes="eyebrow"
                       Text="Custom Curve" />
            <controls:EasingCurveEditorControl Height="168"
                                              ControlPoint1X="{Binding Host.CustomEaseControl1X, Mode=TwoWay}"
                                              ControlPoint1Y="{Binding Host.CustomEaseControl1Y, Mode=TwoWay}"
                                              ControlPoint2X="{Binding Host.CustomEaseControl2X, Mode=TwoWay}"
                                              ControlPoint2Y="{Binding Host.CustomEaseControl2Y, Mode=TwoWay}"
                                              IsEnabled="{Binding Host.CanEditCustomEasingCurve}" />
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  RowDefinitions="Auto,Auto">
              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle A X" />
                <TextBox Text="{Binding Host.CustomEaseControl1X, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle A Y" />
                <TextBox Text="{Binding Host.CustomEaseControl1Y, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle B X" />
                <TextBox Text="{Binding Host.CustomEaseControl2X, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Grid.Column="1"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Handle B Y" />
                <TextBox Text="{Binding Host.CustomEaseControl2Y, Mode=TwoWay}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled">
      <Grid RowDefinitions="Auto,*">
        <controls:TimelineEditorControl x:Name="TimelineEditorHeader"
                                        Width="{Binding Host.TimelineSurfaceWidth}"
                                        Height="52"
                                        Rows="{Binding Host.TimelineRows}"
                                        CurrentTime="{Binding Host.CurrentTime}"
                                        Duration="{Binding Host.Duration}"
                                        FrameRate="{Binding Host.SceneFrameRate}"
                                        SelectedProperty="{Binding Host.SelectedProperty}"
                                        SelectedKeyframeId="{Binding Host.SelectedKeyframeId}"
                                        PixelsPerSecond="{Binding Host.TimelineZoom}"
                                        ShowHeader="True"
                                        ShowBody="False" />

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <controls:TimelineEditorControl x:Name="TimelineEditorBody"
                                          Width="{Binding Host.TimelineSurfaceWidth}"
                                          Height="{Binding Host.TimelineSurfaceBodyHeight}"
                                          Rows="{Binding Host.TimelineRows}"
                                          CurrentTime="{Binding Host.CurrentTime}"
                                          Duration="{Binding Host.Duration}"
                                          FrameRate="{Binding Host.SceneFrameRate}"
                                          SelectedProperty="{Binding Host.SelectedProperty}"
                                          SelectedKeyframeId="{Binding Host.SelectedKeyframeId}"
                                          PixelsPerSecond="{Binding Host.TimelineZoom}"
                                          ShowHeader="False"
                                          ShowBody="True" />
        </ScrollViewer>
      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>
