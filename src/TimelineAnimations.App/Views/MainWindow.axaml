<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:TimelineAnimations.App.Controls"
        xmlns:dockViews="using:TimelineAnimations.App.Views.Dock"
        xmlns:models="using:TimelineAnimations.Core.Models"
        xmlns:vm="using:TimelineAnimations.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1560"
        d:DesignHeight="940"
        x:Class="TimelineAnimations.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1560"
        Height="940"
        MinWidth="1240"
        MinHeight="760"
        UseLayoutRounding="True"
        ExtendClientAreaToDecorationsHint="{Binding UseIntegratedTitleBar}"
        ExtendClientAreaChromeHints="{Binding IntegratedTitleBarChromeHints}"
        ExtendClientAreaTitleBarHeightHint="{Binding IntegratedTitleBarHeightHint}"
        Title="{Binding ApplicationTitle}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Z"
                Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Z"
                Command="{Binding RedoCommand}" />
    <KeyBinding Gesture="Ctrl+1"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="classic" />
    <KeyBinding Gesture="Ctrl+2"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="stage" />
    <KeyBinding Gesture="Ctrl+3"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="timeline" />
    <KeyBinding Gesture="Ctrl+4"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="tools" />
    <KeyBinding Gesture="Ctrl+5"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="inspector" />
    <KeyBinding Gesture="Ctrl+Shift+1"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="left" />
    <KeyBinding Gesture="Ctrl+Shift+2"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="right" />
    <KeyBinding Gesture="Ctrl+Shift+3"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="timeline" />
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid Margin="{Binding WindowContentMargin}"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="3">
    <Border Grid.Row="0"
            Classes="chrome"
            Padding="{Binding TitleBarChromePadding}">
      <controls:TitleBarDragGrid ColumnDefinitions="Auto,Auto,*,Auto"
                                 ColumnSpacing="10">
        <Border Width="{Binding TitleBarLeadingInsetWidth}"
                IsVisible="{Binding UseIntegratedTitleBar}" />

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
          <TextBlock Classes="title"
                     Text="{Binding ApplicationTitle}" />
        </StackPanel>

        <Grid Grid.Column="2">
        <Menu Classes="app-menu"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              IsVisible="{Binding IsFallbackAppMenuVisible}">
          <MenuItem Classes="app-menu-root"
                    Header="_File">
            <MenuItem Classes="menu-summary"
                      Header="{Binding DocumentFileSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="New Blank Animation"
                      Command="{Binding ResetBlankCommand}" />
            <MenuItem Header="New Sample Composition"
                      Command="{Binding ResetSampleCommand}" />
            <MenuItem Header="Open..."
                      Click="OpenDocumentClick" />
            <MenuItem Header="Save..."
                      Click="SaveDocumentClick" />
            <Separator />
            <MenuItem Header="Import">
              <MenuItem Header="Avalonia XAML..."
                        ToggleType="Radio"
                        GroupName="importFormats"
                        IsChecked="{Binding IsAvaloniaXamlExchangeSelected, Mode=OneWay}"
                        CommandParameter="AvaloniaXaml"
                        Click="ImportAnimationFormatMenuClick" />
              <MenuItem Header="Flash XFL..."
                        ToggleType="Radio"
                        GroupName="importFormats"
                        IsChecked="{Binding IsFlashXflExchangeSelected, Mode=OneWay}"
                        CommandParameter="FlashXfl"
                        Click="ImportAnimationFormatMenuClick" />
              <MenuItem Header="SVG / SMIL..."
                        ToggleType="Radio"
                        GroupName="importFormats"
                        IsChecked="{Binding IsSvgAnimationExchangeSelected, Mode=OneWay}"
                        CommandParameter="SvgSmil"
                        Click="ImportAnimationFormatMenuClick" />
              <MenuItem Header="HTML / CSS..."
                        ToggleType="Radio"
                        GroupName="importFormats"
                        IsChecked="{Binding IsHtmlAnimationExchangeSelected, Mode=OneWay}"
                        CommandParameter="HtmlCss"
                        Click="ImportAnimationFormatMenuClick" />
              <Separator />
              <MenuItem Header="Audio..."
                        Click="ImportAudioClick" />
              <MenuItem Header="Video Sequence..."
                        Click="ImportVideoClick" />
            </MenuItem>
            <MenuItem Header="Export">
              <MenuItem Header="Avalonia XAML..."
                        ToggleType="Radio"
                        GroupName="exportFormats"
                        IsChecked="{Binding IsAvaloniaXamlExchangeSelected, Mode=OneWay}"
                        CommandParameter="AvaloniaXaml"
                        Click="ExportAnimationFormatMenuClick" />
              <MenuItem Header="Flash XFL..."
                        ToggleType="Radio"
                        GroupName="exportFormats"
                        IsChecked="{Binding IsFlashXflExchangeSelected, Mode=OneWay}"
                        CommandParameter="FlashXfl"
                        Click="ExportAnimationFormatMenuClick" />
              <MenuItem Header="SVG / SMIL..."
                        ToggleType="Radio"
                        GroupName="exportFormats"
                        IsChecked="{Binding IsSvgAnimationExchangeSelected, Mode=OneWay}"
                        CommandParameter="SvgSmil"
                        Click="ExportAnimationFormatMenuClick" />
              <MenuItem Header="HTML / CSS..."
                        ToggleType="Radio"
                        GroupName="exportFormats"
                        IsChecked="{Binding IsHtmlAnimationExchangeSelected, Mode=OneWay}"
                        CommandParameter="HtmlCss"
                        Click="ExportAnimationFormatMenuClick" />
              <Separator />
              <MenuItem Header="Current Frame PNG..."
                        Click="ExportFrameClick" />
              <MenuItem Header="PNG Sequence..."
                        Click="RenderSequenceClick" />
              <MenuItem Header="Project Sequence..."
                        Click="RenderProjectClick" />
            </MenuItem>
            <MenuItem Header="Publish">
              <MenuItem Header="Preview Selected Profile"
                        Click="PreviewPublishProfileClick"
                        IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
              <MenuItem Header="Export Selected Profile..."
                        Click="ExportPublishProfileClick"
                        IsEnabled="{Binding CanExportSelectedPublishProfile}" />
            </MenuItem>
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Edit">
            <MenuItem Classes="menu-summary"
                      Header="{Binding ModifyMenuSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Undo"
                      HotKey="Ctrl+Z"
                      Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" />
            <MenuItem Header="Redo"
                      HotKey="Ctrl+Shift+Z"
                      Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" />
            <Separator />
            <MenuItem Header="Duplicate Selection"
                      Command="{Binding DuplicateSelectionCommand}"
                      IsEnabled="{Binding CanUseSelectionActions}" />
            <MenuItem Header="Delete Selection"
                      Command="{Binding DeleteSelectionCommand}"
                      IsEnabled="{Binding CanUseSelectionActions}" />
            <MenuItem Header="{Binding SelectedLayerVisibilityLabel}"
                      Command="{Binding ToggleSelectedLayerVisibilityCommand}"
                      IsEnabled="{Binding CanToggleLayerState}" />
            <MenuItem Header="{Binding SelectedLayerLockLabel}"
                      Command="{Binding ToggleSelectedLayerLockCommand}"
                      IsEnabled="{Binding CanToggleLayerState}" />
            <Separator />
            <MenuItem Header="Add Scene"
                      Command="{Binding AddSceneCommand}"
                      IsEnabled="{Binding CanEditScenes}" />
            <MenuItem Header="Duplicate Scene"
                      Command="{Binding DuplicateSceneCommand}"
                      IsEnabled="{Binding CanEditScenes}" />
            <MenuItem Header="Delete Scene"
                      Command="{Binding DeleteSceneCommand}"
                      IsEnabled="{Binding CanDeleteScene}" />
            <MenuItem Header="Move Scene Back"
                      Command="{Binding MoveSceneBackwardCommand}"
                      IsEnabled="{Binding CanMoveSceneBackward}" />
            <MenuItem Header="Move Scene Forward"
                      Command="{Binding MoveSceneForwardCommand}"
                      IsEnabled="{Binding CanMoveSceneForward}" />
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_View">
            <MenuItem Classes="menu-summary"
                      Header="{Binding WorkspaceLayoutSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Fit Stage"
                      Click="CanvasFitClick" />
            <MenuItem Header="Actual Size"
                      Click="CanvasActualSizeClick" />
            <MenuItem Header="Snap To Grid"
                      ToggleType="CheckBox"
                      IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
            <MenuItem Header="Onion Skin"
                      ToggleType="CheckBox"
                      IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}" />
            <Separator />
            <MenuItem Header="Frames View"
                      ToggleType="Radio"
                      GroupName="timelineWorkspaceView"
                      IsChecked="{Binding IsFramesTimelineViewActive, Mode=OneWay}"
                      Command="{Binding SetTimelineWorkspaceViewCommand}"
                      CommandParameter="Frames" />
            <MenuItem Header="Curves View"
                      ToggleType="Radio"
                      GroupName="timelineWorkspaceView"
                      IsChecked="{Binding IsCurvesTimelineViewActive, Mode=OneWay}"
                      Command="{Binding SetTimelineWorkspaceViewCommand}"
                      CommandParameter="Curves" />
            <Separator />
            <MenuItem Header="Workspace Focus">
              <MenuItem Header="Classic"
                        HotKey="Ctrl+1"
                        Command="{Binding FocusWorkspaceAreaCommand}"
                        CommandParameter="classic" />
              <MenuItem Header="Stage"
                        HotKey="Ctrl+2"
                        Command="{Binding FocusWorkspaceAreaCommand}"
                        CommandParameter="stage" />
              <MenuItem Header="Timeline"
                        HotKey="Ctrl+3"
                        Command="{Binding FocusWorkspaceAreaCommand}"
                        CommandParameter="timeline" />
              <MenuItem Header="Tools"
                        HotKey="Ctrl+4"
                        Command="{Binding FocusWorkspaceAreaCommand}"
                        CommandParameter="tools" />
              <MenuItem Header="Inspector"
                        HotKey="Ctrl+5"
                        Command="{Binding FocusWorkspaceAreaCommand}"
                        CommandParameter="inspector" />
            </MenuItem>
            <MenuItem Header="Active Tool">
              <MenuItem Header="Select"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsSelectToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Select" />
              <MenuItem Header="Rectangle"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsRectangleToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Rectangle" />
              <MenuItem Header="Ellipse"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsEllipseToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Ellipse" />
              <MenuItem Header="Text"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsTextToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Text" />
              <MenuItem Header="Line"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsLineToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Line" />
              <MenuItem Header="Pen"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsPenToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Pen" />
              <MenuItem Header="Brush"
                        ToggleType="Radio"
                        GroupName="activeTool"
                        IsChecked="{Binding IsBrushToolActive, Mode=OneWay}"
                        Command="{Binding SelectDrawingToolCommand}"
                        CommandParameter="Brush" />
            </MenuItem>
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Insert">
            <MenuItem Classes="menu-summary"
                      Header="{Binding SelectedSceneSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Rectangle"
                      Command="{Binding AddRectangleCommand}"
                      IsEnabled="{Binding CanInsertStageItems}" />
            <MenuItem Header="Ellipse"
                      Command="{Binding AddEllipseCommand}"
                      IsEnabled="{Binding CanInsertStageItems}" />
            <MenuItem Header="Text"
                      Command="{Binding AddTextCommand}"
                      IsEnabled="{Binding CanInsertStageItems}" />
            <MenuItem Header="Camera Layer"
                      Command="{Binding AddCameraLayerCommand}"
                      IsEnabled="{Binding CanAddCameraLayer}" />
            <MenuItem Header="Avalonia Control">
              <MenuItem Header="Border"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Border"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="Button"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Button"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="TextBlock"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="TextBlock"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="TextBox"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="TextBox"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="CheckBox"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="CheckBox"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="ToggleButton"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="ToggleButton"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="Slider"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Slider"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="ProgressBar"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="ProgressBar"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="ComboBox"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="ComboBox"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="ListBox"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="ListBox"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="TabControl"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="TabControl"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="Grid"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Grid"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="StackPanel"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="StackPanel"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="PathIcon"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="PathIcon"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="Image"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Image"
                        IsEnabled="{Binding CanInsertStageItems}" />
              <MenuItem Header="Panel"
                        Command="{Binding InsertAvaloniaControlCommand}"
                        CommandParameter="Panel"
                        IsEnabled="{Binding CanInsertStageItems}" />
            </MenuItem>
            <Separator />
            <MenuItem Header="Selected Library Item"
                      Command="{Binding InsertSelectedLibraryItemCommand}"
                      IsEnabled="{Binding CanInsertFromLibrary}" />
            <MenuItem Header="Selected Component"
                      Command="{Binding InsertSelectedComponentCommand}"
                      IsEnabled="{Binding CanInsertSelectedComponent}" />
            <MenuItem Header="Selected Media Asset"
                      Command="{Binding InsertSelectedMediaAssetCommand}"
                      IsEnabled="{Binding CanInsertSelectedMediaAsset}" />
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="{Binding ModifyMenuHeader}">
            <MenuItem Classes="menu-summary"
                      Header="{Binding ModifyMenuSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Align Left"
                      Command="{Binding AlignLeftCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <MenuItem Header="Align Center"
                      Command="{Binding AlignCenterCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <MenuItem Header="Align Right"
                      Command="{Binding AlignRightCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <MenuItem Header="Align Top"
                      Command="{Binding AlignTopCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <MenuItem Header="Align Middle"
                      Command="{Binding AlignMiddleCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <MenuItem Header="Align Bottom"
                      Command="{Binding AlignBottomCommand}"
                      IsEnabled="{Binding CanAlignSelection}" />
            <Separator />
            <MenuItem Header="Add Keyframe"
                      Command="{Binding AddCurrentKeyframeCommand}"
                      IsEnabled="{Binding CanEditPropertyTracks}" />
            <MenuItem Header="Delete Keyframe"
                      Command="{Binding DeleteCurrentKeyframeCommand}"
                      IsEnabled="{Binding CanDeleteSelectedKeyframe}" />
            <MenuItem Header="Add Folder"
                      Command="{Binding AddFolderCommand}"
                      IsEnabled="{Binding CanCreateFolder}" />
            <MenuItem Header="Group Into Folder"
                      Command="{Binding GroupSelectionIntoFolderCommand}"
                      IsEnabled="{Binding CanGroupSelectionIntoFolder}" />
            <MenuItem Header="Move To Root"
                      Command="{Binding RemoveSelectionFromFolderCommand}"
                      IsEnabled="{Binding CanRemoveSelectionFromFolder}" />
            <MenuItem Header="{Binding SelectedLayerMuteLabel}"
                      Command="{Binding ToggleSelectedLayerMuteCommand}"
                      IsEnabled="{Binding CanToggleLayerState}" />
            <MenuItem Header="{Binding SelectedLayerSoloLabel}"
                      Command="{Binding ToggleSelectedLayerSoloCommand}"
                      IsEnabled="{Binding CanToggleLayerState}" />
            <MenuItem Header="Add Cel"
                      Command="{Binding AddFrameKeyframeCommand}"
                      IsEnabled="{Binding CanEditPropertyTracks}" />
            <MenuItem Header="Add Blank Cel"
                      Command="{Binding AddBlankFrameKeyframeCommand}"
                      IsEnabled="{Binding CanEditPropertyTracks}" />
            <MenuItem Header="Extend Hold"
                      Command="{Binding ExtendFrameHoldCommand}"
                      IsEnabled="{Binding CanEditPropertyTracks}" />
            <MenuItem Header="Copy Frame Range"
                      Command="{Binding CopyFrameRangeCommand}"
                      IsEnabled="{Binding CanCopyFrameRange}" />
            <MenuItem Header="Paste Frame Range"
                      Command="{Binding PasteFrameRangeCommand}"
                      IsEnabled="{Binding CanPasteFrameRange}" />
            <MenuItem Header="Razor Split"
                      Command="{Binding RazorSelectionCommand}"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Slip Earlier"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="slip-back"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Slip Later"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="slip-forward"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Slide Earlier"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="slide-back"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Slide Later"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="slide-forward"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Ripple Shorter"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="ripple-shorter"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <MenuItem Header="Ripple Longer"
                      Command="{Binding ApplyEditorialOperationCommand}"
                      CommandParameter="ripple-longer"
                      IsEnabled="{Binding CanUseEditorialTools}" />
            <Separator />
            <MenuItem Header="Capture Shape Key"
                      Command="{Binding CaptureShapeKeyframeCommand}"
                      IsEnabled="{Binding CanCaptureShapeKeyframe}" />
            <MenuItem Header="Delete Shape Key"
                      Command="{Binding DeleteCurrentShapeKeyframeCommand}"
                      IsEnabled="{Binding CanDeleteCurrentShapeKeyframe}" />
            <MenuItem Header="Canvas Preset">
              <MenuItem Header="HD 1280 × 720"
                        Command="{Binding ApplyCanvasPresetCommand}"
                        CommandParameter="hd"
                        IsEnabled="{Binding CanEditCanvasProperties}" />
              <MenuItem Header="Full HD 1920 × 1080"
                        Command="{Binding ApplyCanvasPresetCommand}"
                        CommandParameter="fhd"
                        IsEnabled="{Binding CanEditCanvasProperties}" />
              <MenuItem Header="Square 1080 × 1080"
                        Command="{Binding ApplyCanvasPresetCommand}"
                        CommandParameter="square"
                        IsEnabled="{Binding CanEditCanvasProperties}" />
              <MenuItem Header="Story 1080 × 1920"
                        Command="{Binding ApplyCanvasPresetCommand}"
                        CommandParameter="story"
                        IsEnabled="{Binding CanEditCanvasProperties}" />
            </MenuItem>
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Text">
            <MenuItem Classes="menu-summary"
                      Header="{Binding TextMenuSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Add Text Layer"
                      Command="{Binding AddTextCommand}"
                      IsEnabled="{Binding CanInsertStageItems}" />
            <MenuItem Header="Select Text Tool"
                      ToggleType="Radio"
                      GroupName="activeTool"
                      IsChecked="{Binding IsTextToolActive, Mode=OneWay}"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Text"
                      IsEnabled="{Binding CanInsertStageItems}" />
            <MenuItem Header="Increase Font Size"
                      Command="{Binding IncreaseTextSizeCommand}"
                      IsEnabled="{Binding CanEditTextMenu}" />
            <MenuItem Header="Decrease Font Size"
                      Command="{Binding DecreaseTextSizeCommand}"
                      IsEnabled="{Binding CanEditTextMenu}" />
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Commands">
            <MenuItem Classes="menu-summary"
                      Header="{Binding SelectedLibrarySummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Create Symbol From Selection"
                      Command="{Binding CreateSymbolFromSelectionCommand}"
                      IsEnabled="{Binding CanCreateSymbolFromSelection}" />
            <MenuItem Header="Create Component From Selection"
                      Command="{Binding CreateComponentFromSelectionCommand}"
                      IsEnabled="{Binding CanCreateComponentFromSelection}" />
            <MenuItem Header="Enter Symbol Edit"
                      Command="{Binding EnterSelectedSymbolEditCommand}"
                      IsEnabled="{Binding CanEnterSymbolEdit}" />
            <MenuItem Header="Exit Symbol Edit"
                      Command="{Binding ExitSymbolEditCommand}"
                      IsEnabled="{Binding CanExitSymbolEdit}" />
            <MenuItem Header="Update Linked Symbol"
                      Command="{Binding UpdateLinkedSymbolFromSelectionCommand}"
                      IsEnabled="{Binding CanUpdateLinkedSymbol}" />
            <MenuItem Header="Relink Selection To Selected Library Item"
                      Command="{Binding RelinkSelectionToSelectedLibraryItemCommand}"
                      IsEnabled="{Binding CanRelinkSelectionToSelectedLibraryItem}" />
            <Separator />
            <MenuItem Header="Add Behavior"
                      Command="{Binding AddBehaviorCommand}"
                      IsEnabled="{Binding CanAddBehavior}" />
            <MenuItem Header="Delete Selected Behavior"
                      Command="{Binding DeleteSelectedBehaviorCommand}"
                      IsEnabled="{Binding CanDeleteSelectedBehavior}" />
            <MenuItem Header="Save Frame Label"
                      Command="{Binding AddOrUpdateFrameLabelCommand}"
                      IsEnabled="{Binding CanManageFrameLabels}" />
            <MenuItem Header="Clear Frame Label"
                      Command="{Binding RemoveFrameLabelCommand}"
                      IsEnabled="{Binding CanManageFrameLabels}" />
            <Separator />
            <MenuItem Header="Add Publish Profile"
                      Command="{Binding AddPublishProfileCommand}"
                      IsEnabled="{Binding CanEditPublishProfiles}" />
            <MenuItem Header="Duplicate Publish Profile"
                      Command="{Binding DuplicatePublishProfileCommand}"
                      IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
            <MenuItem Header="Delete Publish Profile"
                      Command="{Binding DeletePublishProfileCommand}"
                      IsEnabled="{Binding CanDeletePublishProfile}" />
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="C_ontrol">
            <MenuItem Classes="menu-summary"
                      Header="{Binding ControlMenuSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Play / Pause"
                      Command="{Binding TogglePlaybackCommand}" />
            <MenuItem Header="Stop"
                      Command="{Binding StopPlaybackCommand}"
                      IsEnabled="{Binding CanStopPlayback}" />
            <MenuItem Header="Prototype Mode"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsPrototypeMode, Mode=OneWay}"
                      Command="{Binding TogglePrototypeModeCommand}"
                      IsEnabled="{Binding CanTogglePrototypeModeMenu}" />
            <Separator />
            <MenuItem Header="Loop Playback"
                      ToggleType="CheckBox"
                      IsChecked="{Binding LoopPlayback, Mode=TwoWay}" />
            <MenuItem Header="Play All Scenes"
                      ToggleType="CheckBox"
                      IsChecked="{Binding PlayAllScenes, Mode=TwoWay}" />
            <MenuItem Header="Auto Key"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AutoKey, Mode=TwoWay}" />
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Window">
            <MenuItem Classes="menu-summary"
                      Header="{Binding WorkspaceLayoutSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Restore Workspace"
                      Command="{Binding RestoreSavedWorkspaceLayoutCommand}" />
            <MenuItem Header="Show / Hide Panels">
              <MenuItem Header="{Binding LeftPanelToggleLabel}"
                        HotKey="Ctrl+Shift+1"
                        Command="{Binding ToggleWorkspacePanelCommand}"
                        CommandParameter="left" />
              <MenuItem Header="{Binding RightPanelToggleLabel}"
                        HotKey="Ctrl+Shift+2"
                        Command="{Binding ToggleWorkspacePanelCommand}"
                        CommandParameter="right" />
              <MenuItem Header="{Binding TimelinePanelToggleLabel}"
                        HotKey="Ctrl+Shift+3"
                        Command="{Binding ToggleWorkspacePanelCommand}"
                        CommandParameter="timeline" />
            </MenuItem>
            <MenuItem Header="Panel Modes">
              <MenuItem Header="Tools Dock">
                <MenuItem Header="Dock"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:dock" />
                <MenuItem Header="Overlay"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:over" />
                <MenuItem Header="Hide"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:hide" />
              </MenuItem>
              <MenuItem Header="Inspector Dock">
                <MenuItem Header="Dock"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="right:dock" />
                <MenuItem Header="Overlay"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="right:over" />
                <MenuItem Header="Hide"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="right:hide" />
              </MenuItem>
              <MenuItem Header="Timeline Dock">
                <MenuItem Header="Dock"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="timeline:dock" />
                <MenuItem Header="Overlay"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="timeline:over" />
                <MenuItem Header="Hide"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="timeline:hide" />
              </MenuItem>
            </MenuItem>
          </MenuItem>

          <MenuItem Classes="app-menu-root"
                    Header="_Help">
            <MenuItem Classes="menu-summary"
                      Header="{Binding HelpMenuSummary}"
                      IsEnabled="False" />
            <Separator />
            <MenuItem Header="Show Current Context"
                      Command="{Binding ShowWorkspaceHelpCommand}" />
            <MenuItem Header="Show Selection Context"
                      Command="{Binding ShowSelectionContextCommand}" />
            <MenuItem Header="Show Keyboard Shortcuts"
                      Command="{Binding ShowKeyboardShortcutsCommand}" />
          </MenuItem>
        </Menu>

        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding UseNativeMenuTitleBarLayout}">
          <Menu Classes="timeline-toolbar"
                VerticalAlignment="Center">
            <MenuItem Classes="timeline-toolbar-item"
                      Header="Panels">
              <MenuItem Header="Monitors">
                <MenuItem Header="{Binding DockWorkspace.StageSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="StageDocument" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="StageDocument" />
                </MenuItem>
                <MenuItem Header="{Binding DockWorkspace.SourceSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="SourceMonitorTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="SourceMonitorTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="SourceMonitorTool" />
                </MenuItem>
                <MenuItem Header="{Binding DockWorkspace.ProgramSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="ProgramMonitorTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="ProgramMonitorTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="ProgramMonitorTool" />
                </MenuItem>
              </MenuItem>
              <MenuItem Header="Timeline">
                <MenuItem Header="{Binding DockWorkspace.FramesSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="FramesTimelineTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="FramesTimelineTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="FramesTimelineTool" />
                </MenuItem>
                <MenuItem Header="{Binding DockWorkspace.CurvesSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="CurvesTimelineTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="CurvesTimelineTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="CurvesTimelineTool" />
                </MenuItem>
              </MenuItem>
              <MenuItem Header="Side panels">
                <MenuItem Header="{Binding DockWorkspace.ProjectSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="ProjectTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="ProjectTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="ProjectTool" />
                </MenuItem>
                <MenuItem Header="{Binding DockWorkspace.InspectorSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="InspectorTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="InspectorTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="InspectorTool" />
                </MenuItem>
                <MenuItem Header="{Binding DockWorkspace.OutputSurfaceMenuLabel}">
                  <MenuItem Header="Show / focus"
                            Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                            CommandParameter="OutputTool" />
                  <MenuItem Header="Overlay"
                            Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                            CommandParameter="OutputTool" />
                  <MenuItem Header="Hide"
                            Command="{Binding DockWorkspace.HideSurfaceCommand}"
                            CommandParameter="OutputTool" />
                </MenuItem>
              </MenuItem>
              <Separator />
              <MenuItem Header="Reveal all"
                        Command="{Binding DockWorkspace.RestoreAllSurfacesCommand}"
                        IsEnabled="{Binding DockWorkspace.CanRevealAllSurfaces}" />
            </MenuItem>

            <MenuItem Classes="timeline-toolbar-item"
                      Header="More">
              <MenuItem Header="Open..."
                        Click="OpenDocumentClick" />
              <MenuItem Header="Export">
                <MenuItem Header="Current Frame PNG..."
                          Click="ExportFrameClick" />
                <MenuItem Header="PNG Sequence..."
                          Click="RenderSequenceClick" />
                <MenuItem Header="Project Sequence..."
                          Click="RenderProjectClick" />
              </MenuItem>
              <Separator />
              <MenuItem Header="New Blank Animation"
                        Command="{Binding ResetBlankCommand}" />
              <MenuItem Header="New Sample Composition"
                        Command="{Binding ResetSampleCommand}" />
              <Separator />
              <MenuItem Header="Show current context"
                        Command="{Binding ShowWorkspaceHelpCommand}" />
              <MenuItem Header="Show selection context"
                        Command="{Binding ShowSelectionContextCommand}" />
              <MenuItem Header="Show keyboard shortcuts"
                        Command="{Binding ShowKeyboardShortcutsCommand}" />
            </MenuItem>
          </Menu>

          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
              <Button Classes="toolbar compact workspace-preset"
                      Content="Animate"
                      Command="{Binding DockWorkspace.ApplyPresetCommand}"
                      CommandParameter="Animate" />
              <Button Classes="toolbar compact workspace-preset"
                      Content="Editorial"
                      Command="{Binding DockWorkspace.ApplyPresetCommand}"
                      CommandParameter="Editorial" />
              <Button Classes="toolbar compact workspace-preset"
                      Content="Review"
                      Command="{Binding DockWorkspace.ApplyPresetCommand}"
                      CommandParameter="Review" />
              <Button Classes="toolbar compact workspace-preset"
                      Content="Stage"
                      Command="{Binding DockWorkspace.ApplyPresetCommand}"
                      CommandParameter="StageFocus" />
            </StackPanel>
          </Border>

          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="5"
                        VerticalAlignment="Center">
              <CheckBox Content="Dock"
                        IsChecked="{Binding UseDockWorkspace, Mode=TwoWay}" />
              <Button Classes="toolbar"
                      Content="Reset Dock"
                      Command="{Binding DockWorkspace.ResetLayoutCommand}"
                      IsVisible="{Binding IsDockWorkspaceVisible}" />
              <Button Classes="toolbar"
                      Content="Edit Symbol"
                      Command="{Binding EnterSelectedSymbolEditCommand}"
                      IsVisible="{Binding CanEnterSymbolEdit}"
                      IsEnabled="{Binding CanEnterSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Exit Symbol"
                      Command="{Binding ExitSymbolEditCommand}"
                      IsVisible="{Binding CanExitSymbolEdit}"
                      IsEnabled="{Binding CanExitSymbolEdit}" />
              <ToggleButton Classes="toolbar warm"
                            Content="Prototype"
                            Command="{Binding TogglePrototypeModeCommand}"
                            IsChecked="{Binding IsPrototypeMode, Mode=OneWay}"
                            IsEnabled="{Binding CanTogglePrototypeModeMenu}" />
              <Button Classes="toolbar accent"
                      Content="Save"
                      Click="SaveDocumentClick" />
              <Button Classes="toolbar"
                      Content="Undo"
                      Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" />
              <Button Classes="toolbar"
                      Content="Redo"
                      Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" />
              <Button Classes="toolbar"
                      Content="Reveal"
                      Command="{Binding DockWorkspace.RestoreAllSurfacesCommand}"
                      IsVisible="{Binding DockWorkspace.CanRevealAllSurfaces}"
                      IsEnabled="{Binding DockWorkspace.CanRevealAllSurfaces}" />
            </StackPanel>
          </Border>
        </StackPanel>
        </Grid>

        <Border Grid.Column="3"
                Classes="workspace-tab active">
          <StackPanel Spacing="2">
            <TextBlock Classes="eyebrow"
                       Text="Document" />
            <TextBlock Classes="strong-label"
                       Text="{Binding DocumentName}" />
            <TextBlock Classes="micro-label"
                       Text="{Binding DocumentFileSummary}" />
          </StackPanel>
        </Border>
      </controls:TitleBarDragGrid>
    </Border>

    <Border Grid.Row="1"
            Classes="chrome-soft">
      <Grid>
        <Grid IsVisible="{Binding IsDockWorkspaceVisible}"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      IsVisible="{Binding ShowWorkspacePresetStrip}">
            <Border Classes="workspace-tab active">
              <TextBlock Classes="strong-label"
                         Text="Essentials" />
            </Border>
            <Button Classes="toolbar compact workspace-preset"
                    Content="Animate"
                    Command="{Binding DockWorkspace.ApplyPresetCommand}"
                    CommandParameter="Animate" />
            <Button Classes="toolbar compact workspace-preset"
                    Content="Editorial"
                    Command="{Binding DockWorkspace.ApplyPresetCommand}"
                    CommandParameter="Editorial" />
            <Button Classes="toolbar compact workspace-preset"
                    Content="Review"
                    Command="{Binding DockWorkspace.ApplyPresetCommand}"
                    CommandParameter="Review" />
            <Button Classes="toolbar compact workspace-preset"
                    Content="Stage"
                    Command="{Binding DockWorkspace.ApplyPresetCommand}"
                    CommandParameter="StageFocus" />
            <Border Classes="chrome-group">
              <StackPanel Orientation="Horizontal"
                          Spacing="6"
                          VerticalAlignment="Center">
                <CheckBox Content="Dock"
                          IsChecked="{Binding UseDockWorkspace, Mode=TwoWay}" />
                <Button Classes="toolbar"
                        Content="Reset"
                        Command="{Binding DockWorkspace.ResetLayoutCommand}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="workspace-summary-chip"
                  Padding="10,5"
                  ToolTip.Tip="{Binding DockWorkspace.WorkspaceOrganizerSummary}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
              <StackPanel Spacing="1">
                <TextBlock Classes="eyebrow"
                           Text="{Binding DockWorkspace.CurrentPresetLabel}" />
                <TextBlock Classes="strong-label"
                           Text="{Binding SelectionHeadline}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="1">
                <TextBlock Classes="micro-label"
                           Text="{Binding SelectedSceneSummary}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Classes="micro-label"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Grid>
          </Border>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      IsVisible="{Binding ShowDockWorkspaceOrganizerMenus}">
            <Menu Classes="timeline-toolbar">
              <MenuItem Classes="timeline-toolbar-item"
                        Header="Panels">
                <MenuItem Header="Monitors">
                  <MenuItem Header="{Binding DockWorkspace.StageSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="StageDocument" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="StageDocument" />
                  </MenuItem>
                  <MenuItem Header="{Binding DockWorkspace.SourceSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="SourceMonitorTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="SourceMonitorTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="SourceMonitorTool" />
                  </MenuItem>
                  <MenuItem Header="{Binding DockWorkspace.ProgramSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="ProgramMonitorTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="ProgramMonitorTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="ProgramMonitorTool" />
                  </MenuItem>
                </MenuItem>
                <MenuItem Header="Timeline">
                  <MenuItem Header="{Binding DockWorkspace.FramesSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="FramesTimelineTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="FramesTimelineTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="FramesTimelineTool" />
                  </MenuItem>
                  <MenuItem Header="{Binding DockWorkspace.CurvesSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="CurvesTimelineTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="CurvesTimelineTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="CurvesTimelineTool" />
                  </MenuItem>
                </MenuItem>
                <MenuItem Header="Side panels">
                  <MenuItem Header="{Binding DockWorkspace.ProjectSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="ProjectTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="ProjectTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="ProjectTool" />
                  </MenuItem>
                  <MenuItem Header="{Binding DockWorkspace.InspectorSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="InspectorTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="InspectorTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="InspectorTool" />
                  </MenuItem>
                  <MenuItem Header="{Binding DockWorkspace.OutputSurfaceMenuLabel}">
                    <MenuItem Header="Show / focus"
                              Command="{Binding DockWorkspace.FocusSurfaceCommand}"
                              CommandParameter="OutputTool" />
                    <MenuItem Header="Overlay"
                              Command="{Binding DockWorkspace.OverlaySurfaceCommand}"
                              CommandParameter="OutputTool" />
                    <MenuItem Header="Hide"
                              Command="{Binding DockWorkspace.HideSurfaceCommand}"
                              CommandParameter="OutputTool" />
                  </MenuItem>
                </MenuItem>
                <Separator />
                <MenuItem Header="Reveal all"
                          Command="{Binding DockWorkspace.RestoreAllSurfacesCommand}"
                          IsEnabled="{Binding DockWorkspace.CanRevealAllSurfaces}" />
              </MenuItem>

              <MenuItem Classes="timeline-toolbar-item"
                        Header="More">
                <MenuItem Header="Open..."
                          Click="OpenDocumentClick" />
                <MenuItem Header="Export">
                  <MenuItem Header="Current Frame PNG..."
                            Click="ExportFrameClick" />
                  <MenuItem Header="PNG Sequence..."
                            Click="RenderSequenceClick" />
                  <MenuItem Header="Project Sequence..."
                            Click="RenderProjectClick" />
                </MenuItem>
                <Separator />
                <MenuItem Header="New Blank Animation"
                          Command="{Binding ResetBlankCommand}" />
                <MenuItem Header="New Sample Composition"
                          Command="{Binding ResetSampleCommand}" />
                <Separator />
                <MenuItem Header="Show current context"
                          Command="{Binding ShowWorkspaceHelpCommand}" />
                <MenuItem Header="Show selection context"
                          Command="{Binding ShowSelectionContextCommand}" />
                <MenuItem Header="Show keyboard shortcuts"
                          Command="{Binding ShowKeyboardShortcutsCommand}" />
              </MenuItem>
            </Menu>

            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        IsVisible="{Binding ShowSecondaryWorkspaceActions}">
              <Button Classes="toolbar"
                      Content="Edit Symbol"
                      Command="{Binding EnterSelectedSymbolEditCommand}"
                      IsVisible="{Binding CanEnterSymbolEdit}"
                      IsEnabled="{Binding CanEnterSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Exit Symbol"
                      Command="{Binding ExitSymbolEditCommand}"
                      IsVisible="{Binding CanExitSymbolEdit}"
                      IsEnabled="{Binding CanExitSymbolEdit}" />
              <ToggleButton Classes="toolbar warm"
                            Content="Prototype"
                            Command="{Binding TogglePrototypeModeCommand}"
                            IsChecked="{Binding IsPrototypeMode, Mode=OneWay}"
                            IsEnabled="{Binding CanTogglePrototypeModeMenu}" />
              <Button Classes="toolbar accent"
                      Content="Save"
                      Click="SaveDocumentClick" />
              <Button Classes="toolbar"
                      Content="Undo"
                      Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" />
              <Button Classes="toolbar"
                      Content="Redo"
                      Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" />
              <Button Classes="toolbar"
                      Content="Reveal"
                      Command="{Binding DockWorkspace.RestoreAllSurfacesCommand}"
                      IsVisible="{Binding DockWorkspace.CanRevealAllSurfaces}"
                      IsEnabled="{Binding DockWorkspace.CanRevealAllSurfaces}" />
            </StackPanel>
          </StackPanel>
        </Grid>

        <Grid IsVisible="{Binding IsClassicWorkspaceVisible}"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ShowWorkspacePresetStrip}">
          <Border Classes="workspace-tab active">
            <TextBlock Classes="strong-label"
                       Text="Essentials" />
          </Border>
          <Button Classes="toolbar compact workspace-preset"
                  Content="Animate"
                  Command="{Binding DockWorkspace.ApplyPresetCommand}"
                  CommandParameter="Animate"
                  IsVisible="{Binding IsDockWorkspaceVisible}" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Editorial"
                  Command="{Binding DockWorkspace.ApplyPresetCommand}"
                  CommandParameter="Editorial"
                  IsVisible="{Binding IsDockWorkspaceVisible}" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Review"
                  Command="{Binding DockWorkspace.ApplyPresetCommand}"
                  CommandParameter="Review"
                  IsVisible="{Binding IsDockWorkspaceVisible}" />
          <Button Classes="toolbar compact workspace-preset"
                  Content="Stage"
                  Command="{Binding DockWorkspace.ApplyPresetCommand}"
                  CommandParameter="StageFocus"
                  IsVisible="{Binding IsDockWorkspaceVisible}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding WorkspaceShortcutSummary}">
          <StackPanel.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Restore Workspace"
                        Command="{Binding RestoreSavedWorkspaceLayoutCommand}" />
              <Separator />
              <MenuItem Header="Focus">
                <MenuItem Header="Classic"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="classic" />
                <MenuItem Header="Stage"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="stage" />
                <MenuItem Header="Timeline"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="timeline" />
                <MenuItem Header="Tools"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="tools" />
                <MenuItem Header="Inspector"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="inspector" />
              </MenuItem>
              <MenuItem Header="Panels">
                <MenuItem Header="{Binding LeftPanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="left" />
                <MenuItem Header="{Binding RightPanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="right" />
                <MenuItem Header="{Binding TimelinePanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="timeline" />
              </MenuItem>
            </ContextMenu>
          </StackPanel.ContextMenu>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Classes="micro-label"
                         VerticalAlignment="Center"
                         Text="Workspace" />
              <CheckBox Content="Dock"
                        IsChecked="{Binding UseDockWorkspace, Mode=TwoWay}" />
              <ComboBox Width="108"
                        IsEnabled="{Binding IsClassicWorkspaceVisible}"
                        ItemsSource="{Binding AvailableWorkspacePresets}"
                        SelectedItem="{Binding SelectedWorkspacePreset, Mode=TwoWay}" />
              <Button Classes="toolbar"
                      Content="Restore"
                      IsEnabled="{Binding IsClassicWorkspaceVisible}"
                      Command="{Binding RestoreSavedWorkspaceLayoutCommand}" />
              <Button Classes="toolbar"
                      Content="Reset Dock"
                      Command="{Binding DockWorkspace.ResetLayoutCommand}"
                      IsVisible="{Binding IsDockWorkspaceVisible}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group"
                  IsVisible="{Binding HasHiddenWorkspacePanels}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Classes="micro-label"
                         VerticalAlignment="Center"
                         Text="Show" />
              <Button Classes="toolbar"
                      Content="Tools"
                      IsVisible="{Binding IsLeftPanelHidden}"
                      Command="{Binding ToggleWorkspacePanelCommand}"
                      CommandParameter="left" />
              <Button Classes="toolbar"
                      Content="Inspector"
                      IsVisible="{Binding IsRightPanelHidden}"
                      Command="{Binding ToggleWorkspacePanelCommand}"
                      CommandParameter="right" />
              <Button Classes="toolbar"
                      Content="Timeline"
                      IsVisible="{Binding IsTimelinePanelHidden}"
                      Command="{Binding ToggleWorkspacePanelCommand}"
                      CommandParameter="timeline" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Classes="micro-label"
                         VerticalAlignment="Center"
                         Text="Focus" />
              <ComboBox Width="98"
                        ItemsSource="{Binding AvailableWorkspaceFocusTargets}"
                        SelectedItem="{Binding SelectedWorkspaceFocusTarget, Mode=TwoWay}" />
              <Button Classes="toolbar"
                      Content="Apply"
                      Command="{Binding FocusWorkspaceAreaCommand}"
                      CommandParameter="{Binding SelectedWorkspaceFocusTarget}" />
            </StackPanel>
          </Border>
          <Border Classes="workspace-summary-chip"
                  ToolTip.Tip="{Binding WorkspaceLayoutSummary}">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Context" />
              <TextBlock Classes="strong-label"
                         Text="{Binding WorkspaceSummary}"
                         TextTrimming="CharacterEllipsis" />
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="{Binding WorkspaceLayoutLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding DurationLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding FrameRateLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding CanvasSizeLabel}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ShowSecondaryWorkspaceActions}">
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Edit Symbol"
                      Command="{Binding EnterSelectedSymbolEditCommand}"
                      IsEnabled="{Binding CanEnterSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Exit Symbol"
                      Command="{Binding ExitSymbolEditCommand}"
                      IsEnabled="{Binding CanExitSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Prototype"
                      Command="{Binding TogglePrototypeModeCommand}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Undo"
                      Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" />
              <Button Classes="toolbar"
                      Content="Redo"
                      Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" />
              <Button Classes="toolbar"
                      Content="Sample"
                      Command="{Binding ResetSampleCommand}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Open"
                      Click="OpenDocumentClick" />
              <Button Classes="toolbar accent"
                      Content="Save"
                      Click="SaveDocumentClick" />
              <Button Classes="toolbar"
                      Content="Frame"
                      Click="ExportFrameClick" />
              <Button Classes="toolbar warm"
                      Content="Sequence"
                      Click="RenderSequenceClick" />
              <Button Classes="toolbar"
                      Content="Project"
                      Click="RenderProjectClick" />
            </StackPanel>
          </Border>
        </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <ContentControl Grid.Row="2"
                    IsVisible="{Binding IsDockWorkspaceVisible}"
                    Content="{Binding DockWorkspace}" />

    <Grid Grid.Row="2"
          IsVisible="{Binding IsClassicWorkspaceVisible}"
          ClipToBounds="False">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding LeftPanelColumnWidth}" MinWidth="0" />
        <ColumnDefinition Width="{Binding LeftSplitterColumnWidth}" />
        <ColumnDefinition Width="*" MinWidth="520" />
        <ColumnDefinition Width="{Binding RightSplitterColumnWidth}" />
        <ColumnDefinition Width="{Binding RightPanelColumnWidth}" MinWidth="0" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0"
            Grid.ColumnSpan="{Binding LeftPanelColumnSpan}"
            Width="{Binding LeftPanelHostWidth}"
            HorizontalAlignment="{Binding LeftPanelHorizontalAlignment}"
            Margin="{Binding LeftPanelHostMargin}"
            Panel.ZIndex="{Binding LeftPanelZIndex}"
            IsVisible="{Binding IsLeftPanelVisible}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" MinHeight="220" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="88" MinWidth="76" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="*" MinWidth="140" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Classes="panel">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                ColumnSpacing="4"
                ToolTip.Tip="Right click for dock actions">
            <Grid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Focus Tools"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="tools" />
                <Separator />
                <MenuItem Header="Dock"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:dock" />
                <MenuItem Header="Overlay"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:over" />
                <MenuItem Header="Hide"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:hide" />
              </ContextMenu>
            </Grid.ContextMenu>
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Authoring" />
              <TextBlock Classes="section-title"
                         Text="Tools + project" />
            </StackPanel>
            <ToggleButton Grid.Column="1"
                          Classes="toolbar"
                          Content="Dock"
                          IsChecked="{Binding IsLeftPanelDocked, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:dock" />
            <ToggleButton Grid.Column="2"
                          Classes="toolbar"
                          Content="Over"
                          IsChecked="{Binding IsLeftPanelOverlay, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:over" />
            <ToggleButton Grid.Column="3"
                          Classes="toolbar"
                          Content="Hide"
                          IsChecked="{Binding IsLeftPanelHidden, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:hide" />
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Classes="panel">
          <Grid RowDefinitions="*,Auto"
                RowSpacing="6">
            <StackPanel Spacing="6">
              <Button Classes="tool-rail"
                      Content="Select"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Select" />
              <Button Classes="tool-rail"
                      Content="Rect"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Rectangle" />
              <Button Classes="tool-rail"
                      Content="Ellipse"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Ellipse" />
              <Button Classes="tool-rail"
                      Content="Text"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Text" />
              <Button Classes="tool-rail"
                      Content="Line"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Line" />
              <Button Classes="tool-rail"
                      Content="Pen"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Pen" />
              <Button Classes="tool-rail"
                      Content="Brush"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Brush" />
              <Button Classes="tool-rail accent"
                      Content="Play"
                      Command="{Binding TogglePlaybackCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="panel-soft">
              <StackPanel Spacing="4">
                <TextBlock Classes="eyebrow"
                           Text="Active" />
                <TextBlock Classes="strong-label"
                           Text="{Binding ToolModeLabel}"
                           TextWrapping="Wrap" />
                <TextBlock Classes="micro-label"
                           Text="{Binding CurrentFrameLabel}" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Classes="panel-splitter vertical"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <TabControl Grid.Row="1"
                    Grid.Column="2"
                    Classes="dock-tabs">
          <TabItem Header="Project">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="8"
                              IsEnabled="{Binding CanEditScenes}">
                    <TextBlock Classes="eyebrow"
                               Text="Composition" />
                    <TextBlock Classes="section-title"
                               Text="{Binding DocumentName}" />
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Selected scene" />
                      <TextBox Text="{Binding SceneNameEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Frame rate" />
                      <TextBox Text="{Binding SceneFrameRate, Mode=TwoWay}" />
                    </StackPanel>
                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedSceneSummary}"
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*,*,*,*"
                          ColumnSpacing="8">
                      <Button Content="+ Scene"
                              Command="{Binding AddSceneCommand}" />
                      <Button Grid.Column="1"
                              Content="Copy"
                              Command="{Binding DuplicateSceneCommand}" />
                      <Button Grid.Column="2"
                              Content="Back"
                              Command="{Binding MoveSceneBackwardCommand}"
                              IsEnabled="{Binding CanMoveSceneBackward}" />
                      <Button Grid.Column="3"
                              Content="Next"
                              Command="{Binding MoveSceneForwardCommand}"
                              IsEnabled="{Binding CanMoveSceneForward}" />
                      <Button Grid.Column="4"
                              Content="Remove"
                              Classes="warm"
                              Command="{Binding DeleteSceneCommand}"
                              IsEnabled="{Binding CanDeleteScene}" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Scenes}"
                             SelectedItem="{Binding SelectedScene, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SceneViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="82,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="82"
                                      Height="46"
                                      CornerRadius="10"
                                      Background="{Binding PreviewBrush}">
                                <Border Margin="8"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Padding="8,4"
                                        Background="#44000000"
                                        CornerRadius="8">
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Name}" />
                                </Border>
                              </Border>
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="Scene" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Border Classes="panel-soft">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="eyebrow"
                                     Text="Duration" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding DurationLabel}" />
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1"
                              Classes="panel-soft">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="eyebrow"
                                     Text="Stage" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CanvasSizeLabel}" />
                        </StackPanel>
                      </Border>
                    </Grid>
                    <TextBlock Classes="micro-label"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Layers" />
                        <TextBlock Classes="section-title"
                                   Text="Composition stack" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="+ Folder"
                              Command="{Binding AddFolderCommand}" />
                      <Button Grid.Column="2"
                              Content="+ Rect"
                              Command="{Binding AddRectangleCommand}" />
                      <Button Grid.Column="3"
                              Content="+ Orb"
                              Classes="warm"
                              Command="{Binding AddEllipseCommand}" />
                      <Button Grid.Column="4"
                              Content="+ Text"
                              Command="{Binding AddTextCommand}" />
                      <Button Grid.Column="5"
                              Content="+ Camera"
                              Command="{Binding AddCameraLayerCommand}"
                              IsEnabled="{Binding CanAddCameraLayer}" />
                      <Button Grid.Column="6"
                              Content="Group"
                              Command="{Binding GroupSelectionIntoFolderCommand}"
                              IsEnabled="{Binding CanGroupSelectionIntoFolder}" />
                      <Button Grid.Column="7"
                              Content="Copy"
                              Command="{Binding DuplicateSelectionCommand}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding Layers}"
                             SelectedItem="{Binding SelectedLayer, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayerViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding FillBrush}" />
                              <StackPanel Grid.Column="1"
                                          Margin="{Binding HierarchyMargin}"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           IsVisible="{Binding HasLibraryLink}"
                                           Text="{Binding LibraryLinkLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding StateBadge}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding KindLabel}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Content="Forward"
                              Command="{Binding BringForwardCommand}" />
                      <Button Grid.Column="1"
                              Content="Backward"
                              Command="{Binding SendBackwardCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">
                      <Button Content="{Binding SelectedLayerVisibilityLabel}"
                              Command="{Binding ToggleSelectedLayerVisibilityCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                      <Button Grid.Column="1"
                              Content="{Binding SelectedLayerLockLabel}"
                              Command="{Binding ToggleSelectedLayerLockCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                      <Button Grid.Column="2"
                              Content="{Binding SelectedLayerExpandLabel}"
                              Command="{Binding ToggleSelectedFolderExpandedCommand}"
                              IsEnabled="{Binding CanToggleSelectedFolderExpanded}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">
                      <Button Content="{Binding SelectedLayerMuteLabel}"
                              Command="{Binding ToggleSelectedLayerMuteCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                      <Button Grid.Column="1"
                              Content="{Binding SelectedLayerSoloLabel}"
                              Command="{Binding ToggleSelectedLayerSoloCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                      <Button Grid.Column="2"
                              Content="Move To Root"
                              Command="{Binding RemoveSelectionFromFolderCommand}"
                              IsEnabled="{Binding CanRemoveSelectionFromFolder}" />
                    </Grid>

                    <Button Content="Delete Selection"
                            Classes="warm"
                            Command="{Binding DeleteSelectionCommand}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Assets">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow"
                               Text="Palette" />
                    <TextBlock Classes="section-title"
                               Text="Drop new elements onto the stage" />
                    <ItemsControl ItemsSource="{Binding PaletteItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemViewModel">
                          <controls:PaletteItemControl />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow"
                               Text="Avalonia Toolbox" />
                    <TextBlock Classes="section-title"
                               Text="Controls, shapes, and visual hosts" />
                    <TextBlock Classes="micro-label"
                               Text="Drag native Avalonia controls onto the stage to compose animated UI states." />
                    <ItemsControl ItemsSource="{Binding AvaloniaToolboxItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemViewModel">
                          <controls:PaletteItemControl />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Library" />
                        <TextBlock Classes="section-title"
                                   Text="Reusable symbols" />
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="8">
                        <Button Content="Edit"
                                Command="{Binding EnterSelectedSymbolEditCommand}"
                                IsEnabled="{Binding CanEnterSymbolEdit}" />
                        <Button Content="Place"
                                Command="{Binding InsertSelectedLibraryItemCommand}"
                                IsEnabled="{Binding CanInsertFromLibrary}" />
                      </StackPanel>
                      <Button Grid.Column="2"
                              Content="Relink"
                              Classes="warm"
                              Command="{Binding RelinkSelectionToSelectedLibraryItemCommand}"
                              IsEnabled="{Binding CanRelinkSelectionToSelectedLibraryItem}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,156"
                          ColumnSpacing="10">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="micro-label"
                                   Text="Search" />
                        <TextBox Watermark="Name, folder, linkage, source"
                                 Text="{Binding LibrarySearchText, Mode=TwoWay}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Spacing="6">
                        <TextBlock Classes="micro-label"
                                   Text="Folder filter" />
                        <ComboBox ItemsSource="{Binding LibraryFolderFilters}"
                                  SelectedItem="{Binding SelectedLibraryFolderFilter, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedLibrarySummary}"
                               TextWrapping="Wrap" />

                    <Border Classes="panel-soft"
                            IsEnabled="{Binding CanEditSelectedLibraryItem}">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow"
                                   Text="Asset Metadata" />
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Asset name" />
                          <TextBox Text="{Binding LibraryItemNameEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Folder path" />
                          <TextBox Watermark="Symbols/Graphics"
                                   Text="{Binding LibraryFolderEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Linkage id" />
                          <TextBox Watermark="hero_card"
                                   Text="{Binding LibraryLinkageIdEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Base class" />
                          <TextBox Watermark="Project.SymbolBase"
                                   Text="{Binding LibraryBaseClassEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Runtime export"
                                    IsChecked="{Binding LibraryExportForRuntimeEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Runtime import"
                                    IsChecked="{Binding LibraryImportForRuntimeEditor, Mode=TwoWay}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Export in first frame"
                                    IsChecked="{Binding LibraryExportInFirstFrameEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Auto update"
                                    IsChecked="{Binding LibraryUpdateAutomaticallyEditor, Mode=TwoWay}" />
                        </Grid>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Shared library path" />
                          <TextBox Watermark="libs/shared_assets.fla"
                                   Text="{Binding LibrarySharedLibraryPathEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Registration X" />
                            <TextBox Text="{Binding LibraryRegistrationPointXEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Registration Y" />
                            <TextBox Text="{Binding LibraryRegistrationPointYEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                          <CheckBox Content="Use Scale-9 grid"
                                    IsChecked="{Binding LibraryUseScale9GridEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10"
                              RowDefinitions="Auto,Auto"
                              IsVisible="{Binding LibraryUseScale9GridEditor}">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Scale left" />
                            <TextBox Text="{Binding LibraryScale9LeftEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Scale top" />
                            <TextBox Text="{Binding LibraryScale9TopEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Row="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Scale right" />
                            <TextBox Text="{Binding LibraryScale9RightEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Row="1"
                                      Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Scale bottom" />
                            <TextBox Text="{Binding LibraryScale9BottomEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Source path" />
                          <TextBox Watermark="Optional external source"
                                   Text="{Binding LibrarySourceAssetPathEditor, Mode=TwoWay}" />
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding EditingSymbolIsButton}">
                      <TextBlock Classes="micro-label"
                                 Text="Button state" />
                      <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                                SelectedItem="{Binding EditingButtonState, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="New symbol type" />
                      <ComboBox ItemsSource="{Binding AvailableSymbolKinds}"
                                SelectedItem="{Binding SelectedLibrarySymbolKind, Mode=TwoWay}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Content="Capture Selection"
                              Command="{Binding CreateSymbolFromSelectionCommand}"
                              IsEnabled="{Binding CanCreateSymbolFromSelection}" />
                      <Button Grid.Column="1"
                              Content="Update Symbol"
                              Command="{Binding UpdateLinkedSymbolFromSelectionCommand}"
                              IsEnabled="{Binding CanUpdateLinkedSymbol}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding LibraryItems}"
                             SelectedItem="{Binding SelectedLibraryItem, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryItemViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding FolderPathLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding LinkageLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SourceAssetLabel}" />
                              </StackPanel>
                              <StackPanel Grid.Column="2"
                                          Spacing="2"
                                          VerticalAlignment="Center">
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SymbolKindLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding AssetKindLabel}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Components" />
                        <TextBlock Classes="section-title"
                                   Text="Interactive building blocks" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Capture"
                              Command="{Binding CreateComponentFromSelectionCommand}"
                              IsEnabled="{Binding CanCreateComponentFromSelection}" />
                      <Button Grid.Column="2"
                              Content="Place"
                              Classes="warm"
                              Command="{Binding InsertSelectedComponentCommand}"
                              IsEnabled="{Binding CanInsertSelectedComponent}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedComponentSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding ComponentItems}"
                             SelectedItem="{Binding SelectedComponentItem, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryItemViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding ComponentBadge}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Media" />
                        <TextBlock Classes="section-title"
                                   Text="Audio and video clips" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Import Audio"
                              Click="ImportAudioClick" />
                      <Button Grid.Column="2"
                              Content="Import Video"
                              Click="ImportVideoClick" />
                      <Button Grid.Column="3"
                              Content="Place"
                              Classes="warm"
                              Command="{Binding InsertSelectedMediaAssetCommand}"
                              IsEnabled="{Binding CanInsertSelectedMediaAsset}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedMediaSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding MediaAssets}"
                             SelectedItem="{Binding SelectedMediaAsset, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaAssetViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SourceLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding KindLabel}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Output">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Animation Interop" />
                        <TextBlock Classes="section-title"
                                   Text="Preview, inspect, import, and export runtime animation formats" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Refresh"
                              Command="{Binding RefreshAnimationExchangePreviewCommand}" />
                      <Button Grid.Column="2"
                              Content="Import"
                              Click="ImportAnimationFormatClick" />
                      <Button Grid.Column="3"
                              Content="Export"
                              Classes="accent"
                              Click="ExportAnimationFormatClick" />
                    </Grid>

                    <Grid ColumnDefinitions="160,148,*"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="micro-label"
                                   Text="Format" />
                        <ComboBox ItemsSource="{Binding AvailableAnimationExchangeFormats}"
                                  SelectedItem="{Binding SelectedAnimationExchangeFormat, Mode=TwoWay}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Spacing="4">
                        <TextBlock Classes="micro-label"
                                   Text="Layout" />
                        <ComboBox ItemsSource="{Binding AvailableAnimationExchangePreviewModes}"
                                  SelectedItem="{Binding SelectedAnimationExchangePreviewMode, Mode=TwoWay}" />
                      </StackPanel>
                      <Border Grid.Column="2"
                              Classes="panel-soft">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="micro-label"
                                     Text="{Binding SelectedAnimationExchangeSummary}"
                                     TextWrapping="Wrap" />
                          <TextBlock Classes="micro-label"
                                     Text="{Binding AnimationExchangePreviewModeSummary}" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                      <Border Classes="metric-chip">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="eyebrow"
                                     Text="Generated file" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding AnimationExchangePreviewFileSummary}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="1"
                              Classes="metric-chip">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="eyebrow"
                                     Text="Preview summary" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding AnimationExchangePreviewSummaryDisplay}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <Border Classes="panel-soft"
                            IsVisible="{Binding HasAnimationExchangePreviewIssues}">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="eyebrow"
                                   Text="Preview diagnostics" />
                        <ItemsControl ItemsSource="{Binding AnimationExchangePreviewIssues}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AnimationExchangeIssue">
                              <Border Classes="layer-row">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="strong-label"
                                             Text="{Binding Severity}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Source}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Message}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding AnimationExchangeCodeColumnWidth}" />
                        <ColumnDefinition Width="{Binding AnimationExchangeSplitterColumnWidth}" />
                        <ColumnDefinition Width="{Binding AnimationExchangeVisualColumnWidth}" />
                      </Grid.ColumnDefinitions>

                      <Border Grid.Column="0"
                              Classes="panel-soft"
                              IsVisible="{Binding IsAnimationExchangeCodeVisible}">
                        <StackPanel Spacing="6">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="8">
                            <TextBlock Classes="eyebrow"
                                       Text="Generated code" />
                            <TextBlock Grid.Column="1"
                                       Classes="micro-label"
                                       Text="{Binding AnimationExchangePreviewFileSummary}" />
                          </Grid>
                          <controls:AnimationExchangeCodeEditorControl MinHeight="360"
                                                                        Text="{Binding AnimationExchangePreviewCode}"
                                                                        Format="{Binding SelectedAnimationExchangeFormat}" />
                        </StackPanel>
                      </Border>

                      <GridSplitter Grid.Column="1"
                                    Width="8"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding IsAnimationExchangeSplitMode}"
                                    Classes="panel-splitter vertical" />

                      <Border Grid.Column="2"
                              Classes="panel-soft"
                              IsVisible="{Binding IsAnimationExchangeVisualVisible}">
                        <StackPanel Spacing="6">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="8">
                            <TextBlock Classes="eyebrow"
                                       Text="Visual preview" />
                            <TextBlock Grid.Column="1"
                                       Classes="micro-label"
                                       Text="{Binding CurrentTimeLabel}" />
                          </Grid>
                          <controls:AnimationExchangeVisualPreviewControl MinHeight="360"
                                                                          Format="{Binding SelectedAnimationExchangeFormat}"
                                                                          PreviewText="{Binding AnimationExchangePreviewCode}"
                                                                          PreviewDocument="{Binding AnimationExchangePreviewDocument}"
                                                                          PreviewTime="{Binding CurrentTime}"
                                                                          PreviewSummary="{Binding AnimationExchangePreviewVisualSummary}" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="eyebrow"
                                   Text="Last run" />
                        <TextBlock Classes="micro-label"
                                   Text="{Binding LastAnimationExchangeSummaryDisplay}"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding AnimationExchangeIssues}"
                                      IsVisible="{Binding HasAnimationExchangeIssues}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AnimationExchangeIssue">
                              <Border Classes="layer-row">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="strong-label"
                                             Text="{Binding Severity}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Source}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Message}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10"
                              IsEnabled="{Binding CanEditPublishProfiles}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Publish" />
                        <TextBlock Classes="section-title"
                                   Text="Preview and export profiles" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="+ Profile"
                              Command="{Binding AddPublishProfileCommand}" />
                      <Button Grid.Column="2"
                              Content="Copy"
                              Command="{Binding DuplicatePublishProfileCommand}"
                              IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
                      <Button Grid.Column="3"
                              Content="Preview"
                              Click="PreviewPublishProfileClick"
                              IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
                      <Button Grid.Column="4"
                              Content="Publish"
                              Classes="accent"
                              Click="ExportPublishProfileClick"
                              IsEnabled="{Binding CanExportSelectedPublishProfile}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedPublishProfileSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding PublishProfiles}"
                             SelectedItem="{Binding SelectedPublishProfile, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PublishProfileViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="#57C9FF" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding FormatLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding OutputKind}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="Remove Selected Profile"
                            Classes="warm"
                            Command="{Binding DeletePublishProfileCommand}"
                            IsEnabled="{Binding CanDeletePublishProfile}" />

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow"
                                   Text="Profile setup" />
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Name" />
                          <TextBox Text="{Binding PublishProfileNameEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Output format" />
                          <ComboBox ItemsSource="{Binding AvailablePublishOutputs}"
                                    SelectedItem="{Binding PublishOutputKindEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Width" />
                            <TextBox Text="{Binding PublishWidthEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Height" />
                            <TextBox Text="{Binding PublishHeightEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Frame rate" />
                            <TextBox Text="{Binding PublishFrameRateEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Quality" />
                            <TextBox Text="{Binding PublishQualityEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding PublishOutputIsSpriteSheet}">
                          <TextBlock Classes="micro-label"
                                     Text="Sprite sheet columns" />
                          <TextBox Text="{Binding PublishSpriteSheetColumnsEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Play all scenes"
                                    IsChecked="{Binding PublishPlayAllScenesEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Transparent background"
                                    IsChecked="{Binding PublishTransparentBackgroundEditor, Mode=TwoWay}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Include scene graph"
                                    IsChecked="{Binding PublishIncludeSceneGraphEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Include validation report"
                                    IsChecked="{Binding PublishIncludeValidationReportEditor, Mode=TwoWay}" />
                        </Grid>
                        <TextBlock Classes="micro-label"
                                   IsVisible="{Binding PublishOutputRequiresDirectory}"
                                   Text="This profile publishes into a folder. Supplemental files are written alongside the frame sequence." />
                        <TextBlock Classes="micro-label"
                                   IsVisible="{Binding PublishOutputIsSingleFile}"
                                   Text="This profile publishes a single primary file and optional companion metadata beside it." />
                      </StackPanel>
                    </Border>

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                          <StackPanel Spacing="2">
                            <TextBlock Classes="eyebrow"
                                       Text="Validation" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding PublishValidationIssues.Count, StringFormat='{}{0} checks'}" />
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Classes="micro-label"
                                     VerticalAlignment="Center"
                                     Text="{Binding HasPublishErrors, StringFormat='Errors block export: {0}'}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding PublishValidationIssues}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PublishValidationIssue">
                              <Border Classes="layer-row">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="strong-label"
                                             Text="{Binding Severity}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Source}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Message}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="micro-label"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Grid>

      <GridSplitter Grid.Column="1"
                    Classes="panel-splitter vertical"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

      <Grid Grid.Column="2"
            ClipToBounds="False">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" MinHeight="320" />
          <RowDefinition Height="{Binding TimelineSplitterRowHeight}" />
          <RowDefinition Height="{Binding TimelinePanelRowHeight}" />
        </Grid.RowDefinitions>
        <Border Classes="panel"
                Padding="5">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="4">
            <Border Classes="chrome-group"
                    Padding="4,3"
                    ToolTip.Tip="{Binding CanvasViewportHint}">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <StackPanel Spacing="1">
                  <TextBlock Classes="section-title"
                             Text="{Binding SelectionHeadline}" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding SelectedSceneSummary}"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                  <Border Classes="metric-chip">
                    <StackPanel Spacing="1">
                      <TextBlock Classes="eyebrow"
                                 Text="Tool" />
                      <TextBlock Classes="strong-label"
                                 Text="{Binding ToolModeLabel}" />
                    </StackPanel>
                  </Border>
                  <CheckBox Content="Snap"
                            IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                  <CheckBox Content="Onion"
                            IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}" />
                  <Button Classes="toolbar"
                          Content="Fit"
                          Click="CanvasFitClick" />
                  <Button Classes="toolbar"
                          Content="1:1"
                          Click="CanvasActualSizeClick" />
                </StackPanel>

                <Border Grid.Column="2"
                        Classes="metric-chip"
                        Padding="7,4">
                  <StackPanel Spacing="1">
                    <TextBlock Classes="eyebrow"
                               Text="Stage" />
                    <TextBlock Classes="strong-label"
                               Text="{Binding CanvasSizeLabel}" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="stage-workspace"
                    Padding="5">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="6">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="6">
                  <Border Classes="panel-soft"
                          Padding="8">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="6">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Source Monitor" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding SourceMonitorTitle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Classes="micro-label"
                                   VerticalAlignment="Center"
                                   Text="{Binding SourceMonitorRangeSummary}" />
                      </Grid>
                      <Border Grid.Row="1"
                              Classes="panel-soft"
                              Padding="6"
                              Background="#07101C"
                              MinHeight="156">
                        <Grid RowDefinitions="*,Auto"
                              RowSpacing="6">
                          <Image Source="{Binding SourceMonitorBitmap}"
                                 Stretch="Uniform"
                                 IsVisible="{Binding HasSourceMonitorBitmap}" />
                          <TextBlock Grid.Row="1"
                                     Classes="micro-label"
                                     Text="{Binding SourceMonitorSummary}"
                                     TextWrapping="Wrap"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                      <Grid Grid.Row="2"
                            ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                            ColumnSpacing="8">
                        <Button Content="Mark In"
                                Classes="toolbar"
                                Command="{Binding MarkSourceMonitorInCommand}" />
                        <Button Grid.Column="1"
                                Content="Mark Out"
                                Classes="toolbar"
                                Command="{Binding MarkSourceMonitorOutCommand}" />
                        <Slider Grid.Column="2"
                                Minimum="0"
                                Maximum="{Binding SourceMonitorDuration}"
                                Value="{Binding SourceMonitorTime, Mode=TwoWay}" />
                        <TextBlock Grid.Column="3"
                                   Classes="micro-label"
                                   VerticalAlignment="Center"
                                   Text="{Binding SourceMonitorTime, StringFormat='{}{0:0.00}s'}" />
                        <TextBlock Grid.Column="4"
                                   Classes="micro-label"
                                   VerticalAlignment="Center"
                                   Text="{Binding SourceMonitorSummary}" />
                      </Grid>
                    </Grid>
                  </Border>

                  <Border Grid.Column="1"
                          Classes="panel-soft"
                          Padding="8">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="6">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Program Monitor" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding ProgramMonitorSummary}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Classes="micro-label"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentTimeLabel}" />
                      </Grid>
                      <Border Grid.Row="1"
                              Classes="panel-soft"
                              Padding="6"
                              Background="#07101C"
                              MinHeight="156">
                        <Grid RowDefinitions="*,Auto"
                              RowSpacing="6">
                          <Image Source="{Binding ProgramMonitorBitmap}"
                                 Stretch="Uniform"
                                 IsVisible="{Binding HasProgramMonitorBitmap}" />
                          <TextBlock Grid.Row="1"
                                     Classes="micro-label"
                                     Text="{Binding ProgramMonitorSummary}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                      <Grid Grid.Row="2"
                            ColumnDefinitions="Auto,Auto,*,Auto"
                            ColumnSpacing="8">
                        <Border Classes="metric-chip compact">
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CurrentSceneInFrameLabel}" />
                        </Border>
                        <Border Grid.Column="1"
                                Classes="metric-chip compact">
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CurrentSceneOutFrameLabel}" />
                        </Border>
                        <TextBlock Grid.Column="2"
                                   Classes="micro-label"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentSceneWorkAreaLabel}" />
                        <CheckBox Grid.Column="3"
                                  Content="Work area"
                                  IsChecked="{Binding UseWorkAreaPlayback, Mode=TwoWay}" />
                      </Grid>
                    </Grid>
                  </Border>
                </Grid>

                <Grid Grid.Row="1">
                  <controls:SceneCanvasControl x:Name="SceneCanvas"
                                               Document="{Binding Document}"
                                               Layers="{Binding Layers}"
                                               SelectedLayer="{Binding SelectedLayer}"
                                               CanvasZoom="{Binding CanvasZoom}"
                                               DrawingTool="{Binding SelectedDrawingTool}"
                                               CurrentTime="{Binding CurrentTime}"
                                               FrameRate="{Binding SceneFrameRate}"
                                               TotalFrames="{Binding TotalFrames}"
                                               Duration="{Binding Duration}"
                                               SnapToGrid="{Binding SnapToGrid}"
                                               OnionSkinEnabled="{Binding OnionSkinEnabled}"
                                               OnionSkinBefore="{Binding OnionSkinBefore}"
                                               OnionSkinAfter="{Binding OnionSkinAfter}"
                                               PrototypeMode="{Binding IsPrototypeMode}"
                                               CanResizeCanvas="{Binding CanEditCanvasProperties}"
                                               DocumentWidth="{Binding CanvasWidth}"
                                               DocumentHeight="{Binding CanvasHeight}"
                                               BackgroundFrom="{Binding BackgroundFrom}"
                                               BackgroundTo="{Binding BackgroundTo}" />

                  <Border Classes="canvas-overlay"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,10,10">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,180"
                          ColumnSpacing="8">
                      <Button Content="Fit"
                              Classes="toolbar"
                              Click="CanvasFitClick" />
                      <Button Grid.Column="1"
                              Content="1:1"
                              Classes="toolbar"
                              Click="CanvasActualSizeClick" />
                      <Border Grid.Column="2"
                              Classes="metric-chip compact">
                        <TextBlock Classes="strong-label"
                                   Text="{Binding CanvasZoomLabel}" />
                      </Border>
                      <Slider Grid.Column="3"
                              Minimum="0.25"
                              Maximum="8"
                              VerticalAlignment="Center"
                              Value="{Binding CanvasZoom, Mode=TwoWay}" />
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Classes="panel-splitter horizontal"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <Border Grid.Row="{Binding TimelinePanelGridRow}"
                Grid.RowSpan="{Binding TimelinePanelRowSpan}"
                Height="{Binding TimelinePanelHostHeight}"
                VerticalAlignment="{Binding TimelinePanelVerticalAlignment}"
                Margin="{Binding TimelinePanelHostMargin}"
                Panel.ZIndex="{Binding TimelinePanelZIndex}"
                IsVisible="{Binding IsTimelinePanelVisible}"
                Classes="panel"
                Padding="5">
          <Grid RowDefinitions="6,Auto,*"
                RowSpacing="4">
            <Border Grid.Row="0"
                    x:Name="TimelineResizeGrip"
                    Classes="timeline-resize-grip"
                    PointerPressed="TimelineResizeGripPointerPressed"
                    PointerMoved="TimelineResizeGripPointerMoved"
                    PointerReleased="TimelineResizeGripPointerReleased"
                    PointerCaptureLost="TimelineResizeGripPointerCaptureLost" />

            <Border Grid.Row="1"
                    Classes="chrome-group"
                    Padding="4,3"
                    ToolTip.Tip="Right click for dock actions">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Focus Timeline"
                            Command="{Binding FocusWorkspaceAreaCommand}"
                            CommandParameter="timeline" />
                  <Separator />
                  <MenuItem Header="Dock"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:dock" />
                  <MenuItem Header="Overlay"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:over" />
                  <MenuItem Header="Hide"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:hide" />
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="Auto,*,180,132,Auto"
                    ColumnSpacing="6">
                <StackPanel Orientation="Horizontal"
                            Spacing="4">
                  <ToggleButton Classes="timeline-tab"
                                MinWidth="78"
                                Content="Frames"
                                IsChecked="{Binding IsFramesTimelineViewActive, Mode=OneWay}"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Frames" />
                  <ToggleButton Classes="timeline-tab"
                                MinWidth="78"
                                Content="Curves"
                                IsChecked="{Binding IsCurvesTimelineViewActive, Mode=OneWay}"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Curves" />
                  <Border Width="1"
                          Height="22"
                          Margin="2,0"
                          Background="#222932"
                          VerticalAlignment="Center" />
                  <Button Classes="timeline-action accent"
                          Content="Play"
                          Command="{Binding TogglePlaybackCommand}" />
                  <Button Classes="timeline-action"
                          Content="Stop"
                          Command="{Binding StopPlaybackCommand}" />
                  <Button Classes="timeline-action"
                          Content="+ Key"
                          Command="{Binding AddCurrentKeyframeCommand}"
                          IsEnabled="{Binding CanEditPropertyTracks}" />
                  <Button Classes="timeline-action"
                          Content="- Key"
                          Command="{Binding DeleteCurrentKeyframeCommand}"
                          IsEnabled="{Binding CanDeleteSelectedKeyframe}" />
                  <ToggleButton Classes="timeline-action"
                                IsChecked="{Binding AutoKey, Mode=TwoWay}"
                                Content="Auto" />
                  <Menu Classes="timeline-toolbar">
                    <MenuItem Classes="timeline-toolbar-item"
                              Header="Playback">
                      <MenuItem Header="Loop playback"
                                ToggleType="CheckBox"
                                IsChecked="{Binding LoopPlayback, Mode=TwoWay}" />
                      <MenuItem Header="Play all scenes"
                                ToggleType="CheckBox"
                                IsChecked="{Binding PlayAllScenes, Mode=TwoWay}" />
                    </MenuItem>
                    <MenuItem Classes="timeline-toolbar-item"
                              Header="Options">
                      <MenuItem Header="Snap timeline"
                                ToggleType="CheckBox"
                                IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                      <Separator />
                      <MenuItem Header="Focus frames view"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Frames" />
                      <MenuItem Header="Focus curves view"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Curves" />
                    </MenuItem>
                  </Menu>
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="metric-chip"
                        Padding="8,4">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                    <StackPanel Spacing="1">
                      <TextBlock Classes="eyebrow"
                                 Text="Selection" />
                      <TextBlock Classes="strong-label"
                                 Text="{Binding CurrentFrameLabel}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Classes="micro-label"
                               VerticalAlignment="Center"
                               Text="{Binding TimelineWorkspaceViewSummary}" />
                  </Grid>
                </Border>

                <StackPanel Grid.Column="2"
                            Spacing="2">
                  <TextBlock Classes="eyebrow"
                             Text="Timeline zoom" />
                  <Slider Minimum="90"
                          Maximum="250"
                          Value="{Binding TimelineZoom, Mode=TwoWay}" />
                </StackPanel>

                <Border Grid.Column="3"
                        Classes="metric-chip">
                  <StackPanel Spacing="1">
                    <TextBlock Classes="eyebrow"
                               Text="Frame" />
                    <TextBlock Classes="strong-label"
                               Text="{Binding CurrentFrameLabel}" />
                    <TextBlock Classes="micro-label"
                               Text="{Binding FrameRateLabel}" />
                  </StackPanel>
                </Border>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                  <ToggleButton Classes="toolbar"
                                Content="Dock"
                                IsChecked="{Binding IsTimelinePanelDocked, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:dock" />
                  <ToggleButton Classes="toolbar"
                                Content="Over"
                                IsChecked="{Binding IsTimelinePanelOverlay, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:over" />
                  <ToggleButton Classes="toolbar"
                                Content="Hide"
                                IsChecked="{Binding IsTimelinePanelHidden, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:hide" />
                </StackPanel>
              </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid IsVisible="{Binding IsFramesTimelineViewActive}"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                  <Border Classes="chrome-group"
                          Padding="4,3">
                    <Grid ColumnDefinitions="Auto,220,*,148"
                          ColumnSpacing="6">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="4">
                        <Menu Classes="timeline-toolbar">
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Insert">
                            <MenuItem Header="Add cel"
                                      Command="{Binding AddFrameKeyframeCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                            <MenuItem Header="Add blank cel"
                                      Command="{Binding AddBlankFrameKeyframeCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                            <MenuItem Header="Extend hold"
                                      Command="{Binding ExtendFrameHoldCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Range">
                            <MenuItem Header="Copy frame range"
                                      Command="{Binding CopyFrameRangeCommand}"
                                      IsEnabled="{Binding CanCopyFrameRange}" />
                            <MenuItem Header="Paste frame range"
                                      Command="{Binding PasteFrameRangeCommand}"
                                      IsEnabled="{Binding CanPasteFrameRange}" />
                            <Separator />
                            <MenuItem Header="Set scene in"
                                      Command="{Binding SetSceneInPointCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                            <MenuItem Header="Set scene out"
                                      Command="{Binding SetSceneOutPointCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                            <MenuItem Header="Set work area from selection"
                                      Command="{Binding SetSceneWorkAreaFromSelectionCommand}"
                                      IsEnabled="{Binding CanSetSceneWorkArea}" />
                            <MenuItem Header="Clear work area"
                                      Command="{Binding ClearSceneWorkAreaCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                            <MenuItem Header="Use work area for playback"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding UseWorkAreaPlayback, Mode=TwoWay}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Edit">
                            <MenuItem Header="Edit multiple frames"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding EditMultipleFramesEnabled, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem Header="Razor split"
                                      Command="{Binding RazorSelectionCommand}"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Slip earlier"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="slip-back"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Slip later"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="slip-forward"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Slide earlier"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="slide-back"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Slide later"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="slide-forward"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Ripple shorter"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="ripple-shorter"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                            <MenuItem Header="Ripple longer"
                                      Command="{Binding ApplyEditorialOperationCommand}"
                                      CommandParameter="ripple-longer"
                                      IsEnabled="{Binding CanUseEditorialTools}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Markers">
                            <MenuItem Header="Save marker at playhead"
                                      Command="{Binding AddOrUpdateSceneMarkerCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                            <MenuItem Header="Remove selected marker"
                                      Command="{Binding RemoveSelectedSceneMarkerCommand}"
                                      IsEnabled="{Binding CanRemoveSelectedSceneMarker}" />
                            <Separator />
                            <MenuItem Header="Jump to scene in"
                                      Command="{Binding JumpToSceneInPointCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                            <MenuItem Header="Jump to scene out"
                                      Command="{Binding JumpToSceneOutPointCommand}"
                                      IsEnabled="{Binding CanEditSceneMarkers}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Onion">
                            <MenuItem Header="Enable onion skin"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem Header="Previous frames">
                              <MenuItem Header="0"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:0" />
                              <MenuItem Header="1"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:1" />
                              <MenuItem Header="2"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:2" />
                              <MenuItem Header="3"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:3" />
                              <MenuItem Header="4"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:4" />
                              <MenuItem Header="5"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:5" />
                              <MenuItem Header="6"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:6" />
                            </MenuItem>
                            <MenuItem Header="Next frames">
                              <MenuItem Header="0"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:0" />
                              <MenuItem Header="1"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:1" />
                              <MenuItem Header="2"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:2" />
                              <MenuItem Header="3"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:3" />
                              <MenuItem Header="4"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:4" />
                              <MenuItem Header="5"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:5" />
                              <MenuItem Header="6"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:6" />
                            </MenuItem>
                          </MenuItem>
                        </Menu>
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="4">
                        <TextBox Classes="timeline-entry"
                                 Width="132"
                                 Watermark="Frame label"
                                 Text="{Binding FrameLabelEditor, Mode=TwoWay}" />
                        <Button Classes="timeline-action"
                                Content="Set"
                                Command="{Binding AddOrUpdateFrameLabelCommand}" />
                        <Button Classes="timeline-action"
                                Content="Clear"
                                Command="{Binding RemoveFrameLabelCommand}" />
                      </StackPanel>

                      <Border Grid.Column="2"
                              Classes="metric-chip"
                              Padding="8,4">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                              ColumnSpacing="10">
                          <StackPanel Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Range" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding SelectedFrameRangeSummary}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="In / Out" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding CurrentSceneInFrameLabel}" />
                          </StackPanel>
                          <StackPanel Grid.Column="2"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Work" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding CurrentSceneWorkAreaLabel}" />
                          </StackPanel>
                          <StackPanel Grid.Column="3"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Marker" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding SelectedSceneMarkerSummary}" />
                          </StackPanel>
                          <StackPanel Grid.Column="4"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Power" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding EditMultipleFramesSummary}" />
                          </StackPanel>
                        </Grid>
                      </Border>

                      <StackPanel Grid.Column="3"
                                  Spacing="2">
                        <TextBlock Classes="eyebrow"
                                   Text="Frame zoom" />
                        <Slider Minimum="10"
                                Maximum="32"
                                Value="{Binding FrameTimelineZoom, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>
                  </Border>

                  <Border Grid.Row="1"
                          Classes="panel-soft"
                          Padding="0"
                          MinHeight="280">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MinHeight="280">
                      <controls:FrameTimelineControl x:Name="FrameTimeline"
                                                     Width="{Binding FrameTimelineSurfaceWidth}"
                                                     Height="{Binding FrameTimelineSurfaceHeight}"
                                                     Rows="{Binding FrameRows}"
                                                     Labels="{Binding SceneFrameLabels}"
                                                     Markers="{Binding SceneMarkers}"
                                                     CurrentFrame="{Binding CurrentFrame}"
                                                     TotalFrames="{Binding TotalFrames}"
                                                     PixelsPerFrame="{Binding FrameTimelineZoom}"
                                                     SelectedLayerId="{Binding SelectedLayerId}"
                                                     SelectionStartFrame="{Binding SelectionStartFrame}"
                                                     SelectionEndFrame="{Binding SelectionEndFrame}"
                                                     InFrame="{Binding CurrentSceneInFrame}"
                                                     OutFrame="{Binding CurrentSceneOutFrame}"
                                                     WorkAreaStartFrame="{Binding CurrentSceneWorkAreaStartFrame}"
                                                     WorkAreaEndFrame="{Binding CurrentSceneWorkAreaEndFrame}" />
                    </ScrollViewer>
                  </Border>
                </Grid>

                <Grid IsVisible="{Binding IsCurvesTimelineViewActive}"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                  <Border Classes="chrome-group"
                          Padding="4,3">
                    <Grid ColumnDefinitions="*,*,180"
                          ColumnSpacing="6">
                      <Border Classes="metric-chip">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Keyframe" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding SelectedKeyframeSummary}" />
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="1"
                              Classes="metric-chip">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Shape tween" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding ShapeTweenSummary}" />
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="2"
                              Classes="panel-soft"
                              Padding="8,5">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Playhead" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CurrentTimeLabel}" />
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>

                  <Border Grid.Row="1"
                          Classes="panel-soft"
                          Padding="0"
                          MinHeight="300">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MinHeight="300">
                      <controls:TimelineEditorControl x:Name="TimelineEditor"
                                                      Width="{Binding TimelineSurfaceWidth}"
                                                      Height="{Binding TimelineSurfaceHeight}"
                                                      Rows="{Binding TimelineRows}"
                                                      CurrentTime="{Binding CurrentTime}"
                                                      Duration="{Binding Duration}"
                                                      SelectedProperty="{Binding SelectedProperty}"
                                                      SelectedKeyframeId="{Binding SelectedKeyframeId}"
                                                      PixelsPerSecond="{Binding TimelineZoom}" />
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Grid>
            </Grid>
        </Border>

        <Button Classes="toolbar edge-handle"
                Content="Tools"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="8,0,0,0"
                ZIndex="40"
                IsVisible="{Binding IsLeftPanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="left" />

        <Button Classes="toolbar edge-handle"
                Content="Inspector"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                ZIndex="40"
                IsVisible="{Binding IsRightPanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="right" />

        <Button Classes="toolbar edge-handle"
                Content="Timeline"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                ZIndex="40"
                IsVisible="{Binding IsTimelinePanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="timeline" />
      </Grid>

      <GridSplitter Grid.Column="3"
                    Classes="panel-splitter vertical"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

      <TabControl Grid.Column="{Binding RightPanelGridColumn}"
                  Grid.ColumnSpan="{Binding RightPanelColumnSpan}"
                  Width="{Binding RightPanelHostWidth}"
                  HorizontalAlignment="{Binding RightPanelHorizontalAlignment}"
                  Margin="{Binding RightPanelHostMargin}"
                  Panel.ZIndex="{Binding RightPanelZIndex}"
                  IsVisible="{Binding IsRightPanelVisible}"
                  Classes="dock-tabs">
        <TabItem Header="Properties">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">
          <Border Classes="panel">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                    ColumnSpacing="4"
                    ToolTip.Tip="Right click for dock actions">
                <Grid.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Focus Inspector"
                              Command="{Binding FocusWorkspaceAreaCommand}"
                              CommandParameter="inspector" />
                    <Separator />
                    <MenuItem Header="Dock"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:dock" />
                    <MenuItem Header="Overlay"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:over" />
                    <MenuItem Header="Hide"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:hide" />
                  </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock Classes="section-title"
                           VerticalAlignment="Center"
                           Text="Inspector" />
                <ToggleButton Grid.Column="1"
                              Classes="toolbar"
                              Content="Dock"
                              IsChecked="{Binding IsRightPanelDocked, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:dock" />
                <ToggleButton Grid.Column="2"
                              Classes="toolbar"
                              Content="Over"
                              IsChecked="{Binding IsRightPanelOverlay, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:over" />
                <ToggleButton Grid.Column="3"
                              Classes="toolbar"
                              Content="Hide"
                              IsChecked="{Binding IsRightPanelHidden, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:hide" />
              </Grid>
              <TextBlock Classes="section-title"
                         Text="{Binding SelectionHeadline}" />
              <Border Classes="panel-soft">
                <TextBlock Classes="micro-label"
                           Text="{Binding SelectedLayerStateLabel}"
                           TextWrapping="Wrap" />
              </Border>

              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditCanvasProperties}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Canvas" />
                  <TextBlock Classes="section-title"
                             Text="Scene size and surface" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding CanvasSceneSummary}"
                             TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Width" />
                      <TextBox Text="{Binding CanvasWidth, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Height" />
                      <TextBox Text="{Binding CanvasHeight, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Duration" />
                      <TextBox Text="{Binding Duration, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Frame rate" />
                      <TextBox Text="{Binding SceneFrameRate, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <UniformGrid Columns="4"
                               Rows="1">
                    <Button Content="HD"
                            Command="{Binding ApplyCanvasPresetCommand}"
                            CommandParameter="hd" />
                    <Button Content="FHD"
                            Command="{Binding ApplyCanvasPresetCommand}"
                            CommandParameter="fhd" />
                    <Button Content="Square"
                            Command="{Binding ApplyCanvasPresetCommand}"
                            CommandParameter="square" />
                    <Button Content="Story"
                            Command="{Binding ApplyCanvasPresetCommand}"
                            CommandParameter="story" />
                  </UniformGrid>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Background from" />
                      <TextBox Text="{Binding BackgroundFrom, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Background to" />
                      <TextBox Text="{Binding BackgroundTo, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Classes="micro-label"
                             Text="{Binding CanvasBackgroundSummary}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="panel-soft"
                      IsVisible="{Binding SelectedLayerIsSymbolInstance}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Symbol Instance" />
                  <StackPanel Spacing="6"
                              IsEnabled="{Binding CanEditSelectedLayerInstanceMetadata}">
                    <TextBlock Classes="micro-label"
                               Text="Instance name" />
                    <TextBox Text="{Binding InstanceNameEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Playback mode" />
                    <ComboBox ItemsSource="{Binding AvailableSymbolPlaybackModes}"
                              SelectedItem="{Binding SymbolPlaybackModeEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Time offset" />
                      <TextBox Text="{Binding SymbolPlaybackOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Locked frame" />
                      <TextBox Text="{Binding SymbolLockedFrameEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6"
                              IsVisible="{Binding SelectedSymbolInstanceIsButton}">
                    <TextBlock Classes="micro-label"
                               Text="Button preview state" />
                    <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                              SelectedItem="{Binding SymbolButtonStateEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Spacing="6"
                              IsVisible="{Binding CanEditBitmapCacheMetadata}">
                    <CheckBox Content="Cache as bitmap"
                              IsChecked="{Binding LayerCacheAsBitmapEditor, Mode=TwoWay}" />
                    <StackPanel Spacing="6"
                                IsVisible="{Binding LayerCacheAsBitmapEditor}">
                      <TextBlock Classes="micro-label"
                                 Text="Cache background" />
                      <TextBox Text="{Binding LayerBitmapCacheBackgroundEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>

              <StackPanel Spacing="10"
                          IsEnabled="{Binding CanEditSelection}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Name" />
                  <TextBox Text="{Binding LayerNameEditor, Mode=TwoWay}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="X" />
                    <TextBox Text="{Binding InspectorX, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Y" />
                    <TextBox Text="{Binding InspectorY, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Width" />
                    <TextBox Text="{Binding InspectorWidth, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1"
                              Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Height" />
                    <TextBox Text="{Binding InspectorHeight, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="2"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Scale X" />
                    <TextBox Text="{Binding InspectorScaleX, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="2"
                              Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Scale Y" />
                    <TextBox Text="{Binding InspectorScaleY, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="3"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Skew X" />
                    <TextBox Text="{Binding InspectorSkewX, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="3"
                              Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Skew Y" />
                    <TextBox Text="{Binding InspectorSkewY, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="4"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Rotation" />
                    <TextBox Text="{Binding InspectorRotation, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="4"
                              Grid.Column="1"
                              Spacing="6"
                              IsVisible="{Binding SelectedLayerSupportsCornerRadius}">
                    <TextBlock Classes="micro-label"
                               Text="Corner radius" />
                    <TextBox Text="{Binding InspectorCornerRadius, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">
                    <TextBlock Classes="micro-label"
                               Text="Opacity" />
                    <TextBlock Grid.Column="1"
                               Classes="micro-label"
                               Text="{Binding InspectorOpacity, StringFormat='{}{0:0.00}'}" />
                  </Grid>
                  <Slider Minimum="0"
                          Maximum="1"
                          Value="{Binding InspectorOpacity, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="8"
                            IsEnabled="{Binding CanAlignSelection}">
                  <TextBlock Classes="micro-label"
                             Text="Align to stage" />
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8"
                        RowDefinitions="Auto,Auto">
                    <Button Content="Left"
                            Command="{Binding AlignLeftCommand}" />
                    <Button Grid.Column="1"
                            Content="Center"
                            Command="{Binding AlignCenterCommand}" />
                    <Button Grid.Column="2"
                            Content="Right"
                            Command="{Binding AlignRightCommand}" />
                    <Button Grid.Row="1"
                            Content="Top"
                            Command="{Binding AlignTopCommand}" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Content="Middle"
                            Command="{Binding AlignMiddleCommand}" />
                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Content="Bottom"
                            Command="{Binding AlignBottomCommand}" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanToggleLayerState}">
              <TextBlock Classes="eyebrow"
                         Text="Hierarchy" />
              <TextBlock Classes="section-title"
                         Text="Folders and power editing" />
              <TextBlock Classes="micro-label"
                         Text="{Binding LayerHierarchySummary}"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <Button Content="+ Folder"
                        Command="{Binding AddFolderCommand}"
                        IsEnabled="{Binding CanCreateFolder}" />
                <Button Grid.Column="1"
                        Content="Group"
                        Command="{Binding GroupSelectionIntoFolderCommand}"
                        IsEnabled="{Binding CanGroupSelectionIntoFolder}" />
              </Grid>
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <Button Content="Move To Root"
                        Command="{Binding RemoveSelectionFromFolderCommand}"
                        IsEnabled="{Binding CanRemoveSelectionFromFolder}" />
                <Button Grid.Column="1"
                        Content="{Binding SelectedLayerExpandLabel}"
                        Command="{Binding ToggleSelectedFolderExpandedCommand}"
                        IsEnabled="{Binding CanToggleSelectedFolderExpanded}" />
              </Grid>
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <Button Content="{Binding SelectedLayerMuteLabel}"
                        Command="{Binding ToggleSelectedLayerMuteCommand}" />
                <Button Grid.Column="1"
                        Content="{Binding SelectedLayerSoloLabel}"
                        Command="{Binding ToggleSelectedLayerSoloCommand}" />
              </Grid>
              <Border Classes="panel-soft">
                <StackPanel Spacing="6">
                  <TextBlock Classes="eyebrow"
                             Text="Power editing" />
                  <CheckBox Content="Edit multiple frames"
                            IsChecked="{Binding EditMultipleFramesEnabled, Mode=TwoWay}" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding EditMultipleFramesSummary}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Classes="panel-soft"
                      IsVisible="{Binding CanEditGuideBinding}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Guide binding" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding GuideBindingSummary}"
                             TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Guide layer" />
                      <ComboBox ItemsSource="{Binding AvailableGuideLayers}"
                                SelectedItem="{Binding SelectedGuideLayer, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:LayerViewModel">
                            <TextBlock Text="{Binding Name}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Content="Clear"
                            Command="{Binding ClearGuideBindingCommand}"
                            IsEnabled="{Binding HasGuideBinding}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <CheckBox Content="Orient to path"
                              IsChecked="{Binding GuideOrientToPathEditor, Mode=TwoWay}" />
                    <CheckBox Grid.Column="1"
                              Content="Snap to guide"
                              IsChecked="{Binding GuideSnapToPathEditor, Mode=TwoWay}" />
                  </Grid>
                </StackPanel>
              </Border>
              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditSelection}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Authoring metadata" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding LayerAuthoringSummary}"
                             TextWrapping="Wrap" />
                  <CheckBox Content="Show as outline"
                            IsChecked="{Binding LayerOutlineEditor, Mode=TwoWay}" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Outline color" />
                    <TextBox Text="{Binding LayerOutlineColorEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditStyleSurface}">
              <TextBlock Classes="eyebrow"
                         Text="Style" />
              <TextBlock Classes="section-title"
                         Text="Look and content" />

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Fill" />
                <TextBox Text="{Binding FillHexEditor, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Stroke" />
                <TextBox Text="{Binding StrokeHexEditor, Mode=TwoWay}" />
              </StackPanel>

              <UniformGrid Columns="4"
                           Rows="2">
                <Button Background="#24E5C1"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#24E5C1" />
                <Button Background="#FF8A4C"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#FF8A4C" />
                <Button Background="#F7F5ED"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#F7F5ED" />
                <Button Background="#6D8DFF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#6D8DFF" />
                <Button Background="#FF5F79"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#FF5F79" />
                <Button Background="#A7FF5A"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#A7FF5A" />
                <Button Background="#61E6FF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#61E6FF" />
                <Button Background="#B093FF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#B093FF" />
              </UniformGrid>

              <UniformGrid Columns="4"
                           Rows="2">
                <Button Background="#FFFFFF"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFFFFF" />
                <Button Background="#FFE6D1"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFE6D1" />
                <Button Background="#93A6D8"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#93A6D8" />
                <Button Background="#9BFFF0"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#9BFFF0" />
                <Button Background="#FFD166"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFD166" />
                <Button Background="#FF5F79"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FF5F79" />
                <Button Background="#61E6FF"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#61E6FF" />
                <Button Background="#A7FF5A"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#A7FF5A" />
              </UniformGrid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Fill and stroke" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <CheckBox Content="Fill"
                              IsChecked="{Binding FillEnabledEditor, Mode=TwoWay}" />
                    <CheckBox Grid.Column="1"
                              Content="Stroke"
                              IsChecked="{Binding StrokeEnabledEditor, Mode=TwoWay}" />
                  </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Stroke width" />
                  <TextBox Text="{Binding StrokeThicknessEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Stroke cap" />
                  <ComboBox ItemsSource="{Binding AvailableStrokeCapStyles}"
                            SelectedItem="{Binding StrokeCapStyleEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Stroke join" />
                  <ComboBox ItemsSource="{Binding AvailableStrokeJoinStyles}"
                            SelectedItem="{Binding StrokeJoinStyleEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6"
                          IsVisible="{Binding SelectedLayerUsesMiterJoin}">
                <TextBlock Classes="micro-label"
                           Text="Stroke miter limit" />
                <TextBox Text="{Binding StrokeMiterLimitEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,Auto,*"
                    ColumnSpacing="10"
                    IsVisible="{Binding FillEnabledEditor}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient fill" />
                  <CheckBox Content="Use gradient"
                            IsChecked="{Binding UseGradientEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6"
                            IsVisible="{Binding UseGradientEditor}">
                  <TextBlock Classes="micro-label"
                             Text="Kind" />
                  <ComboBox Width="120"
                            ItemsSource="{Binding AvailableGradientKinds}"
                            SelectedItem="{Binding GradientKindEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Spacing="6"
                            IsVisible="{Binding UseGradientEditor}">
                  <TextBlock Classes="micro-label"
                             Text="Angle" />
                  <TextBox Text="{Binding GradientAngleEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10"
                    IsVisible="{Binding UseGradientEditor}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient from" />
                  <TextBox Text="{Binding GradientFromEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient to" />
                  <TextBox Text="{Binding GradientToEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6"
                          IsVisible="{Binding SelectedLayerIsPath}">
                <CheckBox Content="Close path"
                          IsChecked="{Binding PathClosedEditor, Mode=TwoWay}" />
                <TextBlock Classes="micro-label"
                           IsVisible="{Binding CanEditPathPoints}"
                           Text="Drag vector points directly on the stage to reshape the selected path." />
              </StackPanel>

              <StackPanel IsVisible="{Binding SelectedLayerIsText}"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Text" />
                <TextBox Text="{Binding TextEditor, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="92"
                         TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Font size" />
                    <TextBox Text="{Binding InspectorFontSize, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Font family" />
                    <TextBox Text="{Binding TextFontFamilyEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <CheckBox Content="Bold"
                            IsChecked="{Binding TextBoldEditor, Mode=TwoWay}" />
                  <CheckBox Grid.Column="1"
                            Content="Italic"
                            IsChecked="{Binding TextItalicEditor, Mode=TwoWay}" />
                </Grid>
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Alignment" />
                  <ComboBox ItemsSource="{Binding AvailableTextAlignments}"
                            SelectedItem="{Binding TextAlignmentEditor, Mode=TwoWay}" />
                </StackPanel>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Field kind" />
                    <ComboBox ItemsSource="{Binding AvailableTextFieldKinds}"
                              SelectedItem="{Binding TextFieldKindEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Line mode" />
                    <ComboBox ItemsSource="{Binding AvailableTextLineModes}"
                              SelectedItem="{Binding TextLineModeEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Letter spacing" />
                    <TextBox Text="{Binding TextLetterSpacingEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Line height" />
                    <TextBox Text="{Binding TextLineHeightEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <TextBlock Classes="micro-label"
                           Text="{Binding SelectedTextFieldSummary}"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      IsVisible="{Binding SelectedTextUsesInteractiveFieldMetadata}">
                  <CheckBox Content="Selectable"
                            IsChecked="{Binding TextSelectableEditor, Mode=TwoWay}" />
                  <CheckBox Grid.Column="1"
                            Content="Show border"
                            IsChecked="{Binding TextShowBorderEditor, Mode=TwoWay}" />
                </Grid>
                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedTextUsesVariableName}">
                  <TextBlock Classes="micro-label"
                             Text="Variable name" />
                  <TextBox Text="{Binding TextVariableNameEditor, Mode=TwoWay}" />
                </StackPanel>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Max characters" />
                    <TextBox Text="{Binding TextMaxCharactersEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Anti-alias" />
                    <ComboBox ItemsSource="{Binding AvailableTextAntiAliasModes}"
                              SelectedItem="{Binding TextAntiAliasModeEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <CheckBox Content="Password field"
                            IsChecked="{Binding TextPasswordEditor, Mode=TwoWay}" />
                  <CheckBox Grid.Column="1"
                            Content="Use device fonts"
                            IsChecked="{Binding TextUseDeviceFontsEditor, Mode=TwoWay}" />
                </Grid>
                <CheckBox Content="Render as HTML text"
                          IsChecked="{Binding TextRenderAsHtmlEditor, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel IsVisible="{Binding SelectedLayerIsAvaloniaControl}"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Avalonia control content" />
                <TextBox Text="{Binding AvaloniaControlContentEditor, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="72"
                         TextWrapping="Wrap" />
                <TextBlock Classes="micro-label"
                           Text="Secondary content" />
                <TextBox Text="{Binding AvaloniaControlSecondaryContentEditor, Mode=TwoWay}" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <CheckBox Content="Checked"
                            IsChecked="{Binding AvaloniaControlIsCheckedEditor, Mode=TwoWay}" />
                  <CheckBox Grid.Column="1"
                            Content="Indeterminate"
                            IsChecked="{Binding AvaloniaControlIsIndeterminateEditor, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Minimum" />
                    <TextBox Text="{Binding AvaloniaControlMinimumEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Maximum" />
                    <TextBox Text="{Binding AvaloniaControlMaximumEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Value" />
                  <TextBox Text="{Binding AvaloniaControlValueEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Image source" />
                  <TextBox Text="{Binding AvaloniaControlSourceEditor, Mode=TwoWay}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditSelection}">
              <TextBlock Classes="eyebrow"
                         Text="Compositing" />
              <TextBlock Classes="section-title"
                         Text="Masks, blends, effects" />
              <TextBlock Classes="micro-label"
                         Text="{Binding CompositingSummary}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Layer role" />
                  <ComboBox ItemsSource="{Binding AvailableCompositeRoles}"
                            SelectedItem="{Binding LayerRoleEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Blend mode" />
                  <ComboBox ItemsSource="{Binding AvailableBlendModes}"
                            SelectedItem="{Binding LayerBlendModeEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6"
                          IsVisible="{Binding SelectedLayerIsMask}">
                <TextBlock Classes="micro-label"
                           Text="Mask target count" />
                <TextBox Text="{Binding MaskLayerCountEditor, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Parallax depth" />
                <TextBox Text="{Binding LayerParallaxDepthEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Blur radius" />
                  <TextBox Text="{Binding LayerBlurEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Brightness" />
                  <TextBox Text="{Binding LayerBrightnessEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Tint color" />
                  <TextBox Text="{Binding LayerTintColorEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Tint strength" />
                  <TextBox Text="{Binding LayerTintStrengthEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Border Classes="panel-soft">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Flash color effect" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding FlashColorEffectSummary}"
                             TextWrapping="Wrap" />

                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Mode" />
                    <ComboBox ItemsSource="{Binding AvailableFlashColorEffectModes}"
                              SelectedItem="{Binding LayerFlashColorEffectModeEditor, Mode=TwoWay}" />
                  </StackPanel>

                  <StackPanel Spacing="6"
                              IsVisible="{Binding SelectedLayerUsesFlashAlphaEffect}">
                    <TextBlock Classes="micro-label"
                               Text="Alpha percent" />
                    <TextBox Text="{Binding LayerFlashAlphaPercentEditor, Mode=TwoWay}" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        IsVisible="{Binding SelectedLayerUsesFlashTintEffect}">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Tint color" />
                      <TextBox Text="{Binding LayerFlashTintColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Tint percent" />
                      <TextBox Text="{Binding LayerFlashTintPercentEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>

                  <StackPanel Spacing="6"
                              IsVisible="{Binding SelectedLayerUsesFlashBrightnessEffect}">
                    <TextBlock Classes="micro-label"
                               Text="Brightness percent" />
                    <TextBox Text="{Binding LayerFlashBrightnessPercentEditor, Mode=TwoWay}" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        IsVisible="{Binding SelectedLayerUsesFlashAdvancedColorEffect}">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Red percent" />
                      <TextBox Text="{Binding LayerFlashRedPercentEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Red offset" />
                      <TextBox Text="{Binding LayerFlashRedOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Green percent" />
                      <TextBox Text="{Binding LayerFlashGreenPercentEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Green offset" />
                      <TextBox Text="{Binding LayerFlashGreenOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Blue percent" />
                      <TextBox Text="{Binding LayerFlashBluePercentEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Blue offset" />
                      <TextBox Text="{Binding LayerFlashBlueOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="3"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Alpha percent" />
                      <TextBox Text="{Binding LayerFlashAdvancedAlphaPercentEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="3"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Alpha offset" />
                      <TextBox Text="{Binding LayerFlashAlphaOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Classes="micro-label"
                             Text="Saturation" />
                  <TextBlock Grid.Column="1"
                             Classes="micro-label"
                             Text="{Binding LayerSaturationEditor, StringFormat='{}{0:0.00}'}" />
                </Grid>
                <Slider Minimum="0"
                        Maximum="2"
                        Value="{Binding LayerSaturationEditor, Mode=TwoWay}" />
              </StackPanel>

              <Border Classes="panel-soft">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Glow" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Color" />
                      <TextBox Text="{Binding LayerGlowColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Size" />
                      <TextBox Text="{Binding LayerGlowSizeEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBlock Classes="micro-label"
                                 Text="Opacity" />
                      <TextBlock Grid.Column="1"
                                 Classes="micro-label"
                                 Text="{Binding LayerGlowOpacityEditor, StringFormat='{}{0:0.00}'}" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding LayerGlowOpacityEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="panel-soft">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Shadow" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Color" />
                      <TextBox Text="{Binding LayerShadowColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Blur" />
                      <TextBox Text="{Binding LayerShadowBlurEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Offset X" />
                      <TextBox Text="{Binding LayerShadowOffsetXEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Offset Y" />
                      <TextBox Text="{Binding LayerShadowOffsetYEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBlock Classes="micro-label"
                                 Text="Opacity" />
                      <TextBlock Grid.Column="1"
                                 Classes="micro-label"
                                 Text="{Binding LayerShadowOpacityEditor, StringFormat='{}{0:0.00}'}" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding LayerShadowOpacityEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditSelection}"
                        IsVisible="{Binding SelectedLayerIsMedia}">
              <TextBlock Classes="eyebrow"
                         Text="Media" />
              <TextBlock Classes="section-title"
                         Text="Clip timing and playback" />
              <TextBlock Classes="micro-label"
                         Text="{Binding MediaLayerSummary}"
                         TextWrapping="Wrap" />

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Playback mode" />
                <ComboBox ItemsSource="{Binding AvailableMediaPlaybackModes}"
                          SelectedItem="{Binding MediaPlaybackModeEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Start time" />
                  <TextBox Text="{Binding MediaStartTimeEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Clip offset" />
                  <TextBox Text="{Binding MediaClipOffsetEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Clip duration" />
                  <TextBox Text="{Binding MediaClipDurationEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Looping" />
                  <CheckBox Content="Loop clip"
                            IsChecked="{Binding MediaLoopEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Classes="micro-label"
                             Text="Volume" />
                  <TextBlock Grid.Column="1"
                             Classes="micro-label"
                             Text="{Binding MediaVolumeEditor, StringFormat='{}{0:0.00}'}" />
                </Grid>
                <Slider Minimum="0"
                        Maximum="1"
                        Value="{Binding MediaVolumeEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gain dB" />
                  <TextBox Text="{Binding MediaGainDbEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Pan" />
                  <TextBox Text="{Binding MediaPanEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Fade in" />
                  <TextBox Text="{Binding MediaFadeInEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Fade out" />
                  <TextBox Text="{Binding MediaFadeOutEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Border Classes="panel-soft">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Audio finishing" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding MediaAudioSummary}"
                             TextWrapping="Wrap" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding AudioMeterSummary}"
                             TextWrapping="Wrap"
                             IsVisible="{Binding SelectedLayerIsAudio}" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        IsVisible="{Binding SelectedLayerIsAudio}">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="micro-label"
                                 Text="Peak" />
                      <ProgressBar Minimum="0"
                                   Maximum="1"
                                   Value="{Binding AudioMeterPeak, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Classes="micro-label"
                                 Text="RMS" />
                      <ProgressBar Minimum="0"
                                   Maximum="1"
                                   Value="{Binding AudioMeterRms, Mode=OneWay}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="panel-soft">
                <StackPanel Spacing="8"
                            IsEnabled="{Binding CanUseEditorialTools}">
                  <TextBlock Classes="eyebrow"
                             Text="Editorial" />
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <Button Content="Razor"
                            Command="{Binding RazorSelectionCommand}" />
                    <Button Grid.Column="1"
                            Content="Slip -"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="slip-back" />
                    <Button Grid.Column="2"
                            Content="Slip +"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="slip-forward" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*,*,*"
                        ColumnSpacing="8">
                    <Button Content="Slide -"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="slide-back" />
                    <Button Grid.Column="1"
                            Content="Slide +"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="slide-forward" />
                    <Button Grid.Column="2"
                            Content="Ripple -"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="ripple-shorter" />
                    <Button Grid.Column="3"
                            Content="Ripple +"
                            Command="{Binding ApplyEditorialOperationCommand}"
                            CommandParameter="ripple-longer" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Motion + Actions">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">

          <Border Classes="panel">
            <StackPanel Spacing="8"
                        IsEnabled="{Binding CanEditSceneMarkers}">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Editorial" />
                  <TextBlock Classes="section-title"
                             Text="Markers, ranges, and transitions" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Save Marker"
                        Command="{Binding AddOrUpdateSceneMarkerCommand}" />
                <Button Grid.Column="2"
                        Content="Remove"
                        Classes="warm"
                        Command="{Binding RemoveSelectedSceneMarkerCommand}"
                        IsEnabled="{Binding CanRemoveSelectedSceneMarker}" />
              </Grid>

              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedSceneMarkerSummary}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="140,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Marker kind" />
                  <ComboBox ItemsSource="{Binding AvailableSceneMarkerKinds}"
                            SelectedItem="{Binding SelectedMarkerKind, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Marker name" />
                  <TextBox Text="{Binding MarkerNameEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,140"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Notes" />
                  <TextBox Text="{Binding MarkerNotesEditor, Mode=TwoWay}"
                           AcceptsReturn="True"
                           Height="76"
                           TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Color" />
                  <TextBox Text="{Binding MarkerColorEditor, Mode=TwoWay}" />
                  <Border Classes="panel-soft"
                          Padding="8,6">
                    <TextBlock Classes="micro-label"
                               Text="{Binding CurrentSceneWorkAreaLabel}" />
                  </Border>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">
                <Button Content="Set In"
                        Command="{Binding SetSceneInPointCommand}" />
                <Button Grid.Column="1"
                        Content="Set Out"
                        Command="{Binding SetSceneOutPointCommand}" />
                <Button Grid.Column="2"
                        Content="Set Work"
                        Command="{Binding SetSceneWorkAreaFromSelectionCommand}"
                        IsEnabled="{Binding CanSetSceneWorkArea}" />
              </Grid>

              <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">
                <Button Content="Jump In"
                        Command="{Binding JumpToSceneInPointCommand}" />
                <Button Grid.Column="1"
                        Content="Jump Out"
                        Command="{Binding JumpToSceneOutPointCommand}" />
                <Button Grid.Column="2"
                        Content="Clear Work"
                        Command="{Binding ClearSceneWorkAreaCommand}" />
              </Grid>

              <CheckBox Content="Use work area for playback"
                        IsChecked="{Binding UseWorkAreaPlayback, Mode=TwoWay}" />

              <Border Classes="panel-soft">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Scene transition" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding SceneTransitionSummary}"
                             TextWrapping="Wrap" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Transition kind" />
                    <ComboBox ItemsSource="{Binding AvailableSceneTransitionKinds}"
                              SelectedItem="{Binding SceneTransitionKindEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Duration (s)" />
                      <TextBox Text="{Binding SceneTransitionDurationEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Accent color" />
                      <TextBox Text="{Binding SceneTransitionAccentColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Behaviors" />
                  <TextBlock Classes="section-title"
                             Text="Events and lightweight actions" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="+ Event"
                        Command="{Binding AddBehaviorCommand}"
                        IsEnabled="{Binding CanAddBehavior}" />
                <Button Grid.Column="2"
                        Content="Remove"
                        Classes="warm"
                        Command="{Binding DeleteSelectedBehaviorCommand}"
                        IsEnabled="{Binding CanDeleteSelectedBehavior}" />
              </Grid>

              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedBehaviorSummary}"
                         TextWrapping="Wrap" />

              <ListBox ItemsSource="{Binding Behaviors}"
                       SelectedItem="{Binding SelectedBehavior, Mode=TwoWay}"
                       MinHeight="120">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:InteractionBehaviorViewModel">
                    <Border Classes="layer-row">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="strong-label"
                                   Text="{Binding Name}" />
                        <TextBlock Classes="micro-label"
                                   Text="{Binding Summary}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Spacing="8"
                          IsEnabled="{Binding CanEditBehaviors}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Behavior name" />
                  <TextBox Text="{Binding SelectedBehaviorNameEditor, Mode=TwoWay}" />
                </StackPanel>

                <CheckBox Content="Enabled"
                          IsChecked="{Binding SelectedBehaviorEnabledEditor, Mode=TwoWay}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Trigger" />
                    <ComboBox ItemsSource="{Binding AvailableInteractionTriggers}"
                              SelectedItem="{Binding SelectedBehaviorTriggerEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6"
                              IsVisible="{Binding SelectedBehaviorUsesTriggerArgument}">
                    <TextBlock Classes="micro-label"
                               Text="Frame label" />
                    <TextBox Text="{Binding SelectedBehaviorTriggerArgumentEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Action" />
                  <ComboBox ItemsSource="{Binding AvailableInteractionActions}"
                            SelectedItem="{Binding SelectedBehaviorActionEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetScene}">
                  <TextBlock Classes="micro-label"
                             Text="Target scene" />
                  <ComboBox ItemsSource="{Binding Scenes}"
                            SelectedItem="{Binding SelectedBehaviorTargetScene, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:SceneViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetFrameLabel}">
                  <TextBlock Classes="micro-label"
                             Text="Target frame label" />
                  <TextBox Text="{Binding SelectedBehaviorTargetFrameLabelEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetLayer}">
                  <TextBlock Classes="micro-label"
                             Text="Target layer" />
                  <ComboBox ItemsSource="{Binding Layers}"
                            SelectedItem="{Binding SelectedBehaviorTargetLayer, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:LayerViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesButtonState}">
                  <TextBlock Classes="micro-label"
                             Text="Button state" />
                  <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                            SelectedItem="{Binding SelectedBehaviorTargetButtonStateEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesBoolValue}">
                  <CheckBox Content="Show target layer"
                            IsChecked="{Binding SelectedBehaviorBoolValueEditor, Mode=TwoWay}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      IsVisible="{Binding SelectedBehaviorUsesVariable}">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Variable" />
                    <TextBox Text="{Binding SelectedBehaviorVariableNameEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                              Text="Value" />
                    <TextBox Text="{Binding SelectedBehaviorVariableValueEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      IsVisible="{Binding SelectedBehaviorUsesVisualState}">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="State group" />
                    <ComboBox ItemsSource="{Binding AvailableBehaviorVisualStateGroups}"
                              SelectedItem="{Binding SelectedBehaviorTargetVisualStateGroupEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="State" />
                    <ComboBox ItemsSource="{Binding AvailableBehaviorVisualStates}"
                              SelectedItem="{Binding SelectedBehaviorTargetVisualStateEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10">
              <TextBlock Classes="eyebrow"
                         Text="Actions" />
              <TextBlock Classes="section-title"
                         Text="Frame scripts and behavior code" />

              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditCurrentFrameActionScript}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Current frame action" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding CurrentFrameActionSummary}"
                             TextWrapping="Wrap" />
                  <TextBox Text="{Binding FrameActionScriptEditor, Mode=TwoWay}"
                           AcceptsReturn="True"
                           Height="132"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditSelectedBehaviorScript}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Selected behavior script" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding SelectedBehaviorScriptSummary}"
                             TextWrapping="Wrap" />
                  <TextBox Text="{Binding SelectedBehaviorScriptEditor, Mode=TwoWay}"
                           AcceptsReturn="True"
                           Height="148"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="panel-soft">
                <StackPanel Spacing="6">
                  <TextBlock Classes="eyebrow"
                             Text="Command set" />
                  <TextBlock Classes="micro-label"
                             Text='play, stop, goto_scene "Scene", goto_label "Label", goto_frame 24, show "Layer", hide "Layer", set_var score 10, set_text "Layer" "HELLO", set_button "Layer" Over, trace "message"'
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="8"
                        IsEnabled="{Binding CanEditVisualStates}">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Visual States" />
                  <TextBlock Classes="section-title"
                             Text="Blend-style state authoring" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Capture"
                        Command="{Binding CaptureVisualStateCommand}" />
                <Button Grid.Column="2"
                        Content="Apply"
                        Classes="accent"
                        Command="{Binding ApplySelectedVisualStateCommand}"
                        IsEnabled="{Binding CanApplySelectedVisualState}" />
              </Grid>

              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedVisualStateSummary}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="State group" />
                  <TextBox Text="{Binding VisualStateGroupNameEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="State name" />
                  <TextBox Text="{Binding VisualStateNameEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <ListBox ItemsSource="{Binding VisualStateGroups}"
                         SelectedItem="{Binding SelectedVisualStateGroup, Mode=TwoWay}"
                         MinHeight="110">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VisualStateGroupViewModel">
                      <Border Classes="layer-row">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="strong-label"
                                     Text="{Binding Name}" />
                          <TextBlock Classes="micro-label"
                                     Text="{Binding Subtitle}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <ListBox Grid.Column="1"
                         ItemsSource="{Binding VisualStates}"
                         SelectedItem="{Binding SelectedVisualState, Mode=TwoWay}"
                         MinHeight="110">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VisualStateViewModel">
                      <Border Classes="layer-row">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="strong-label"
                                     Text="{Binding Name}" />
                          <TextBlock Classes="micro-label"
                                     Text="{Binding Subtitle}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="8">
                <Button Content="Remove State"
                        Classes="warm"
                        Command="{Binding DeleteSelectedVisualStateCommand}"
                        IsEnabled="{Binding CanRemoveSelectedVisualState}" />
                <Button Grid.Column="1"
                        Content="Remove Group"
                        Classes="warm"
                        Command="{Binding DeleteSelectedVisualStateGroupCommand}"
                        IsEnabled="{Binding CanRemoveSelectedVisualStateGroup}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="8">
              <TextBlock Classes="eyebrow"
                         Text="Animation" />
              <TextBlock Classes="section-title"
                         Text="Track focus" />
              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedKeyframeSummary}"
                         TextWrapping="Wrap" />
              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Selected keyframe easing" />
                <ComboBox ItemsSource="{Binding AvailableEasings}"
                          SelectedItem="{Binding SelectedKeyframeEasing, Mode=TwoWay}"
                          IsEnabled="{Binding CanDeleteSelectedKeyframe}" />
              </StackPanel>
              <Border Classes="panel-soft"
                      IsVisible="{Binding HasSelectedCustomEasing}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Custom Curve" />
                  <controls:EasingCurveEditorControl Height="220"
                                                    ControlPoint1X="{Binding CustomEaseControl1X, Mode=TwoWay}"
                                                    ControlPoint1Y="{Binding CustomEaseControl1Y, Mode=TwoWay}"
                                                    ControlPoint2X="{Binding CustomEaseControl2X, Mode=TwoWay}"
                                                    ControlPoint2Y="{Binding CustomEaseControl2Y, Mode=TwoWay}"
                                                    IsEnabled="{Binding CanEditCustomEasingCurve}" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle A X" />
                      <TextBox Text="{Binding CustomEaseControl1X, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle A Y" />
                      <TextBox Text="{Binding CustomEaseControl1Y, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle B X" />
                      <TextBox Text="{Binding CustomEaseControl2X, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle B Y" />
                      <TextBox Text="{Binding CustomEaseControl2Y, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
              <Border Classes="panel-soft"
                      IsVisible="{Binding SelectedLayerIsPath}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Shape Tween" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding ShapeTweenSummary}"
                             TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <Button Content="Capture Morph Key"
                            Command="{Binding CaptureShapeKeyframeCommand}"
                            IsEnabled="{Binding CanCaptureShapeKeyframe}" />
                    <Button Grid.Column="1"
                            Content="Delete Morph Key"
                            Classes="warm"
                            Command="{Binding DeleteCurrentShapeKeyframeCommand}"
                            IsEnabled="{Binding CanDeleteCurrentShapeKeyframe}" />
                  </Grid>
                </StackPanel>
              </Border>
              <Border Classes="panel-soft">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Editing model" />
                  <TextBlock Classes="micro-label"
                             Text="Canvas edits and inspector changes update the current playhead. Away from zero or with auto-key enabled, the editor writes keyframes automatically."
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Classes="micro-label"
                         Text="Selecting a layer on the stage now reveals its motion path and animated waypoints directly on the canvas."
                         TextWrapping="Wrap" />
              <TextBlock Classes="micro-label"
                         Text="Sequence rendering exports 30 fps PNG frames to the selected folder."
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</Window>
