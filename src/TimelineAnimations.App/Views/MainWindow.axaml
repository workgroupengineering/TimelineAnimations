<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:TimelineAnimations.App.Controls"
        xmlns:models="using:TimelineAnimations.Core.Models"
        xmlns:vm="using:TimelineAnimations.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1560"
        d:DesignHeight="940"
        x:Class="TimelineAnimations.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1560"
        Height="940"
        MinWidth="1240"
        MinHeight="760"
        UseLayoutRounding="True"
        Title="TimelineAnimations Studio">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+1"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="classic" />
    <KeyBinding Gesture="Ctrl+2"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="stage" />
    <KeyBinding Gesture="Ctrl+3"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="timeline" />
    <KeyBinding Gesture="Ctrl+4"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="tools" />
    <KeyBinding Gesture="Ctrl+5"
                Command="{Binding FocusWorkspaceAreaCommand}"
                CommandParameter="inspector" />
    <KeyBinding Gesture="Ctrl+Shift+1"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="left" />
    <KeyBinding Gesture="Ctrl+Shift+2"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="right" />
    <KeyBinding Gesture="Ctrl+Shift+3"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="timeline" />
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid Margin="6"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="3">
    <Border Grid.Row="0"
            Classes="chrome">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Classes="title"
                     Text="TimelineAnimations MX" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <TextBlock Classes="menu-label" Text="File" />
          <TextBlock Classes="menu-label" Text="Edit" />
          <TextBlock Classes="menu-label" Text="View" />
          <TextBlock Classes="menu-label" Text="Insert" />
          <TextBlock Classes="menu-label" Text="Modify" />
          <TextBlock Classes="menu-label" Text="Text" />
          <TextBlock Classes="menu-label" Text="Commands" />
          <TextBlock Classes="menu-label" Text="Control" />
          <TextBlock Classes="menu-label" Text="Window" />
          <TextBlock Classes="menu-label" Text="Help" />
        </StackPanel>

        <Border Grid.Column="2"
                Classes="workspace-tab active">
          <StackPanel Spacing="2">
            <TextBlock Classes="eyebrow"
                       Text="Document" />
            <TextBlock Classes="strong-label"
                       Text="{Binding DocumentName}" />
            <TextBlock Classes="micro-label"
                       Text="{Binding DocumentFileSummary}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="chrome-soft">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Border Classes="workspace-tab active">
            <TextBlock Classes="strong-label"
                       Text="Animate" />
          </Border>
          <Border Classes="workspace-tab">
            <TextBlock Classes="strong-label"
                       Text="Author" />
          </Border>
          <Border Classes="workspace-tab">
            <TextBlock Classes="strong-label"
                       Text="Library" />
          </Border>
          <Border Classes="workspace-tab">
            <TextBlock Classes="strong-label"
                       Text="Publish" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding WorkspaceShortcutSummary}">
          <StackPanel.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Restore Workspace"
                        Command="{Binding RestoreSavedWorkspaceLayoutCommand}" />
              <Separator />
              <MenuItem Header="Focus">
                <MenuItem Header="Classic"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="classic" />
                <MenuItem Header="Stage"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="stage" />
                <MenuItem Header="Timeline"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="timeline" />
                <MenuItem Header="Tools"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="tools" />
                <MenuItem Header="Inspector"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="inspector" />
              </MenuItem>
              <MenuItem Header="Panels">
                <MenuItem Header="{Binding LeftPanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="left" />
                <MenuItem Header="{Binding RightPanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="right" />
                <MenuItem Header="{Binding TimelinePanelToggleLabel}"
                          Command="{Binding ToggleWorkspacePanelCommand}"
                          CommandParameter="timeline" />
              </MenuItem>
            </ContextMenu>
          </StackPanel.ContextMenu>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Classes="micro-label"
                         VerticalAlignment="Center"
                         Text="Workspace" />
              <ComboBox Width="108"
                        ItemsSource="{Binding AvailableWorkspacePresets}"
                        SelectedItem="{Binding SelectedWorkspacePreset, Mode=TwoWay}" />
              <Button Classes="toolbar"
                      Content="Restore"
                      Command="{Binding RestoreSavedWorkspaceLayoutCommand}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Classes="micro-label"
                         VerticalAlignment="Center"
                         Text="Focus" />
              <ComboBox Width="98"
                        ItemsSource="{Binding AvailableWorkspaceFocusTargets}"
                        SelectedItem="{Binding SelectedWorkspaceFocusTarget, Mode=TwoWay}" />
              <Button Classes="toolbar"
                      Content="Apply"
                      Command="{Binding FocusWorkspaceAreaCommand}"
                      CommandParameter="{Binding SelectedWorkspaceFocusTarget}" />
            </StackPanel>
          </Border>
          <Border Classes="workspace-summary-chip"
                  ToolTip.Tip="{Binding WorkspaceLayoutSummary}">
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Context" />
              <TextBlock Classes="strong-label"
                         Text="{Binding WorkspaceSummary}"
                         TextTrimming="CharacterEllipsis" />
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="{Binding WorkspaceLayoutLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding DurationLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding FrameRateLabel}" />
                <TextBlock Classes="micro-label"
                           Text="{Binding CanvasSizeLabel}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Edit Symbol"
                      Command="{Binding EnterSelectedSymbolEditCommand}"
                      IsEnabled="{Binding CanEnterSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Exit Symbol"
                      Command="{Binding ExitSymbolEditCommand}"
                      IsEnabled="{Binding CanExitSymbolEdit}" />
              <Button Classes="toolbar warm"
                      Content="Prototype"
                      Command="{Binding TogglePrototypeModeCommand}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Undo"
                      Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" />
              <Button Classes="toolbar"
                      Content="Redo"
                      Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" />
              <Button Classes="toolbar"
                      Content="Sample"
                      Command="{Binding ResetSampleCommand}" />
            </StackPanel>
          </Border>
          <Border Classes="chrome-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar"
                      Content="Open"
                      Click="OpenDocumentClick" />
              <Button Classes="toolbar accent"
                      Content="Save"
                      Click="SaveDocumentClick" />
              <Button Classes="toolbar"
                      Content="Frame"
                      Click="ExportFrameClick" />
              <Button Classes="toolbar warm"
                      Content="Sequence"
                      Click="RenderSequenceClick" />
              <Button Classes="toolbar"
                      Content="Project"
                      Click="RenderProjectClick" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          ClipToBounds="False">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding LeftPanelColumnWidth}" MinWidth="0" />
        <ColumnDefinition Width="{Binding LeftSplitterColumnWidth}" />
        <ColumnDefinition Width="*" MinWidth="520" />
        <ColumnDefinition Width="{Binding RightSplitterColumnWidth}" />
        <ColumnDefinition Width="{Binding RightPanelColumnWidth}" MinWidth="0" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0"
            Grid.ColumnSpan="{Binding LeftPanelColumnSpan}"
            Width="{Binding LeftPanelHostWidth}"
            HorizontalAlignment="{Binding LeftPanelHorizontalAlignment}"
            Margin="{Binding LeftPanelHostMargin}"
            Panel.ZIndex="{Binding LeftPanelZIndex}"
            IsVisible="{Binding IsLeftPanelVisible}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" MinHeight="220" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="88" MinWidth="76" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="*" MinWidth="140" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Classes="panel">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                ColumnSpacing="4"
                ToolTip.Tip="Right click for dock actions">
            <Grid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Focus Tools"
                          Command="{Binding FocusWorkspaceAreaCommand}"
                          CommandParameter="tools" />
                <Separator />
                <MenuItem Header="Dock"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:dock" />
                <MenuItem Header="Overlay"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:over" />
                <MenuItem Header="Hide"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:hide" />
              </ContextMenu>
            </Grid.ContextMenu>
            <StackPanel Spacing="1">
              <TextBlock Classes="eyebrow"
                         Text="Authoring" />
              <TextBlock Classes="section-title"
                         Text="Tools + project" />
            </StackPanel>
            <ToggleButton Grid.Column="1"
                          Classes="toolbar"
                          Content="Dock"
                          IsChecked="{Binding IsLeftPanelDocked, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:dock" />
            <ToggleButton Grid.Column="2"
                          Classes="toolbar"
                          Content="Over"
                          IsChecked="{Binding IsLeftPanelOverlay, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:over" />
            <ToggleButton Grid.Column="3"
                          Classes="toolbar"
                          Content="Hide"
                          IsChecked="{Binding IsLeftPanelHidden, Mode=OneWay}"
                          Command="{Binding SetWorkspacePanelModeCommand}"
                          CommandParameter="left:hide" />
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Classes="panel">
          <Grid RowDefinitions="*,Auto"
                RowSpacing="6">
            <StackPanel Spacing="6">
              <Button Classes="tool-rail"
                      Content="Select"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Select" />
              <Button Classes="tool-rail"
                      Content="Rect"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Rectangle" />
              <Button Classes="tool-rail"
                      Content="Ellipse"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Ellipse" />
              <Button Classes="tool-rail"
                      Content="Text"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Text" />
              <Button Classes="tool-rail"
                      Content="Line"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Line" />
              <Button Classes="tool-rail"
                      Content="Pen"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Pen" />
              <Button Classes="tool-rail"
                      Content="Brush"
                      Command="{Binding SelectDrawingToolCommand}"
                      CommandParameter="Brush" />
              <Button Classes="tool-rail accent"
                      Content="Play"
                      Command="{Binding TogglePlaybackCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="panel-soft">
              <StackPanel Spacing="4">
                <TextBlock Classes="eyebrow"
                           Text="Active" />
                <TextBlock Classes="strong-label"
                           Text="{Binding ToolModeLabel}"
                           TextWrapping="Wrap" />
                <TextBlock Classes="micro-label"
                           Text="{Binding CurrentFrameLabel}" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Classes="panel-splitter vertical"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <TabControl Grid.Row="1"
                    Grid.Column="2"
                    Classes="dock-tabs">
          <TabItem Header="Project">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="8"
                              IsEnabled="{Binding CanEditScenes}">
                    <TextBlock Classes="eyebrow"
                               Text="Composition" />
                    <TextBlock Classes="section-title"
                               Text="{Binding DocumentName}" />
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Selected scene" />
                      <TextBox Text="{Binding SceneNameEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Frame rate" />
                      <TextBox Text="{Binding SceneFrameRate, Mode=TwoWay}" />
                    </StackPanel>
                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedSceneSummary}"
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*,*,*,*"
                          ColumnSpacing="8">
                      <Button Content="+ Scene"
                              Command="{Binding AddSceneCommand}" />
                      <Button Grid.Column="1"
                              Content="Copy"
                              Command="{Binding DuplicateSceneCommand}" />
                      <Button Grid.Column="2"
                              Content="Back"
                              Command="{Binding MoveSceneBackwardCommand}"
                              IsEnabled="{Binding CanMoveSceneBackward}" />
                      <Button Grid.Column="3"
                              Content="Next"
                              Command="{Binding MoveSceneForwardCommand}"
                              IsEnabled="{Binding CanMoveSceneForward}" />
                      <Button Grid.Column="4"
                              Content="Remove"
                              Classes="warm"
                              Command="{Binding DeleteSceneCommand}"
                              IsEnabled="{Binding CanDeleteScene}" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Scenes}"
                             SelectedItem="{Binding SelectedScene, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SceneViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="82,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="82"
                                      Height="46"
                                      CornerRadius="10"
                                      Background="{Binding PreviewBrush}">
                                <Border Margin="8"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Padding="8,4"
                                        Background="#44000000"
                                        CornerRadius="8">
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Name}" />
                                </Border>
                              </Border>
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="Scene" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Border Classes="panel-soft">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="eyebrow"
                                     Text="Duration" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding DurationLabel}" />
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1"
                              Classes="panel-soft">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="eyebrow"
                                     Text="Stage" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CanvasSizeLabel}" />
                        </StackPanel>
                      </Border>
                    </Grid>
                    <TextBlock Classes="micro-label"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Layers" />
                        <TextBlock Classes="section-title"
                                   Text="Composition stack" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="+ Rect"
                              Command="{Binding AddRectangleCommand}" />
                      <Button Grid.Column="2"
                              Content="+ Orb"
                              Classes="warm"
                              Command="{Binding AddEllipseCommand}" />
                      <Button Grid.Column="3"
                              Content="+ Text"
                              Command="{Binding AddTextCommand}" />
                      <Button Grid.Column="4"
                              Content="+ Camera"
                              Command="{Binding AddCameraLayerCommand}"
                              IsEnabled="{Binding CanAddCameraLayer}" />
                      <Button Grid.Column="5"
                              Content="Copy"
                              Command="{Binding DuplicateSelectionCommand}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding Layers}"
                             SelectedItem="{Binding SelectedLayer, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayerViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding FillBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           IsVisible="{Binding HasLibraryLink}"
                                           Text="{Binding LibraryLinkLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding StateBadge}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding KindLabel}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Content="Forward"
                              Command="{Binding BringForwardCommand}" />
                      <Button Grid.Column="1"
                              Content="Backward"
                              Command="{Binding SendBackwardCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Content="{Binding SelectedLayerVisibilityLabel}"
                              Command="{Binding ToggleSelectedLayerVisibilityCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                      <Button Grid.Column="1"
                              Content="{Binding SelectedLayerLockLabel}"
                              Command="{Binding ToggleSelectedLayerLockCommand}"
                              IsEnabled="{Binding CanToggleLayerState}" />
                    </Grid>

                    <Button Content="Delete Selection"
                            Classes="warm"
                            Command="{Binding DeleteSelectionCommand}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Assets">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow"
                               Text="Palette" />
                    <TextBlock Classes="section-title"
                               Text="Drop new elements onto the stage" />
                    <ItemsControl ItemsSource="{Binding PaletteItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemViewModel">
                          <controls:PaletteItemControl />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="eyebrow"
                               Text="Avalonia Toolbox" />
                    <TextBlock Classes="section-title"
                               Text="Controls, shapes, and visual hosts" />
                    <TextBlock Classes="micro-label"
                               Text="Drag native Avalonia controls onto the stage to compose animated UI states." />
                    <ItemsControl ItemsSource="{Binding AvaloniaToolboxItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemViewModel">
                          <controls:PaletteItemControl />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Library" />
                        <TextBlock Classes="section-title"
                                   Text="Reusable symbols" />
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="8">
                        <Button Content="Edit"
                                Command="{Binding EnterSelectedSymbolEditCommand}"
                                IsEnabled="{Binding CanEnterSymbolEdit}" />
                        <Button Content="Place"
                                Command="{Binding InsertSelectedLibraryItemCommand}"
                                IsEnabled="{Binding CanInsertFromLibrary}" />
                      </StackPanel>
                      <Button Grid.Column="2"
                              Content="Relink"
                              Classes="warm"
                              Command="{Binding RelinkSelectionToSelectedLibraryItemCommand}"
                              IsEnabled="{Binding CanRelinkSelectionToSelectedLibraryItem}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,156"
                          ColumnSpacing="10">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="micro-label"
                                   Text="Search" />
                        <TextBox Watermark="Name, folder, linkage, source"
                                 Text="{Binding LibrarySearchText, Mode=TwoWay}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Spacing="6">
                        <TextBlock Classes="micro-label"
                                   Text="Folder filter" />
                        <ComboBox ItemsSource="{Binding LibraryFolderFilters}"
                                  SelectedItem="{Binding SelectedLibraryFolderFilter, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedLibrarySummary}"
                               TextWrapping="Wrap" />

                    <Border Classes="panel-soft"
                            IsEnabled="{Binding CanEditSelectedLibraryItem}">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow"
                                   Text="Asset Metadata" />
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Asset name" />
                          <TextBox Text="{Binding LibraryItemNameEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Folder path" />
                          <TextBox Watermark="Symbols/Graphics"
                                   Text="{Binding LibraryFolderEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Linkage id" />
                          <TextBox Watermark="hero_card"
                                   Text="{Binding LibraryLinkageIdEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Source path" />
                          <TextBox Watermark="Optional external source"
                                   Text="{Binding LibrarySourceAssetPathEditor, Mode=TwoWay}" />
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding EditingSymbolIsButton}">
                      <TextBlock Classes="micro-label"
                                 Text="Button state" />
                      <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                                SelectedItem="{Binding EditingButtonState, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="New symbol type" />
                      <ComboBox ItemsSource="{Binding AvailableSymbolKinds}"
                                SelectedItem="{Binding SelectedLibrarySymbolKind, Mode=TwoWay}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Content="Capture Selection"
                              Command="{Binding CreateSymbolFromSelectionCommand}"
                              IsEnabled="{Binding CanCreateSymbolFromSelection}" />
                      <Button Grid.Column="1"
                              Content="Update Symbol"
                              Command="{Binding UpdateLinkedSymbolFromSelectionCommand}"
                              IsEnabled="{Binding CanUpdateLinkedSymbol}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding LibraryItems}"
                             SelectedItem="{Binding SelectedLibraryItem, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryItemViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding FolderPathLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding LinkageLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SourceAssetLabel}" />
                              </StackPanel>
                              <StackPanel Grid.Column="2"
                                          Spacing="2"
                                          VerticalAlignment="Center">
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SymbolKindLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding AssetKindLabel}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Components" />
                        <TextBlock Classes="section-title"
                                   Text="Interactive building blocks" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Capture"
                              Command="{Binding CreateComponentFromSelectionCommand}"
                              IsEnabled="{Binding CanCreateComponentFromSelection}" />
                      <Button Grid.Column="2"
                              Content="Place"
                              Classes="warm"
                              Command="{Binding InsertSelectedComponentCommand}"
                              IsEnabled="{Binding CanInsertSelectedComponent}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedComponentSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding ComponentItems}"
                             SelectedItem="{Binding SelectedComponentItem, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryItemViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding ComponentBadge}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Media" />
                        <TextBlock Classes="section-title"
                                   Text="Audio and video clips" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Import Audio"
                              Click="ImportAudioClick" />
                      <Button Grid.Column="2"
                              Content="Import Video"
                              Click="ImportVideoClick" />
                      <Button Grid.Column="3"
                              Content="Place"
                              Classes="warm"
                              Command="{Binding InsertSelectedMediaAssetCommand}"
                              IsEnabled="{Binding CanInsertSelectedMediaAsset}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedMediaSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding MediaAssets}"
                             SelectedItem="{Binding SelectedMediaAsset, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaAssetViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="{Binding PreviewBrush}" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding SourceLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding TimelineLabel}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding KindLabel}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Output">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="6">
                <Border Classes="panel">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Animation Interop" />
                        <TextBlock Classes="section-title"
                                   Text="Import and export runtime animation formats" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="Import"
                              Click="ImportAnimationFormatClick" />
                      <Button Grid.Column="2"
                              Content="Export"
                              Classes="accent"
                              Click="ExportAnimationFormatClick" />
                    </Grid>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Format" />
                      <ComboBox ItemsSource="{Binding AvailableAnimationExchangeFormats}"
                                SelectedItem="{Binding SelectedAnimationExchangeFormat, Mode=TwoWay}" />
                    </StackPanel>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedAnimationExchangeSummary}"
                               TextWrapping="Wrap" />

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="eyebrow"
                                   Text="Last run" />
                        <TextBlock Classes="micro-label"
                                   Text="{Binding LastAnimationExchangeSummaryDisplay}"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding AnimationExchangeIssues}"
                                      IsVisible="{Binding HasAnimationExchangeIssues}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AnimationExchangeIssue">
                              <Border Classes="layer-row">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="strong-label"
                                             Text="{Binding Severity}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Source}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Message}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <Border Classes="panel">
                  <StackPanel Spacing="10"
                              IsEnabled="{Binding CanEditPublishProfiles}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow"
                                   Text="Publish" />
                        <TextBlock Classes="section-title"
                                   Text="Preview and export profiles" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="+ Profile"
                              Command="{Binding AddPublishProfileCommand}" />
                      <Button Grid.Column="2"
                              Content="Copy"
                              Command="{Binding DuplicatePublishProfileCommand}"
                              IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
                      <Button Grid.Column="3"
                              Content="Preview"
                              Click="PreviewPublishProfileClick"
                              IsEnabled="{Binding CanPreviewSelectedPublishProfile}" />
                      <Button Grid.Column="4"
                              Content="Publish"
                              Classes="accent"
                              Click="ExportPublishProfileClick"
                              IsEnabled="{Binding CanExportSelectedPublishProfile}" />
                    </Grid>

                    <TextBlock Classes="micro-label"
                               Text="{Binding SelectedPublishProfileSummary}"
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding PublishProfiles}"
                             SelectedItem="{Binding SelectedPublishProfile, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PublishProfileViewModel">
                          <Border Classes="layer-row">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="14"
                                      Height="14"
                                      CornerRadius="7"
                                      VerticalAlignment="Center"
                                      Background="#57C9FF" />
                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Classes="strong-label"
                                           Text="{Binding Name}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding FormatLabel}" />
                                <TextBlock Classes="micro-label"
                                           Text="{Binding Subtitle}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2"
                                         Classes="micro-label"
                                         VerticalAlignment="Center"
                                         Text="{Binding OutputKind}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="Remove Selected Profile"
                            Classes="warm"
                            Command="{Binding DeletePublishProfileCommand}"
                            IsEnabled="{Binding CanDeletePublishProfile}" />

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow"
                                   Text="Profile setup" />
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Name" />
                          <TextBox Text="{Binding PublishProfileNameEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Classes="micro-label"
                                     Text="Output format" />
                          <ComboBox ItemsSource="{Binding AvailablePublishOutputs}"
                                    SelectedItem="{Binding PublishOutputKindEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Width" />
                            <TextBox Text="{Binding PublishWidthEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Height" />
                            <TextBox Text="{Binding PublishHeightEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <StackPanel Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Frame rate" />
                            <TextBox Text="{Binding PublishFrameRateEditor, Mode=TwoWay}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6">
                            <TextBlock Classes="micro-label"
                                       Text="Quality" />
                            <TextBox Text="{Binding PublishQualityEditor, Mode=TwoWay}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding PublishOutputIsSpriteSheet}">
                          <TextBlock Classes="micro-label"
                                     Text="Sprite sheet columns" />
                          <TextBox Text="{Binding PublishSpriteSheetColumnsEditor, Mode=TwoWay}" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Play all scenes"
                                    IsChecked="{Binding PublishPlayAllScenesEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Transparent background"
                                    IsChecked="{Binding PublishTransparentBackgroundEditor, Mode=TwoWay}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                          <CheckBox Content="Include scene graph"
                                    IsChecked="{Binding PublishIncludeSceneGraphEditor, Mode=TwoWay}" />
                          <CheckBox Grid.Column="1"
                                    Content="Include validation report"
                                    IsChecked="{Binding PublishIncludeValidationReportEditor, Mode=TwoWay}" />
                        </Grid>
                        <TextBlock Classes="micro-label"
                                   IsVisible="{Binding PublishOutputRequiresDirectory}"
                                   Text="This profile publishes into a folder. Supplemental files are written alongside the frame sequence." />
                        <TextBlock Classes="micro-label"
                                   IsVisible="{Binding PublishOutputIsSingleFile}"
                                   Text="This profile publishes a single primary file and optional companion metadata beside it." />
                      </StackPanel>
                    </Border>

                    <Border Classes="panel-soft">
                      <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                          <StackPanel Spacing="2">
                            <TextBlock Classes="eyebrow"
                                       Text="Validation" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding PublishValidationIssues.Count, StringFormat='{}{0} checks'}" />
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Classes="micro-label"
                                     VerticalAlignment="Center"
                                     Text="{Binding HasPublishErrors, StringFormat='Errors block export: {0}'}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding PublishValidationIssues}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PublishValidationIssue">
                              <Border Classes="layer-row">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="strong-label"
                                             Text="{Binding Severity}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Source}" />
                                  <TextBlock Classes="micro-label"
                                             Text="{Binding Message}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="micro-label"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Grid>

      <GridSplitter Grid.Column="1"
                    Classes="panel-splitter vertical"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

      <Grid Grid.Column="2"
            ClipToBounds="False">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" MinHeight="320" />
          <RowDefinition Height="{Binding TimelineSplitterRowHeight}" />
          <RowDefinition Height="{Binding TimelinePanelRowHeight}" />
        </Grid.RowDefinitions>
        <Border Classes="panel"
                Padding="5">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="4">
            <Border Classes="chrome-group"
                    Padding="4,3"
                    ToolTip.Tip="{Binding CanvasViewportHint}">
              <Grid ColumnDefinitions="*,Auto,240"
                    ColumnSpacing="8">
                <StackPanel Spacing="1">
                  <TextBlock Classes="section-title"
                             Text="{Binding SelectionHeadline}" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding SelectedSceneSummary}"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                  <Border Classes="metric-chip">
                    <StackPanel Spacing="1">
                      <TextBlock Classes="eyebrow"
                                 Text="Tool" />
                      <TextBlock Classes="strong-label"
                                 Text="{Binding ToolModeLabel}" />
                    </StackPanel>
                  </Border>
                  <CheckBox Content="Snap"
                            IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                  <CheckBox Content="Onion"
                            IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}" />
                  <Button Classes="toolbar"
                          Content="Fit"
                          Click="CanvasFitClick" />
                  <Button Classes="toolbar"
                          Content="1:1"
                          Click="CanvasActualSizeClick" />
                </StackPanel>

                <Border Grid.Column="2"
                        Classes="chrome-group"
                        Padding="6,3">
                  <Grid ColumnDefinitions="Auto,Auto,*"
                        ColumnSpacing="8">
                    <StackPanel Spacing="1">
                      <TextBlock Classes="eyebrow"
                                 Text="View" />
                      <TextBlock Classes="strong-label"
                                 Text="{Binding CanvasZoomLabel}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="metric-chip"
                            Padding="7,4">
                      <StackPanel Spacing="1">
                        <TextBlock Classes="eyebrow"
                                   Text="Stage" />
                        <TextBlock Classes="strong-label"
                                   Text="{Binding CanvasSizeLabel}" />
                      </StackPanel>
                    </Border>
                    <Slider Grid.Column="2"
                            Minimum="0.25"
                            Maximum="8"
                            Value="{Binding CanvasZoom, Mode=TwoWay}" />
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="stage-workspace"
                    Padding="5">
              <controls:SceneCanvasControl x:Name="SceneCanvas"
                                           Document="{Binding Document}"
                                           Layers="{Binding Layers}"
                                           SelectedLayer="{Binding SelectedLayer}"
                                           CanvasZoom="{Binding CanvasZoom}"
                                           DrawingTool="{Binding SelectedDrawingTool}"
                                           CurrentTime="{Binding CurrentTime}"
                                           FrameRate="{Binding SceneFrameRate}"
                                           TotalFrames="{Binding TotalFrames}"
                                           Duration="{Binding Duration}"
                                           SnapToGrid="{Binding SnapToGrid}"
                                           OnionSkinEnabled="{Binding OnionSkinEnabled}"
                                           OnionSkinBefore="{Binding OnionSkinBefore}"
                                           OnionSkinAfter="{Binding OnionSkinAfter}"
                                           PrototypeMode="{Binding IsPrototypeMode}"
                                           DocumentWidth="{Binding CanvasWidth}"
                                           DocumentHeight="{Binding CanvasHeight}"
                                           BackgroundFrom="{Binding BackgroundFrom}"
                                           BackgroundTo="{Binding BackgroundTo}" />
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Classes="panel-splitter horizontal"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <Border Grid.Row="{Binding TimelinePanelGridRow}"
                Grid.RowSpan="{Binding TimelinePanelRowSpan}"
                Height="{Binding TimelinePanelHostHeight}"
                VerticalAlignment="{Binding TimelinePanelVerticalAlignment}"
                Margin="{Binding TimelinePanelHostMargin}"
                Panel.ZIndex="{Binding TimelinePanelZIndex}"
                IsVisible="{Binding IsTimelinePanelVisible}"
                Classes="panel"
                Padding="5">
          <Grid RowDefinitions="6,Auto,*"
                RowSpacing="4">
            <Border Grid.Row="0"
                    x:Name="TimelineResizeGrip"
                    Classes="timeline-resize-grip"
                    PointerPressed="TimelineResizeGripPointerPressed"
                    PointerMoved="TimelineResizeGripPointerMoved"
                    PointerReleased="TimelineResizeGripPointerReleased"
                    PointerCaptureLost="TimelineResizeGripPointerCaptureLost" />

            <Border Grid.Row="1"
                    Classes="chrome-group"
                    Padding="4,3"
                    ToolTip.Tip="Right click for dock actions">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Focus Timeline"
                            Command="{Binding FocusWorkspaceAreaCommand}"
                            CommandParameter="timeline" />
                  <Separator />
                  <MenuItem Header="Dock"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:dock" />
                  <MenuItem Header="Overlay"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:over" />
                  <MenuItem Header="Hide"
                            Command="{Binding SetWorkspacePanelModeCommand}"
                            CommandParameter="timeline:hide" />
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="Auto,*,180,132,Auto"
                    ColumnSpacing="6">
                <StackPanel Orientation="Horizontal"
                            Spacing="4">
                  <ToggleButton Classes="timeline-tab"
                                MinWidth="78"
                                Content="Frames"
                                IsChecked="{Binding IsFramesTimelineViewActive, Mode=OneWay}"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Frames" />
                  <ToggleButton Classes="timeline-tab"
                                MinWidth="78"
                                Content="Curves"
                                IsChecked="{Binding IsCurvesTimelineViewActive, Mode=OneWay}"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Curves" />
                  <Border Width="1"
                          Height="22"
                          Margin="2,0"
                          Background="#222932"
                          VerticalAlignment="Center" />
                  <Button Classes="timeline-action accent"
                          Content="Play"
                          Command="{Binding TogglePlaybackCommand}" />
                  <Button Classes="timeline-action"
                          Content="Stop"
                          Command="{Binding StopPlaybackCommand}" />
                  <Button Classes="timeline-action"
                          Content="+ Key"
                          Command="{Binding AddCurrentKeyframeCommand}"
                          IsEnabled="{Binding CanEditPropertyTracks}" />
                  <Button Classes="timeline-action"
                          Content="- Key"
                          Command="{Binding DeleteCurrentKeyframeCommand}"
                          IsEnabled="{Binding CanDeleteSelectedKeyframe}" />
                  <ToggleButton Classes="timeline-action"
                                IsChecked="{Binding AutoKey, Mode=TwoWay}"
                                Content="Auto" />
                  <Menu Classes="timeline-toolbar">
                    <MenuItem Classes="timeline-toolbar-item"
                              Header="Playback">
                      <MenuItem Header="Loop playback"
                                ToggleType="CheckBox"
                                IsChecked="{Binding LoopPlayback, Mode=TwoWay}" />
                      <MenuItem Header="Play all scenes"
                                ToggleType="CheckBox"
                                IsChecked="{Binding PlayAllScenes, Mode=TwoWay}" />
                    </MenuItem>
                    <MenuItem Classes="timeline-toolbar-item"
                              Header="Options">
                      <MenuItem Header="Snap timeline"
                                ToggleType="CheckBox"
                                IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                      <Separator />
                      <MenuItem Header="Focus frames view"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Frames" />
                      <MenuItem Header="Focus curves view"
                                Command="{Binding SetTimelineWorkspaceViewCommand}"
                                CommandParameter="Curves" />
                    </MenuItem>
                  </Menu>
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="metric-chip"
                        Padding="8,4">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                    <StackPanel Spacing="1">
                      <TextBlock Classes="eyebrow"
                                 Text="Selection" />
                      <TextBlock Classes="strong-label"
                                 Text="{Binding CurrentFrameLabel}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Classes="micro-label"
                               VerticalAlignment="Center"
                               Text="{Binding TimelineWorkspaceViewSummary}" />
                  </Grid>
                </Border>

                <StackPanel Grid.Column="2"
                            Spacing="2">
                  <TextBlock Classes="eyebrow"
                             Text="Timeline zoom" />
                  <Slider Minimum="90"
                          Maximum="250"
                          Value="{Binding TimelineZoom, Mode=TwoWay}" />
                </StackPanel>

                <Border Grid.Column="3"
                        Classes="metric-chip">
                  <StackPanel Spacing="1">
                    <TextBlock Classes="eyebrow"
                               Text="Frame" />
                    <TextBlock Classes="strong-label"
                               Text="{Binding CurrentFrameLabel}" />
                    <TextBlock Classes="micro-label"
                               Text="{Binding FrameRateLabel}" />
                  </StackPanel>
                </Border>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                  <ToggleButton Classes="toolbar"
                                Content="Dock"
                                IsChecked="{Binding IsTimelinePanelDocked, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:dock" />
                  <ToggleButton Classes="toolbar"
                                Content="Over"
                                IsChecked="{Binding IsTimelinePanelOverlay, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:over" />
                  <ToggleButton Classes="toolbar"
                                Content="Hide"
                                IsChecked="{Binding IsTimelinePanelHidden, Mode=OneWay}"
                                Command="{Binding SetWorkspacePanelModeCommand}"
                                CommandParameter="timeline:hide" />
                </StackPanel>
              </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid IsVisible="{Binding IsFramesTimelineViewActive}"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                  <Border Classes="chrome-group"
                          Padding="4,3">
                    <Grid ColumnDefinitions="Auto,220,*,148"
                          ColumnSpacing="6">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="4">
                        <Menu Classes="timeline-toolbar">
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Insert">
                            <MenuItem Header="Add cel"
                                      Command="{Binding AddFrameKeyframeCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                            <MenuItem Header="Add blank cel"
                                      Command="{Binding AddBlankFrameKeyframeCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                            <MenuItem Header="Extend hold"
                                      Command="{Binding ExtendFrameHoldCommand}"
                                      IsEnabled="{Binding CanEditPropertyTracks}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Range">
                            <MenuItem Header="Copy frame range"
                                      Command="{Binding CopyFrameRangeCommand}"
                                      IsEnabled="{Binding CanCopyFrameRange}" />
                            <MenuItem Header="Paste frame range"
                                      Command="{Binding PasteFrameRangeCommand}"
                                      IsEnabled="{Binding CanPasteFrameRange}" />
                          </MenuItem>
                          <MenuItem Classes="timeline-toolbar-item"
                                    Header="Onion">
                            <MenuItem Header="Enable onion skin"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem Header="Previous frames">
                              <MenuItem Header="0"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:0" />
                              <MenuItem Header="1"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:1" />
                              <MenuItem Header="2"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:2" />
                              <MenuItem Header="3"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:3" />
                              <MenuItem Header="4"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:4" />
                              <MenuItem Header="5"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:5" />
                              <MenuItem Header="6"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="before:6" />
                            </MenuItem>
                            <MenuItem Header="Next frames">
                              <MenuItem Header="0"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:0" />
                              <MenuItem Header="1"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:1" />
                              <MenuItem Header="2"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:2" />
                              <MenuItem Header="3"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:3" />
                              <MenuItem Header="4"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:4" />
                              <MenuItem Header="5"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:5" />
                              <MenuItem Header="6"
                                        Command="{Binding SetOnionSkinCountCommand}"
                                        CommandParameter="after:6" />
                            </MenuItem>
                          </MenuItem>
                        </Menu>
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="4">
                        <TextBox Classes="timeline-entry"
                                 Width="132"
                                 Watermark="Frame label"
                                 Text="{Binding FrameLabelEditor, Mode=TwoWay}" />
                        <Button Classes="timeline-action"
                                Content="Set"
                                Command="{Binding AddOrUpdateFrameLabelCommand}" />
                        <Button Classes="timeline-action"
                                Content="Clear"
                                Command="{Binding RemoveFrameLabelCommand}" />
                      </StackPanel>

                      <Border Grid.Column="2"
                              Classes="metric-chip"
                              Padding="8,4">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10">
                          <StackPanel Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Range" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding SelectedFrameRangeSummary}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Onion prev" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding OnionSkinBefore}" />
                          </StackPanel>
                          <StackPanel Grid.Column="2"
                                      Spacing="1">
                            <TextBlock Classes="eyebrow"
                                       Text="Onion next" />
                            <TextBlock Classes="strong-label"
                                       Text="{Binding OnionSkinAfter}" />
                          </StackPanel>
                        </Grid>
                      </Border>

                      <StackPanel Grid.Column="3"
                                  Spacing="2">
                        <TextBlock Classes="eyebrow"
                                   Text="Frame zoom" />
                        <Slider Minimum="10"
                                Maximum="32"
                                Value="{Binding FrameTimelineZoom, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>
                  </Border>

                  <Border Grid.Row="1"
                          Classes="panel-soft"
                          Padding="0"
                          MinHeight="280">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MinHeight="280">
                      <controls:FrameTimelineControl x:Name="FrameTimeline"
                                                     Width="{Binding FrameTimelineSurfaceWidth}"
                                                     Height="{Binding FrameTimelineSurfaceHeight}"
                                                     Rows="{Binding FrameRows}"
                                                     Labels="{Binding SceneFrameLabels}"
                                                     CurrentFrame="{Binding CurrentFrame}"
                                                     TotalFrames="{Binding TotalFrames}"
                                                     PixelsPerFrame="{Binding FrameTimelineZoom}"
                                                     SelectedLayerId="{Binding SelectedLayerId}"
                                                     SelectionStartFrame="{Binding SelectionStartFrame}"
                                                     SelectionEndFrame="{Binding SelectionEndFrame}" />
                    </ScrollViewer>
                  </Border>
                </Grid>

                <Grid IsVisible="{Binding IsCurvesTimelineViewActive}"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                  <Border Classes="chrome-group"
                          Padding="4,3">
                    <Grid ColumnDefinitions="*,*,180"
                          ColumnSpacing="6">
                      <Border Classes="metric-chip">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Keyframe" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding SelectedKeyframeSummary}" />
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="1"
                              Classes="metric-chip">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Shape tween" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding ShapeTweenSummary}" />
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="2"
                              Classes="panel-soft"
                              Padding="8,5">
                        <StackPanel Spacing="1">
                          <TextBlock Classes="eyebrow"
                                     Text="Playhead" />
                          <TextBlock Classes="strong-label"
                                     Text="{Binding CurrentTimeLabel}" />
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>

                  <Border Grid.Row="1"
                          Classes="panel-soft"
                          Padding="0"
                          MinHeight="300">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MinHeight="300">
                      <controls:TimelineEditorControl x:Name="TimelineEditor"
                                                      Width="{Binding TimelineSurfaceWidth}"
                                                      Height="{Binding TimelineSurfaceHeight}"
                                                      Rows="{Binding TimelineRows}"
                                                      CurrentTime="{Binding CurrentTime}"
                                                      Duration="{Binding Duration}"
                                                      SelectedProperty="{Binding SelectedProperty}"
                                                      SelectedKeyframeId="{Binding SelectedKeyframeId}"
                                                      PixelsPerSecond="{Binding TimelineZoom}" />
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Grid>
            </Grid>
        </Border>

        <Button Classes="toolbar edge-handle"
                Content="Tools"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="8,0,0,0"
                IsVisible="{Binding IsLeftPanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="left" />

        <Button Classes="toolbar edge-handle"
                Content="Inspector"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                IsVisible="{Binding IsRightPanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="right" />

        <Button Classes="toolbar edge-handle"
                Content="Timeline"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                IsVisible="{Binding IsTimelinePanelCollapsedHandleVisible}"
                Command="{Binding ToggleWorkspacePanelCommand}"
                CommandParameter="timeline" />
      </Grid>

      <GridSplitter Grid.Column="3"
                    Classes="panel-splitter vertical"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

      <TabControl Grid.Column="{Binding RightPanelGridColumn}"
                  Grid.ColumnSpan="{Binding RightPanelColumnSpan}"
                  Width="{Binding RightPanelHostWidth}"
                  HorizontalAlignment="{Binding RightPanelHorizontalAlignment}"
                  Margin="{Binding RightPanelHostMargin}"
                  Panel.ZIndex="{Binding RightPanelZIndex}"
                  IsVisible="{Binding IsRightPanelVisible}"
                  Classes="dock-tabs">
        <TabItem Header="Properties">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">
          <Border Classes="panel">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                    ColumnSpacing="4"
                    ToolTip.Tip="Right click for dock actions">
                <Grid.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Focus Inspector"
                              Command="{Binding FocusWorkspaceAreaCommand}"
                              CommandParameter="inspector" />
                    <Separator />
                    <MenuItem Header="Dock"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:dock" />
                    <MenuItem Header="Overlay"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:over" />
                    <MenuItem Header="Hide"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:hide" />
                  </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock Classes="section-title"
                           VerticalAlignment="Center"
                           Text="Inspector" />
                <ToggleButton Grid.Column="1"
                              Classes="toolbar"
                              Content="Dock"
                              IsChecked="{Binding IsRightPanelDocked, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:dock" />
                <ToggleButton Grid.Column="2"
                              Classes="toolbar"
                              Content="Over"
                              IsChecked="{Binding IsRightPanelOverlay, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:over" />
                <ToggleButton Grid.Column="3"
                              Classes="toolbar"
                              Content="Hide"
                              IsChecked="{Binding IsRightPanelHidden, Mode=OneWay}"
                              Command="{Binding SetWorkspacePanelModeCommand}"
                              CommandParameter="right:hide" />
              </Grid>
              <TextBlock Classes="section-title"
                         Text="{Binding SelectionHeadline}" />
              <Border Classes="panel-soft">
                <TextBlock Classes="micro-label"
                           Text="{Binding SelectedLayerStateLabel}"
                           TextWrapping="Wrap" />
              </Border>

              <Border Classes="panel-soft"
                      IsVisible="{Binding SelectedLayerIsSymbolInstance}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="eyebrow"
                             Text="Symbol Instance" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Playback mode" />
                    <ComboBox ItemsSource="{Binding AvailableSymbolPlaybackModes}"
                              SelectedItem="{Binding SymbolPlaybackModeEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Time offset" />
                      <TextBox Text="{Binding SymbolPlaybackOffsetEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Locked frame" />
                      <TextBox Text="{Binding SymbolLockedFrameEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6"
                              IsVisible="{Binding SelectedSymbolInstanceIsButton}">
                    <TextBlock Classes="micro-label"
                               Text="Button preview state" />
                    <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                              SelectedItem="{Binding SymbolButtonStateEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <StackPanel Spacing="10"
                          IsEnabled="{Binding CanEditSelection}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Name" />
                  <TextBox Text="{Binding LayerNameEditor, Mode=TwoWay}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      RowDefinitions="Auto,Auto,Auto">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="X" />
                    <TextBox Text="{Binding InspectorX, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Y" />
                    <TextBox Text="{Binding InspectorY, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Width" />
                    <TextBox Text="{Binding InspectorWidth, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1"
                              Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Height" />
                    <TextBox Text="{Binding InspectorHeight, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="2"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Rotation" />
                    <TextBox Text="{Binding InspectorRotation, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Row="2"
                              Grid.Column="1"
                              Spacing="6"
                              IsVisible="{Binding SelectedLayerSupportsCornerRadius}">
                    <TextBlock Classes="micro-label"
                               Text="Corner radius" />
                    <TextBox Text="{Binding InspectorCornerRadius, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">
                    <TextBlock Classes="micro-label"
                               Text="Opacity" />
                    <TextBlock Grid.Column="1"
                               Classes="micro-label"
                               Text="{Binding InspectorOpacity, StringFormat='{}{0:0.00}'}" />
                  </Grid>
                  <Slider Minimum="0"
                          Maximum="1"
                          Value="{Binding InspectorOpacity, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="8"
                            IsEnabled="{Binding CanAlignSelection}">
                  <TextBlock Classes="micro-label"
                             Text="Align to stage" />
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8"
                        RowDefinitions="Auto,Auto">
                    <Button Content="Left"
                            Command="{Binding AlignLeftCommand}" />
                    <Button Grid.Column="1"
                            Content="Center"
                            Command="{Binding AlignCenterCommand}" />
                    <Button Grid.Column="2"
                            Content="Right"
                            Command="{Binding AlignRightCommand}" />
                    <Button Grid.Row="1"
                            Content="Top"
                            Command="{Binding AlignTopCommand}" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Content="Middle"
                            Command="{Binding AlignMiddleCommand}" />
                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Content="Bottom"
                            Command="{Binding AlignBottomCommand}" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditStyleSurface}">
              <TextBlock Classes="eyebrow"
                         Text="Style" />
              <TextBlock Classes="section-title"
                         Text="Look and content" />

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Fill" />
                <TextBox Text="{Binding FillHexEditor, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Stroke" />
                <TextBox Text="{Binding StrokeHexEditor, Mode=TwoWay}" />
              </StackPanel>

              <UniformGrid Columns="4"
                           Rows="2">
                <Button Background="#24E5C1"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#24E5C1" />
                <Button Background="#FF8A4C"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#FF8A4C" />
                <Button Background="#F7F5ED"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#F7F5ED" />
                <Button Background="#6D8DFF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#6D8DFF" />
                <Button Background="#FF5F79"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#FF5F79" />
                <Button Background="#A7FF5A"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#A7FF5A" />
                <Button Background="#61E6FF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#61E6FF" />
                <Button Background="#B093FF"
                        Command="{Binding ApplyFillPresetCommand}"
                        CommandParameter="#B093FF" />
              </UniformGrid>

              <UniformGrid Columns="4"
                           Rows="2">
                <Button Background="#FFFFFF"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFFFFF" />
                <Button Background="#FFE6D1"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFE6D1" />
                <Button Background="#93A6D8"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#93A6D8" />
                <Button Background="#9BFFF0"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#9BFFF0" />
                <Button Background="#FFD166"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FFD166" />
                <Button Background="#FF5F79"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#FF5F79" />
                <Button Background="#61E6FF"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#61E6FF" />
                <Button Background="#A7FF5A"
                        Command="{Binding ApplyStrokePresetCommand}"
                        CommandParameter="#A7FF5A" />
              </UniformGrid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Stroke width" />
                  <TextBox Text="{Binding StrokeThicknessEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient fill" />
                  <CheckBox Content="Use gradient"
                            IsChecked="{Binding UseGradientEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10"
                    IsVisible="{Binding UseGradientEditor}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient from" />
                  <TextBox Text="{Binding GradientFromEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Gradient to" />
                  <TextBox Text="{Binding GradientToEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6"
                          IsVisible="{Binding SelectedLayerIsPath}">
                <CheckBox Content="Close path"
                          IsChecked="{Binding PathClosedEditor, Mode=TwoWay}" />
                <TextBlock Classes="micro-label"
                           IsVisible="{Binding CanEditPathPoints}"
                           Text="Drag vector points directly on the stage to reshape the selected path." />
              </StackPanel>

              <StackPanel IsVisible="{Binding SelectedLayerIsText}"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Text" />
                <TextBox Text="{Binding TextEditor, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="92"
                         TextWrapping="Wrap" />
                <TextBlock Classes="micro-label"
                           Text="Font size" />
                <TextBox Text="{Binding InspectorFontSize, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel IsVisible="{Binding SelectedLayerIsAvaloniaControl}"
                          Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Avalonia control content" />
                <TextBox Text="{Binding AvaloniaControlContentEditor, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="72"
                         TextWrapping="Wrap" />
                <TextBlock Classes="micro-label"
                           Text="Secondary content" />
                <TextBox Text="{Binding AvaloniaControlSecondaryContentEditor, Mode=TwoWay}" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <CheckBox Content="Checked"
                            IsChecked="{Binding AvaloniaControlIsCheckedEditor, Mode=TwoWay}" />
                  <CheckBox Grid.Column="1"
                            Content="Indeterminate"
                            IsChecked="{Binding AvaloniaControlIsIndeterminateEditor, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Minimum" />
                    <TextBox Text="{Binding AvaloniaControlMinimumEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Maximum" />
                    <TextBox Text="{Binding AvaloniaControlMaximumEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Value" />
                  <TextBox Text="{Binding AvaloniaControlValueEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Image source" />
                  <TextBox Text="{Binding AvaloniaControlSourceEditor, Mode=TwoWay}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditSelection}">
              <TextBlock Classes="eyebrow"
                         Text="Compositing" />
              <TextBlock Classes="section-title"
                         Text="Masks, blends, effects" />
              <TextBlock Classes="micro-label"
                         Text="{Binding CompositingSummary}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Layer role" />
                  <ComboBox ItemsSource="{Binding AvailableCompositeRoles}"
                            SelectedItem="{Binding LayerRoleEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Blend mode" />
                  <ComboBox ItemsSource="{Binding AvailableBlendModes}"
                            SelectedItem="{Binding LayerBlendModeEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6"
                          IsVisible="{Binding SelectedLayerIsMask}">
                <TextBlock Classes="micro-label"
                           Text="Mask target count" />
                <TextBox Text="{Binding MaskLayerCountEditor, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Parallax depth" />
                <TextBox Text="{Binding LayerParallaxDepthEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Blur radius" />
                  <TextBox Text="{Binding LayerBlurEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Brightness" />
                  <TextBox Text="{Binding LayerBrightnessEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Tint color" />
                  <TextBox Text="{Binding LayerTintColorEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Tint strength" />
                  <TextBox Text="{Binding LayerTintStrengthEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Classes="micro-label"
                             Text="Saturation" />
                  <TextBlock Grid.Column="1"
                             Classes="micro-label"
                             Text="{Binding LayerSaturationEditor, StringFormat='{}{0:0.00}'}" />
                </Grid>
                <Slider Minimum="0"
                        Maximum="2"
                        Value="{Binding LayerSaturationEditor, Mode=TwoWay}" />
              </StackPanel>

              <Border Classes="panel-soft">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Glow" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Color" />
                      <TextBox Text="{Binding LayerGlowColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Size" />
                      <TextBox Text="{Binding LayerGlowSizeEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBlock Classes="micro-label"
                                 Text="Opacity" />
                      <TextBlock Grid.Column="1"
                                 Classes="micro-label"
                                 Text="{Binding LayerGlowOpacityEditor, StringFormat='{}{0:0.00}'}" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding LayerGlowOpacityEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="panel-soft">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Shadow" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Color" />
                      <TextBox Text="{Binding LayerShadowColorEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Blur" />
                      <TextBox Text="{Binding LayerShadowBlurEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Offset X" />
                      <TextBox Text="{Binding LayerShadowOffsetXEditor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Offset Y" />
                      <TextBox Text="{Binding LayerShadowOffsetYEditor, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBlock Classes="micro-label"
                                 Text="Opacity" />
                      <TextBlock Grid.Column="1"
                                 Classes="micro-label"
                                 Text="{Binding LayerShadowOpacityEditor, StringFormat='{}{0:0.00}'}" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding LayerShadowOpacityEditor, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10"
                        IsEnabled="{Binding CanEditSelection}"
                        IsVisible="{Binding SelectedLayerIsMedia}">
              <TextBlock Classes="eyebrow"
                         Text="Media" />
              <TextBlock Classes="section-title"
                         Text="Clip timing and playback" />
              <TextBlock Classes="micro-label"
                         Text="{Binding MediaLayerSummary}"
                         TextWrapping="Wrap" />

              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Playback mode" />
                <ComboBox ItemsSource="{Binding AvailableMediaPlaybackModes}"
                          SelectedItem="{Binding MediaPlaybackModeEditor, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Start time" />
                  <TextBox Text="{Binding MediaStartTimeEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Clip offset" />
                  <TextBox Text="{Binding MediaClipOffsetEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Clip duration" />
                  <TextBox Text="{Binding MediaClipDurationEditor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Looping" />
                  <CheckBox Content="Loop clip"
                            IsChecked="{Binding MediaLoopEditor, Mode=TwoWay}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Classes="micro-label"
                             Text="Volume" />
                  <TextBlock Grid.Column="1"
                             Classes="micro-label"
                             Text="{Binding MediaVolumeEditor, StringFormat='{}{0:0.00}'}" />
                </Grid>
                <Slider Minimum="0"
                        Maximum="1"
                        Value="{Binding MediaVolumeEditor, Mode=TwoWay}" />
              </StackPanel>
            </StackPanel>
          </Border>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Motion + Actions">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">

          <Border Classes="panel">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Behaviors" />
                  <TextBlock Classes="section-title"
                             Text="Events and lightweight actions" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="+ Event"
                        Command="{Binding AddBehaviorCommand}"
                        IsEnabled="{Binding CanAddBehavior}" />
                <Button Grid.Column="2"
                        Content="Remove"
                        Classes="warm"
                        Command="{Binding DeleteSelectedBehaviorCommand}"
                        IsEnabled="{Binding CanDeleteSelectedBehavior}" />
              </Grid>

              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedBehaviorSummary}"
                         TextWrapping="Wrap" />

              <ListBox ItemsSource="{Binding Behaviors}"
                       SelectedItem="{Binding SelectedBehavior, Mode=TwoWay}"
                       MinHeight="120">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:InteractionBehaviorViewModel">
                    <Border Classes="layer-row">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="strong-label"
                                   Text="{Binding Name}" />
                        <TextBlock Classes="micro-label"
                                   Text="{Binding Summary}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Spacing="8"
                          IsEnabled="{Binding CanEditBehaviors}">
                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Behavior name" />
                  <TextBox Text="{Binding SelectedBehaviorNameEditor, Mode=TwoWay}" />
                </StackPanel>

                <CheckBox Content="Enabled"
                          IsChecked="{Binding SelectedBehaviorEnabledEditor, Mode=TwoWay}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Trigger" />
                    <ComboBox ItemsSource="{Binding AvailableInteractionTriggers}"
                              SelectedItem="{Binding SelectedBehaviorTriggerEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6"
                              IsVisible="{Binding SelectedBehaviorUsesTriggerArgument}">
                    <TextBlock Classes="micro-label"
                               Text="Frame label" />
                    <TextBox Text="{Binding SelectedBehaviorTriggerArgumentEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="6">
                  <TextBlock Classes="micro-label"
                             Text="Action" />
                  <ComboBox ItemsSource="{Binding AvailableInteractionActions}"
                            SelectedItem="{Binding SelectedBehaviorActionEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetScene}">
                  <TextBlock Classes="micro-label"
                             Text="Target scene" />
                  <ComboBox ItemsSource="{Binding Scenes}"
                            SelectedItem="{Binding SelectedBehaviorTargetScene, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:SceneViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetFrameLabel}">
                  <TextBlock Classes="micro-label"
                             Text="Target frame label" />
                  <TextBox Text="{Binding SelectedBehaviorTargetFrameLabelEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesTargetLayer}">
                  <TextBlock Classes="micro-label"
                             Text="Target layer" />
                  <ComboBox ItemsSource="{Binding Layers}"
                            SelectedItem="{Binding SelectedBehaviorTargetLayer, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:LayerViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesButtonState}">
                  <TextBlock Classes="micro-label"
                             Text="Button state" />
                  <ComboBox ItemsSource="{Binding AvailableButtonStates}"
                            SelectedItem="{Binding SelectedBehaviorTargetButtonStateEditor, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="6"
                            IsVisible="{Binding SelectedBehaviorUsesBoolValue}">
                  <CheckBox Content="Show target layer"
                            IsChecked="{Binding SelectedBehaviorBoolValueEditor, Mode=TwoWay}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      IsVisible="{Binding SelectedBehaviorUsesVariable}">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Variable" />
                    <TextBox Text="{Binding SelectedBehaviorVariableNameEditor, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Classes="micro-label"
                               Text="Value" />
                    <TextBox Text="{Binding SelectedBehaviorVariableValueEditor, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="10">
              <TextBlock Classes="eyebrow"
                         Text="Actions" />
              <TextBlock Classes="section-title"
                         Text="Frame scripts and behavior code" />

              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditCurrentFrameActionScript}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Current frame action" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding CurrentFrameActionSummary}"
                             TextWrapping="Wrap" />
                  <TextBox Text="{Binding FrameActionScriptEditor, Mode=TwoWay}"
                           AcceptsReturn="True"
                           Height="132"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="panel-soft"
                      IsEnabled="{Binding CanEditSelectedBehaviorScript}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Selected behavior script" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding SelectedBehaviorScriptSummary}"
                             TextWrapping="Wrap" />
                  <TextBox Text="{Binding SelectedBehaviorScriptEditor, Mode=TwoWay}"
                           AcceptsReturn="True"
                           Height="148"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="panel-soft">
                <StackPanel Spacing="6">
                  <TextBlock Classes="eyebrow"
                             Text="Command set" />
                  <TextBlock Classes="micro-label"
                             Text='play, stop, goto_scene "Scene", goto_label "Label", goto_frame 24, show "Layer", hide "Layer", set_var score 10, set_text "Layer" "HELLO", set_button "Layer" Over, trace "message"'
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="8">
              <TextBlock Classes="eyebrow"
                         Text="Animation" />
              <TextBlock Classes="section-title"
                         Text="Track focus" />
              <TextBlock Classes="micro-label"
                         Text="{Binding SelectedKeyframeSummary}"
                         TextWrapping="Wrap" />
              <StackPanel Spacing="6">
                <TextBlock Classes="micro-label"
                           Text="Selected keyframe easing" />
                <ComboBox ItemsSource="{Binding AvailableEasings}"
                          SelectedItem="{Binding SelectedKeyframeEasing, Mode=TwoWay}"
                          IsEnabled="{Binding CanDeleteSelectedKeyframe}" />
              </StackPanel>
              <Border Classes="panel-soft"
                      IsVisible="{Binding HasSelectedCustomEasing}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Custom Curve" />
                  <controls:EasingCurveEditorControl Height="220"
                                                    ControlPoint1X="{Binding CustomEaseControl1X, Mode=TwoWay}"
                                                    ControlPoint1Y="{Binding CustomEaseControl1Y, Mode=TwoWay}"
                                                    ControlPoint2X="{Binding CustomEaseControl2X, Mode=TwoWay}"
                                                    ControlPoint2Y="{Binding CustomEaseControl2Y, Mode=TwoWay}"
                                                    IsEnabled="{Binding CanEditCustomEasingCurve}" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle A X" />
                      <TextBox Text="{Binding CustomEaseControl1X, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle A Y" />
                      <TextBox Text="{Binding CustomEaseControl1Y, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle B X" />
                      <TextBox Text="{Binding CustomEaseControl2X, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="6">
                      <TextBlock Classes="micro-label"
                                 Text="Handle B Y" />
                      <TextBox Text="{Binding CustomEaseControl2Y, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
              <Border Classes="panel-soft"
                      IsVisible="{Binding SelectedLayerIsPath}">
                <StackPanel Spacing="10">
                  <TextBlock Classes="eyebrow"
                             Text="Shape Tween" />
                  <TextBlock Classes="micro-label"
                             Text="{Binding ShapeTweenSummary}"
                             TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <Button Content="Capture Morph Key"
                            Command="{Binding CaptureShapeKeyframeCommand}"
                            IsEnabled="{Binding CanCaptureShapeKeyframe}" />
                    <Button Grid.Column="1"
                            Content="Delete Morph Key"
                            Classes="warm"
                            Command="{Binding DeleteCurrentShapeKeyframeCommand}"
                            IsEnabled="{Binding CanDeleteCurrentShapeKeyframe}" />
                  </Grid>
                </StackPanel>
              </Border>
              <Border Classes="panel-soft">
                <StackPanel Spacing="4">
                  <TextBlock Classes="eyebrow"
                             Text="Editing model" />
                  <TextBlock Classes="micro-label"
                             Text="Canvas edits and inspector changes update the current playhead. Away from zero or with auto-key enabled, the editor writes keyframes automatically."
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Classes="micro-label"
                         Text="Selecting a layer on the stage now reveals its motion path and animated waypoints directly on the canvas."
                         TextWrapping="Wrap" />
              <TextBlock Classes="micro-label"
                         Text="Sequence rendering exports 30 fps PNG frames to the selected folder."
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</Window>
